{% liquid
  assign tab_blocks = section.blocks | where: 'type', 'tab'
%}

<section
  id="prime-bundles-{{ section.id }}"
  class="prime-bundles section-prime-bundles"
  data-money-format="{{ shop.money_format | escape }}"
  data-cart-add-url="{{ routes.cart_add_url }}"
  data-checkout-url="{{ routes.checkout_url }}"
  style="
    --pb-bg: {{ section.settings.bg_color }};
    --pb-accent: {{ section.settings.accent_color }};
    --pb-card-bg: {{ section.settings.card_bg }};
    --pb-cart-bg: {{ section.settings.cart_button_bg }};
    --pb-shop-bg: {{ section.settings.shop_button_bg }};
    --pb-content-width: {{ section.settings.content_width }};
    --pb-content-width-mobile: {{ section.settings.content_width_mobile }};
    --pb-content-height: {{ section.settings.content_height }};
    --pb-section-pt: {{ section.settings.padding_top }};
    --pb-section-pb: {{ section.settings.padding_bottom }};
    --pb-section-pt-mobile: {{ section.settings.padding_top_mobile }};
    --pb-section-pb-mobile: {{ section.settings.padding_bottom_mobile }};
  "
>
  <div class="prime-bundles__inner">
    <div class="prime-bundles__header">
      {% render 'xmas-section-header' %}
    </div>

    <div class="prime-bundles__tabs" role="tablist" aria-label="{{ section.settings.title | default: 'Prime bundles' | escape }}">
      {% assign has_active_tab = false %}
      {% for block in tab_blocks %}
        {% if block.settings.tab_label != blank %}
          <button
            type="button"
            class="prime-bundles__tab{% unless has_active_tab %} is-active{% endunless %}"
            role="tab"
            aria-selected="{% unless has_active_tab %}true{% else %}false{% endunless %}"
            aria-controls="prime-bundles-panel-{{ section.id }}-{{ block.id }}"
            id="prime-bundles-tab-{{ section.id }}-{{ block.id }}"
            data-pb-tab="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <span>{{ block.settings.tab_label | escape }}</span>
            {% if block.settings.tab_badge != blank %}
              <em>{{ block.settings.tab_badge | escape }}</em>
            {% endif %}
          </button>
          {% assign has_active_tab = true %}
        {% endif %}
      {% endfor %}
    </div>

    <div class="prime-bundles__panels">
      {% assign has_active_panel = false %}
      {% for block in tab_blocks %}
        {% if block.settings.tab_label != blank %}
          {% assign media_bg = block.settings.media_bg_pc | default: block.settings.media_bg_mobile %}
          {% assign slides_count = block.settings.slides_count | default: '2.2' | plus: 0.0 %}
          {% assign slides_count_mobile = block.settings.slides_count_mobile | default: '2.1' | plus: 0.0 %}
          {% assign slide_width = 100.0 | divided_by: slides_count %}
          {% assign slide_width_mobile = 100.0 | divided_by: slides_count_mobile %}
          {% assign product_collection = block.settings.product_collection %}
          {% assign product_limit = block.settings.product_limit %}
          {% assign product_count = product_collection.products_count | default: 0 %}
          <div
            class="prime-bundles__panel{% unless has_active_panel %} is-active{% endunless %}"
            id="prime-bundles-panel-{{ section.id }}-{{ block.id }}"
            role="tabpanel"
            aria-labelledby="prime-bundles-tab-{{ section.id }}-{{ block.id }}"
            data-pb-panel="{{ block.id }}"
            data-compare-discount="{{ block.settings.compare_discount_percent | escape }}"
            style="
              --pb-slide-width: {{ slide_width }}%;
              --pb-slide-width-mobile: {{ slide_width_mobile }}%;
              --pb-media-bg-position: {{ block.settings.media_bg_position }};
              --pb-media-bg-position-mobile: {{ block.settings.media_bg_position_mobile }};
              --pb-media-bg-size: {{ block.settings.media_bg_size }};
              --pb-media-bg-size-mobile: {{ block.settings.media_bg_size_mobile }};
              --pb-badge-top: {{ block.settings.badge_top }};
              --pb-badge-left: {{ block.settings.badge_left }};
              --pb-badge-top-mobile: {{ block.settings.badge_top_mobile }};
              --pb-badge-left-mobile: {{ block.settings.badge_left_mobile }};
              --pb-badge-width: {{ block.settings.badge_width }};
              --pb-badge-height: {{ block.settings.badge_height }};
              --pb-badge-width-mobile: {{ block.settings.badge_width_mobile }};
              --pb-badge-height-mobile: {{ block.settings.badge_height_mobile }};
              --pb-badge-color: {{ block.settings.badge_text_color }};
              {% if media_bg != blank %}
                --pb-media-bg-image: url('{{ media_bg | image_url: width: 1200 }}');
              {% endif %}
              {% if block.settings.media_bg_mobile != blank %}
                --pb-media-bg-image-mobile: url('{{ block.settings.media_bg_mobile | image_url: width: 900 }}');
              {% elsif media_bg != blank %}
                --pb-media-bg-image-mobile: url('{{ media_bg | image_url: width: 900 }}');
              {% endif %}
            "
            {% if has_active_panel %}hidden{% endif %}
          >
            <div class="prime-bundles__content">
              <div class="prime-bundles__media">
                {% if block.settings.show_badge and block.settings.badge_text != blank %}
                  <div class="prime-bundles__badge">
                    {% if block.settings.badge_bg_image != blank %}
                      {{ block.settings.badge_bg_image | image_url: width: 240 | image_tag: loading: 'lazy', alt: block.settings.badge_text }}
                    {% endif %}
                    <span>{{ block.settings.badge_text | escape | newline_to_br }}</span>
                  </div>
                {% endif %}

              </div>

              <div class="prime-bundles__products">
                {% if product_collection != blank and product_count > 0 %}
                  <div class="prime-bundles__carousel-shell">
                    <button type="button" class="prime-bundles__arrow prime-bundles__arrow--prev" data-pb-prev aria-label="Previous products">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15.5 5 8.5 12l7 7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>

                    <div class="prime-bundles__viewport">
                      <div class="prime-bundles__carousel" data-pb-carousel>
                        {% for product_item in product_collection.products limit: product_limit %}
                          {% assign variant = product_item.selected_or_first_available_variant %}
                          {% assign product_image = product_item.featured_image %}
                          {% assign compare_price = variant.compare_at_price %}
                          {% assign item_id = 'pb-product-' | append: section.id | append: '-' | append: block.id | append: '-' | append: forloop.index %}
                          <label class="prime-bundles__product" for="{{ item_id }}">
                            <input
                              id="{{ item_id }}"
                              type="checkbox"
                              class="prime-bundles__check"
                              data-pb-product
                              data-variant-id="{{ variant.id }}"
                              data-price="{{ variant.price }}"
                              data-compare-price="{{ compare_price | default: variant.price }}"
                              {% unless variant.available %}disabled{% endunless %}
                            >
                            <span class="prime-bundles__checkmark" aria-hidden="true"></span>
                            <span class="prime-bundles__product-media">
                              {% if product_image != blank %}
                                {{ product_image | image_url: width: 420 | image_tag: loading: 'lazy', alt: product_item.title }}
                              {% endif %}
                            </span>
                            <span class="prime-bundles__product-title">{{ product_item.title | escape }}</span>
                            <span class="prime-bundles__product-price">
                              <strong>{{ variant.price | money }}</strong>
                              {% if compare_price > variant.price %}
                                <s>{{ compare_price | money }}</s>
                              {% endif %}
                            </span>
                          </label>
                        {% endfor %}
                      </div>
                    </div>

                    <button type="button" class="prime-bundles__arrow prime-bundles__arrow--next" data-pb-next aria-label="Next products">
                      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m8.5 5 7 7-7 7" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                  </div>

                  <div class="prime-bundles__summary">
                    <div class="prime-bundles__total-wrap">
                      <span class="prime-bundles__total-label">{{ section.settings.total_label | escape }}</span>
                      <div class="prime-bundles__price-row">
                        <strong class="prime-bundles__total" data-pb-total>{{ 0 | money }}</strong>
                        <s class="prime-bundles__compare-total" data-pb-compare-total>{{ 0 | money }}</s>
                        <span
                          class="prime-bundles__discount-label"
                          data-pb-discount-label
                          style="--pb-discount-label-bg: {{ section.settings.discount_label_bg }}; --pb-discount-label-color: {{ section.settings.discount_label_color }};"
                          hidden
                        ></span>
                      </div>
                    </div>
                    <div class="prime-bundles__actions">
                      <button type="button" class="prime-bundles__shop" data-pb-shop data-checkout-link="{{ section.settings.checkout_link | escape }}">
                        {{ section.settings.shop_label | escape }}
                      </button>
                      <button type="button" class="prime-bundles__cart" data-pb-cart aria-label="{{ section.settings.cart_aria_label | escape }}">
                        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.8 8.2h12.8l-1.3 7.1a2.1 2.1 0 0 1-2.1 1.7H9.1A2.1 2.1 0 0 1 7 15.2L5.8 5.5H3.5" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"/><path d="M13.2 10.8v3.4M11.5 12.5h3.4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="9.7" cy="20" r="1.35" fill="currentColor"/><circle cx="16.8" cy="20" r="1.35" fill="currentColor"/></svg>
                      </button>
                    </div>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
          {% assign has_active_panel = true %}
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="prime-bundles__toast" role="status" aria-live="polite"></div>
</section>

<style>
  .section-prime-bundles {
    --vp-s: 1px;
  }

  @media screen and (min-width: 850px) and (max-width: 1500px) {
    .section-prime-bundles {
      --vp-s: calc(100vw / 1500);
    }
  }

  @media screen and (max-width: 849px) {
    .section-prime-bundles {
      --vp-s: calc(100vw / 375);
    }
  }

  #prime-bundles-{{ section.id }} {
    padding: calc(var(--pb-section-pt) * var(--vp-s)) 0 calc(var(--pb-section-pb) * var(--vp-s));
    background: var(--pb-bg);
    overflow: hidden;
  }

  #prime-bundles-{{ section.id }} * {
    box-sizing: border-box;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__inner {
    width: calc(var(--pb-content-width) * var(--vp-s));
    max-width: calc(100% - calc(40 * var(--vp-s)));
    margin: 0 auto;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__header {
    margin-bottom: calc(30 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .xmax_section__header {
    margin-top: 0;
    margin-bottom: 0;
    gap: calc(8 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .xmax_section__title-row {
    gap: calc(16 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .xmax_section__title {
    color: {{ section.settings.title_color }};
    font-size: calc({{ section.settings.title_size }} * var(--vp-s));
    line-height: calc({{ section.settings.title_line_height }} * var(--vp-s));
    font-weight: 800;
    letter-spacing: 0;
  }

  #prime-bundles-{{ section.id }} .xmax_section__title-icon {
    width: calc({{ section.settings.title_icon_size }} * var(--vp-s));
    height: calc({{ section.settings.title_icon_size }} * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .xmas-sub-heading {
    color: {{ section.settings.sub_heading_color }};
    font-size: calc({{ section.settings.sub_heading_size }} * var(--vp-s));
    line-height: calc({{ section.settings.sub_heading_line_height }} * var(--vp-s));
    margin: 0;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__tabs {
    display: flex;
    justify-content: center;
    gap: calc(8 * var(--vp-s));
    margin-bottom: calc(26 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__tab {
    min-width: calc(194 * var(--vp-s));
    min-height: calc(38 * var(--vp-s));
    padding: calc(7 * var(--vp-s)) calc(34 * var(--vp-s));
    border: 0;
    border-radius: calc(999 * var(--vp-s));
    background: #fff;
    color: #2a2728;
    font-size: calc(15 * var(--vp-s));
    line-height: calc(20 * var(--vp-s));
    font-weight: 800;
    cursor: pointer;
    letter-spacing: 0;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__tab.is-active {
    background: var(--pb-accent);
    color: #fff;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__tab em {
    display: inline-flex;
    align-items: center;
    min-height: calc(22 * var(--vp-s));
    margin-left: calc(5 * var(--vp-s));
    padding: calc(2 * var(--vp-s)) calc(8 * var(--vp-s));
    border-radius: calc(5 * var(--vp-s));
    background: #22c979;
    color: #fff;
    font-size: calc(12 * var(--vp-s));
    line-height: calc(16 * var(--vp-s));
    font-style: normal;
    vertical-align: middle;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__panel[hidden] {
    display: none;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__content {
    display: grid;
    grid-template-columns: calc(515 * var(--vp-s)) minmax(0, 1fr);
    min-height: calc(var(--pb-content-height) * var(--vp-s));
    border-radius: calc(10 * var(--vp-s));
    background: #fff5e5;
    overflow: hidden;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__media {
    position: relative;
    min-height: calc(var(--pb-content-height) * var(--vp-s));
    background-color: #eadbc7;
    background-image: var(--pb-media-bg-image);
    background-position: var(--pb-media-bg-position);
    background-size: var(--pb-media-bg-size);
    background-repeat: no-repeat;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__badge {
    position: absolute;
    top: calc(var(--pb-badge-top) * var(--vp-s));
    left: calc(var(--pb-badge-left) * var(--vp-s));
    z-index: 3;
    width: calc(var(--pb-badge-width) * var(--vp-s));
    height: calc(var(--pb-badge-height) * var(--vp-s));
    display: grid;
    place-items: center;
    padding: calc(8 * var(--vp-s)) calc(6 * var(--vp-s)) calc(14 * var(--vp-s));
    color: var(--pb-badge-color);
    font-size: calc(18 * var(--vp-s));
    line-height: calc(18 * var(--vp-s));
    font-weight: 900;
    text-align: center;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__badge img {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__badge span {
    position: relative;
    z-index: 1;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__products {
    min-width: 0;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    gap: calc(18 * var(--vp-s));
    padding: calc(18 * var(--vp-s)) calc(14 * var(--vp-s)) calc(20 * var(--vp-s));
    background: var(--pb-card-bg);
  }

  #prime-bundles-{{ section.id }} .prime-bundles__carousel-shell {
    display: grid;
    grid-template-columns: calc(30 * var(--vp-s)) minmax(0, 1fr) calc(30 * var(--vp-s));
    align-items: center;
    gap: calc(6 * var(--vp-s));
    min-width: 0;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__viewport {
    min-width: 0;
    overflow: hidden;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__carousel {
    display: flex;
    gap: calc(12 * var(--vp-s));
    height: 100%;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__carousel::-webkit-scrollbar {
    display: none;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product {
    position: relative;
    flex: 0 0 calc(var(--pb-slide-width) - calc(12 * var(--vp-s)));
    min-height: calc(242 * var(--vp-s));
    padding: calc(16 * var(--vp-s)) calc(12 * var(--vp-s)) calc(14 * var(--vp-s));
    border: calc(2 * var(--vp-s)) solid transparent;
    border-radius: calc(8 * var(--vp-s));
    background: #fff;
    cursor: pointer;
    scroll-snap-align: start;
    text-align: center;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product.is-selected {
    border-color: var(--pb-accent);
  }

  #prime-bundles-{{ section.id }} .prime-bundles__check {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__checkmark {
    position: absolute;
    top: calc(8 * var(--vp-s));
    right: calc(8 * var(--vp-s));
    width: calc(20 * var(--vp-s));
    height: calc(20 * var(--vp-s));
    border-radius: calc(5 * var(--vp-s));
    background: #d9d9d9;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__check:checked + .prime-bundles__checkmark {
    background: var(--pb-accent);
  }

  #prime-bundles-{{ section.id }} .prime-bundles__check:checked + .prime-bundles__checkmark::after {
    content: "";
    position: absolute;
    left: calc(6 * var(--vp-s));
    top: calc(3 * var(--vp-s));
    width: calc(6 * var(--vp-s));
    height: calc(10 * var(--vp-s));
    border-right: calc(2 * var(--vp-s)) solid #fff;
    border-bottom: calc(2 * var(--vp-s)) solid #fff;
    transform: rotate(45deg);
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product-media {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: calc(150 * var(--vp-s));
    margin-bottom: calc(14 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product-media img {
    display: block;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product-title {
    display: block;
    min-height: calc(30 * var(--vp-s));
    margin-bottom: calc(8 * var(--vp-s));
    color: #202020;
    font-size: calc(12 * var(--vp-s));
    line-height: calc(15 * var(--vp-s));
    font-weight: 800;
    text-align: center;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product-price {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: calc(6 * var(--vp-s));
    color: #1f1f1f;
    font-size: calc(13 * var(--vp-s));
    line-height: calc(16 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product-price strong {
    font-weight: 900;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__product-price s {
    color: #9a9a9a;
    font-size: calc(11 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__arrow {
    width: calc(30 * var(--vp-s));
    height: calc(30 * var(--vp-s));
    padding: 0;
    border: 0;
    border-radius: calc(999 * var(--vp-s));
    background: #fff;
    color: #222;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 calc(4 * var(--vp-s)) calc(12 * var(--vp-s)) rgba(0, 0, 0, 0.12);
  }

  #prime-bundles-{{ section.id }} .prime-bundles__arrow svg {
    width: calc(18 * var(--vp-s));
    height: calc(18 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__summary {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: calc(16 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__total-wrap {
    display: grid;
    gap: calc(8 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__total-label {
    color: #2b2420;
    font-size: calc({{ section.settings.total_label_size }} * var(--vp-s));
    line-height: calc({{ section.settings.total_label_line_height }} * var(--vp-s));
    font-weight: 900;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__total {
    color: #2b2420;
    font-size: calc({{ section.settings.total_price_size }} * var(--vp-s));
    line-height: calc({{ section.settings.total_price_line_height }} * var(--vp-s));
    font-weight: 900;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__price-row {
    display: flex;
    align-items: center;
    gap: calc(8 * var(--vp-s));
    flex-wrap: wrap;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__compare-total {
    color: #9a9a9a;
    font-size: calc({{ section.settings.compare_price_size }} * var(--vp-s));
    line-height: calc({{ section.settings.compare_price_line_height }} * var(--vp-s));
    font-weight: 600;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__discount-label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: calc(22 * var(--vp-s));
    padding: calc(3 * var(--vp-s)) calc(10 * var(--vp-s));
    border-radius: calc(999 * var(--vp-s));
    background: var(--pb-discount-label-bg);
    color: var(--pb-discount-label-color);
    font-size: calc({{ section.settings.discount_label_size }} * var(--vp-s));
    line-height: calc({{ section.settings.discount_label_line_height }} * var(--vp-s));
    font-weight: 900;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__discount-label[hidden] {
    display: none;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__actions {
    display: inline-flex;
    align-items: stretch;
    overflow: hidden;
    border-radius: calc(999 * var(--vp-s));
  }

  #prime-bundles-{{ section.id }} .prime-bundles__shop,
  #prime-bundles-{{ section.id }} .prime-bundles__cart {
    min-height: calc(38 * var(--vp-s));
    border: 0;
    color: #fff;
    cursor: pointer;
  }

  #prime-bundles-{{ section.id }} .prime-bundles__shop {
    min-width: calc(126 * var(--vp-s));
    padding: calc(9 * var(--vp-s)) calc(30 * var(--vp-s));
    background: var(--pb-shop-bg);
    font-size: calc({{ section.settings.shop_label_size }} * var(--vp-s));
