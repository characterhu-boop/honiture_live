<script>
  (function() {
    var root = document.getElementById('prime-bundles-{{ section.id }}');
    if (!root) return;

    var moneyFormat = root.getAttribute('data-money-format') || '';
    var cartAddUrl = root.getAttribute('data-cart-add-url') || '/cart/add.js';
    var checkoutUrl = root.getAttribute('data-checkout-url') || '/checkout';
    var toastTimer = null;

    /**
     * Formats cents with the store money format when Shopify helpers are unavailable.
     */
    function formatMoney(cents) {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(cents, moneyFormat);
      }

      var value = (Number(cents || 0) / 100).toFixed(2);
      if (!moneyFormat) {
        return '$' + value;
      }
      return moneyFormat
        .replace(/\{\{\s*amount\s*\}\}/, value)
        .replace(/\{\{\s*amount_no_decimals\s*\}\}/, Math.round(Number(cents || 0) / 100));
    }

    /**
     * Shows a short status message for add-to-cart and validation feedback.
     */
    function showToast(message) {
      var toast = root.querySelector('.prime-bundles__toast');
      if (!toast) return;
      toast.textContent = message;
      toast.classList.add('is-visible');
      clearTimeout(toastTimer);
      toastTimer = setTimeout(function() {
        toast.classList.remove('is-visible');
      }, 2000);
    }

    /**
     * Returns selected variant ids for a panel and keeps the total in sync.
     */
    function getSelectedItems(panel) {
      var items = [];
      var total = 0;
      var compareTotal = 0;
      var hasComparePrice = false;

      panel.querySelectorAll('[data-pb-product]:checked').forEach(function(input) {
        var variantId = input.getAttribute('data-variant-id');
        var price = Number(input.getAttribute('data-price') || 0);
        var comparePrice = Number(input.getAttribute('data-compare-price') || price);
        if (!variantId) return;
        total += price;
        if (comparePrice > price) {
          hasComparePrice = true;
        }
        compareTotal += comparePrice > 0 ? comparePrice : price;
        items.push({ id: Number(variantId), quantity: 1 });
      });

      var compareDiscount = parseFloat(panel.getAttribute('data-compare-discount') || '');
      if (items.length > 1 && !isNaN(compareDiscount) && compareDiscount >= 0) {
        total = Math.round(total * (compareDiscount / 100));
      }

      var totalEl = panel.querySelector('[data-pb-total]');
      if (totalEl) {
        totalEl.textContent = formatMoney(total);
      }

      var compareTotalEl = panel.querySelector('[data-pb-compare-total]');
      if (compareTotalEl) {
        compareTotalEl.textContent = formatMoney(compareTotal);
        compareTotalEl.hidden = !hasComparePrice || compareTotal <= 0;
      }

      var discountLabelEl = panel.querySelector('[data-pb-discount-label]');
      if (discountLabelEl) {
        var savingPercent = compareTotal > total ? Math.round((compareTotal - total) / compareTotal * 100) : 0;
        discountLabelEl.textContent = savingPercent > 0 ? 'SAVE ' + savingPercent + '%' : '';
        discountLabelEl.hidden = savingPercent <= 0;
      }

      return items;
    }

    /**
     * Adds the selected products in the current tab to Shopify cart.
     */
    function addSelectedItems(panel) {
      var items = getSelectedItems(panel);
      if (!items.length) {
        showToast('{{ section.settings.empty_text | escape }}');
        return Promise.reject(new Error('No selected products'));
      }

      return fetch(cartAddUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: items })
      }).then(function(response) {
        if (!response.ok) throw new Error('Add failed');
        return response.json();
      });
    }

    /**
     * Opens a new tab, adds selected variants, then redirects that tab to cart.
     */
    function openCartWithSelectedItems(panel) {
      var items = getSelectedItems(panel);
      if (!items.length) {
        showToast('{{ section.settings.empty_text | escape }}');
        return;
      }

      var targetName = 'prime-bundles-cart-' + Date.now();
      var cartWindow = window.open('about:blank', targetName);
      var form = document.createElement('form');
      form.method = 'post';
      form.action = '/cart/add';
      form.target = targetName;
      form.style.display = 'none';

      items.forEach(function(item, index) {
        var idInput = document.createElement('input');
        idInput.type = 'hidden';
        idInput.name = 'items[' + index + '][id]';
        idInput.value = item.id;
        form.appendChild(idInput);

        var quantityInput = document.createElement('input');
        quantityInput.type = 'hidden';
        quantityInput.name = 'items[' + index + '][quantity]';
        quantityInput.value = item.quantity || 1;
        form.appendChild(quantityInput);
      });

      var returnInput = document.createElement('input');
      returnInput.type = 'hidden';
      returnInput.name = 'return_to';
      returnInput.value = '/cart';
      form.appendChild(returnInput);

      document.body.appendChild(form);
      form.submit();
      setTimeout(function() {
        form.remove();
      }, 1000);

      if (!cartWindow) {
        showToast('{{ section.settings.added_text | escape }}');
      }
    }

    /**
     * Activates the selected tab and refreshes its total.
     */
    function activateTab(tab) {
      var target = tab.getAttribute('data-pb-tab');
      if (!target) return;

      root.querySelectorAll('[data-pb-tab]').forEach(function(item) {
        var isActive = item === tab;
        item.classList.toggle('is-active', isActive);
        item.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      root.querySelectorAll('[data-pb-panel]').forEach(function(panel) {
        var isActive = panel.getAttribute('data-pb-panel') === target;
        panel.classList.toggle('is-active', isActive);
        panel.hidden = !isActive;
        if (isActive) {
          getSelectedItems(panel);
        }
      });
    }

    root.querySelectorAll('[data-pb-panel]').forEach(function(panel) {
      getSelectedItems(panel);
    });

    root.addEventListener('change', function(event) {
      if (!event.target.matches('[data-pb-product]')) return;
      var productCard = event.target.closest('.prime-bundles__product');
      if (productCard) {
        productCard.classList.toggle('is-selected', event.target.checked);
      }
      var panel = event.target.closest('[data-pb-panel]');
      if (panel) {
        getSelectedItems(panel);
      }
    });

    root.addEventListener('click', function(event) {
      var tab = event.target.closest('[data-pb-tab]');
      if (tab) {
        activateTab(tab);
        return;
      }

      var panel = event.target.closest('[data-pb-panel]');
      if (!panel) return;

      var carousel = panel.querySelector('[data-pb-carousel]');
      if (event.target.closest('[data-pb-prev]') && carousel) {
        carousel.scrollBy({ left: -carousel.clientWidth, behavior: 'smooth' });
        return;
      }

      if (event.target.closest('[data-pb-next]') && carousel) {
        carousel.scrollBy({ left: carousel.clientWidth, behavior: 'smooth' });
        return;
      }

      if (event.target.closest('[data-pb-cart]')) {
        openCartWithSelectedItems(panel);
        return;
      }

      var shopButton = event.target.closest('[data-pb-shop]');
      if (shopButton) {
        var checkoutLink = shopButton.getAttribute('data-checkout-link');
        addSelectedItems(panel).then(function() {
          window.location.href = checkoutLink || checkoutUrl || '/checkout';
        }).catch(function(error) {
          if (error.message !== 'No selected products') {
            showToast('{{ section.settings.error_text | escape }}');
          }
        });
      }
    });
  })();
</script>

