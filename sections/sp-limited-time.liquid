{%- liquid
  assign bg_color = section.settings.bg_color
  assign padding_top = section.settings.padding_top
  assign padding_bottom = section.settings.padding_bottom
  assign card_gap = section.settings.card_gap
-%}

<style>
  .sp-limited-time--{{ section.id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    background: {{ bg_color }};
    --sp-limited-time-gap: {{ card_gap }}px;
  }
    .sp-limited-time--{{ section.id }} .copy-code-container{
        margin: 10px 0 20px;
        width: 100%;
    }
  .sp-limited-time--{{ section.id }} .sh-{{ section.id }} .xmax_section__title,
  .sp-limited-time--{{ section.id }} .sh-{{ section.id }} .xmas-sub-heading {
    color: #1a1a1a;
  }

  .sp-limited-time--{{ section.id }} .sh-{{ section.id }} .xmas-viewmore {
    border-color: #1a1a1a;
    color: #1a1a1a;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__countdown {
    display: flex;
    justify-content: center;
    margin: -20px 0 40px;
  }

  .sp-limited-time--{{ section.id }} .page-width {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-limited-time-gap);
    align-items: stretch;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 991px) {
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      max-width: calc(((1200px - (var(--sp-limited-time-gap) * 2)) / 3) * 2 + var(--sp-limited-time-gap));
    }
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__card {
    background: #fff;
    border-radius: 16px;
    padding: 20px 40px 18px;
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__badge {
    position: absolute;
    top: 0;
    left: 12px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100px;
    height: 70px;
    padding: 0;
    background-color: transparent;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    color: #fff;
    z-index: 2;
    text-align: center;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__badge span {
    font-weight: 700;
    font-size: 14px;
    line-height: 1.1;
    display: block;
    transform: translate(15px, 5px);
  }
  
  .sp-limited-time--{{ section.id }} .sp-limited-time__badge.no-bg {
    background: #cfe86f;
    border-radius: 0 0 4px 4px;
    width: auto;
    height: auto;
    padding: 6px 10px;
    color: #1a1a1a;
    flex-direction: row;
  }
  
  .sp-limited-time--{{ section.id }} .sp-limited-time__badge.no-bg span {
    transform: none;
    font-size: 12px;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__image-wrap {
    width: 100%;
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__title {
    font-size: 22px;
    font-weight: 800;
    color: #1a1a1a;
    margin: 4px 0 6px;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__desc {
    font-size: 16px;
    color: #666;
    line-height: 1.4;
    margin-bottom: 12px;
    min-height: 34px;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__prices {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
    margin-top: auto;
    margin-bottom: 12px;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__price {
    font-size: 20px;
    font-weight: 900;
    color: #000;
  }

  .sp-limited-time--{{ section.id }} .sp-limited-time__compare {
    font-size: 13px;
    color: #999;
    text-decoration: line-through;
  }

  /* .sp-limited-time--{{ section.id }} .sp-limited-time__coupon {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    border-radius: 10px;
    background: #dff4b1;
    padding: 10px 12px;
    margin-bottom: 12px;
  } */

  .sp-limited-time--{{ section.id }} .sp-limited-time__coupon-text {
    font-size: 12px;
    color: #1a1a1a;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* .sp-limited-time--{{ section.id }} .sp-limited-time__coupon-btn {
    border: none;
    background: #73d0c1;
    color: #1a1a1a;
    font-size: 12px;
    border-radius: 999px;
    padding: 6px 14px;
    cursor: pointer;
    flex: none;
  } */

  .sp-limited-time--{{ section.id }} .sp-limited-time__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    border: none;
    border-radius: 999px;
    padding: 12px 16px;
    background: #00c9b7;
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
  }

  #sp-limited-time-toast-{{ section.id }} {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.85);
    color: #fff;
    padding: 12px 22px;
    border-radius: 10px;
    z-index: 9999;
    font-size: 12px;
    opacity: 0;
    transition: opacity 0.25s;
    pointer-events: none;
  }

  #sp-limited-time-toast-{{ section.id }}.is-visible {
    opacity: 1;
  }

  @media (max-width: 990px) {
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .sp-limited-time--{{ section.id }} .sp-limited-time__countdown {
      margin: -10px 0 30px;
    }
    
    /* Mobile Grid Layout: Pin Style (品字形) */
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    
    /* First card spans full width */
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: center;
      text-align: left;
      padding: 15px;
      gap: 15px;
    }
    
    /* Styles for the first card (horizontal layout) */
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__image-wrap {
      width: 45%;
      height: auto;
      aspect-ratio: 1/1;
      margin-bottom: 0;
      flex-shrink: 0;
    }
    
    /* Wrapper for content in first card */
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-card-content-wrap {
        display: flex;
        flex-direction: column;
        flex: 1;
        width: 55%;
    }

    /* Adjust elements inside first card */
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__title {
      font-size: 16px;
      margin-top: 0;
      line-height: 1.2;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__desc {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      font-size: 12px;
      line-height: 1.3;
      margin-bottom: 8px;
      color: #666;
      min-height: auto;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__prices {
      justify-content: flex-start;
      margin-top: 5px;
      margin-bottom: 10px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__coupon {
        width: 100%;
        margin-bottom: 10px;
        padding: 6px 4px;
        gap: 4px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__coupon-text {
        font-size: 9px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__coupon-btn {
        padding: 4px;
        font-size: 10px;
    }
    .sp-limited-time--{{ section.id }} .copy-code-container{
          flex-wrap: nowrap;
    }
    .sp-card-content-wrap .sp-limited-time__coupon.copy-code-container{
      flex-wrap: nowrap;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:first-child .sp-limited-time__btn {
        width: 100%;
        padding: 8px 16px;
        font-size: 14px;
    }

    /* Styles for 2nd and 3rd cards (vertical layout, side by side) */
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) {
        padding: 12px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__image-wrap {
      height: 140px;
      margin-bottom: 10px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__title {
      font-size: 14px;
      line-height: 1.2;
      height: 34px; /* Limit to 2 lines */
      overflow: hidden;
      margin-bottom: 4px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__desc {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      font-size: 10px;
      line-height: 1.2;
      margin-bottom: 6px;
      color: #666;
      min-height: auto;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__prices {
        flex-direction: column;
        align-items: center;
        gap: 2px;
        margin-bottom: 8px;
        margin-top: 0;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__price {
        font-size: 18px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__compare {
        font-size: 12px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__coupon {
        padding: 4px;
        flex-direction: row;
        gap: 4px;
        align-items: center;
        text-align: center;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__coupon-text {
        font-size: 8px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__coupon-btn {
        white-space: nowrap;
        padding: 4px 0;
        font-size: 10px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__grid > .sp-limited-time__card:not(:first-child) .sp-limited-time__btn {
        padding: 8px 0;
        font-size: 12px;
    }
    
    /* Badge adjustment for mobile */
    .sp-limited-time--{{ section.id }} .sp-limited-time__badge {
        width: 70px;
        height: 50px;
        left: 10px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__badge span {
        font-size: 11px;
        transform: translate(10px, 3px);
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__badge.no-bg {
        width: auto;
        height: auto;
        padding: 4px 8px;
    }
    .sp-limited-time--{{ section.id }} .sp-limited-time__badge.no-bg span {
        font-size: 10px;
        transform: none;
    }
    #sp-limited-time-toast-{{ section.id }} {
      font-size: 12px;
    }
    .sp-limited-time--{{ section.id }} .copy-code-container{
        margin: 0 0 10px;
    }

    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two > .sp-limited-time__card:first-child {
      grid-column: auto;
      flex-direction: column;
      align-items: stretch;
      text-align: center;
      padding: 12px;
      gap: 0;
    }

    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two > .sp-limited-time__card:first-child .sp-limited-time__image-wrap {
      width: 100%;
      height: 140px;
      aspect-ratio: auto;
      margin-bottom: 10px;
      flex-shrink: 0;
    }

    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two > .sp-limited-time__card:first-child .sp-card-content-wrap {
      display: block;
      width: auto;
    }

    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two > .sp-limited-time__card:first-child .sp-limited-time__title {
      font-size: 14px;
      line-height: 1.2;
      height: 34px;
      overflow: hidden;
      margin-bottom: 4px;
    }

    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two > .sp-limited-time__card:first-child .sp-limited-time__desc {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      font-size: 10px;
      line-height: 1.2;
      margin-bottom: 6px;
      color: #666;
      min-height: auto;
    }

    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two > .sp-limited-time__card:first-child .sp-limited-time__prices {
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2px;
      margin-bottom: 8px;
      margin-top: 0;
    }

    .sp-limited-time--{{ section.id }} .sp-limited-time__grid.sp-limited-time__grid--two > .sp-limited-time__card:first-child .sp-limited-time__btn {
      padding: 8px 0;
      font-size: 12px;
    }
  }
</style>

<section class="sp-limited-time--{{ section.id }}">
  <div class="page-width">
    {% render 'xmas-section-header', section: section %}

    {% for block in section.blocks %}
      {% if block.type == 'count-down' %}
        <div class="sp-limited-time__countdown" {{ block.shopify_attributes }}>
          {% render 'count-down', block: block, cusId: section.id %}
        </div>
      {% endif %}
    {% endfor %}

    {%- liquid
      assign deal_card_count = 0
      for b in section.blocks
        if b.type == 'deal_card'
          assign deal_card_count = deal_card_count | plus: 1
        endif
      endfor
    -%}
    <div class="sp-limited-time__grid{% if deal_card_count == 2 %} sp-limited-time__grid--two{% endif %}">
      {% for block in section.blocks %}
        {% if block.type == 'deal_card' %}
          {% assign product = block.settings.product %}
          {% assign title = block.settings.title | default: product.title %}
          {% assign image = block.settings.image | default: product.featured_image %}
          {% assign description = block.settings.description | default: '' %}
          {% assign price_display = product.price | money %}
          {% if block.settings.custom_price != blank %}
            {% assign price_display = block.settings.custom_price %}
          {% endif %}

          {% assign compare_display = block.settings.custom_compare_price %}
          {% if compare_display == blank and product.compare_at_price > product.price %}
            {% assign compare_display = product.compare_at_price | money %}
          {% endif %}

          {% assign badge_text = block.settings.badge_text %}
          {% if badge_text == blank and product.compare_at_price > product.price %}
            {% assign discount_percentage = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
            {% assign badge_text = discount_percentage | append: '%<br>OFF' %}
          {% endif %}

          <div class="sp-limited-time__card" {{ block.shopify_attributes }}>
            {% if badge_text != blank %}
              <div class="sp-limited-time__badge {% if section.settings.badge_bg == blank %}no-bg{% endif %}"
                   style="{% if section.settings.badge_bg != blank %}background-image: url({{ section.settings.badge_bg | image_url: width: 120 }});{% endif %}">
                <span>{{ badge_text }}</span>
              </div>
            {% endif %}

            <div class="sp-limited-time__image-wrap">
              <a href="{{ block.settings.btn_link | default: product.url }}" target="_blank" rel="noopener" style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
                {% if image != blank %}
                  <img class="sp-limited-time__image" src="{{ image | image_url: width: 700 }}" loading="lazy" alt="{{ title | escape }}">
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag }}
                {% endif %}
              </a>
            </div>
 
            <div class="sp-card-content-wrap">
              <a class="sp-limited-time__title" href="{{ product.url }}" target="_blank" rel="noopener">{{ title }}</a>
              {% if description != blank %}
                <div class="sp-limited-time__desc">{{ description }}</div>
              {% endif %}

              <div class="sp-limited-time__prices">
                <span class="sp-limited-time__price">{{ price_display }}</span>
                {% if compare_display != blank %}
                  <span class="sp-limited-time__compare">{{ compare_display }}</span>
                {% endif %}
              </div>

              {% if block.settings.coupon_code != blank %}
                <div class="sp-limited-time__coupon copy-code-container">
                  <div class="sp-limited-time__coupon-text">{{ block.settings.coupon_prefix | default: 'Off Code:' }} {{ block.settings.coupon_code }}</div>
                  <button
                    type="button"
                    class="sp-limited-time__coupon-btn"
                    data-code="{{ block.settings.coupon_code }}"
                    data-toast="{{ block.settings.copied_text | default: 'Copied' }}"
                  >
                    {{ block.settings.claim_label | default: 'Claim' }}
                  </button>
                </div>
              {% endif %}

              {%- if block.settings.btn_link != blank -%}
                <a class="sp-limited-time__btn" href="{{ block.settings.btn_link }}" target="_blank" rel="noopener">
                  {{ block.settings.btn_text | default: 'Shop Now' }}
                </a>
              {%- else -%}
                <button 
                  class="sp-limited-time__btn sp-limited-time__btn--add" 
                  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                  type="button"
                >
                  {{ block.settings.btn_text | default: 'Shop Now' }}
                </button>
              {%- endif -%}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  <div class="sp-limited-time__toast" id="sp-limited-time-toast-{{ section.id }}"></div>
</section>
{% render 'section-decorations', section: section %}
<script>
  (function () {
    var root = document.querySelector('.sp-limited-time--{{ section.id }}');
    if (!root) return;

    var toast = document.getElementById('sp-limited-time-toast-{{ section.id }}');
    var toastTimer = null;

    function showToast(message) {
      if (!toast) return;
      toast.textContent = message || 'Copied';
      toast.classList.add('is-visible');
      if (toastTimer) window.clearTimeout(toastTimer);
      toastTimer = window.setTimeout(function () {
        toast.classList.remove('is-visible');
      }, 2000);
    }

    function copyText(text, okText) {
      if (!text) return;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(function () {
          showToast(okText);
        }).catch(function () {
          showToast(okText);
        });
        return;
      }
      var textArea = document.createElement('textarea');
      textArea.value = text;
      textArea.style.position = 'fixed';
      textArea.style.left = '-9999px';
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      try {
        document.execCommand('copy');
      } catch (e) {}
      document.body.removeChild(textArea);
      showToast(okText);
    }

    root.querySelectorAll('.sp-limited-time__btn--add').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var variantId = this.getAttribute('data-variant-id');
        if (!variantId) return;

        var formData = new FormData();
        formData.append('items[][id]', variantId);
        formData.append('items[][quantity]', 1);

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          window.open('/cart', '_blank');
        })
        .catch((error) => {
          console.error('Error:', error);
        });
      });
    });

    root.querySelectorAll('.sp-limited-time__coupon-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        copyText(btn.getAttribute('data-code'), btn.getAttribute('data-toast'));
      });
    });
  })();
</script>

{% schema %}
{
  "name": "SP Limited Time",
  "tag": "section",
  "class": "sp-limited-time-section",
  "settings": [
    {
      "type": "header",
      "content": "Section Header 设置"
    },
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "Spring Sale · Limited-Time Deals"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "副标题",
      "default": "Seasonal savings on selected vacuums and robot cleaners."
    },
    {
      "type": "checkbox",
      "id": "show_sub_heading",
      "label": "显示副标题",
      "default": true
    },
    {
      "type": "text",
      "id": "view_more_label",
      "label": "右侧按钮文本",
      "default": "View More"
    },
    {
      "type": "url",
      "id": "view_more_link",
      "label": "右侧按钮链接"
    },
    {
      "type": "checkbox",
      "id": "show_title_icons",
      "label": "主标题左右显示图标",
      "default": true
    },
    {
