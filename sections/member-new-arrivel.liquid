{% comment %}
  Member New Arrivel
  Member hero card with gift artwork, price actions, and six bottom selling points.
{% endcomment %}

{% liquid
  assign product_obj = section.settings.product
  assign selected_variant = blank
  assign variant_id = section.settings.variant_id
  assign card_url = section.settings.shop_link
  assign learn_url = section.settings.learn_link

  if product_obj != blank
    assign selected_variant = product_obj.selected_or_first_available_variant
    if variant_id == blank
      assign variant_id = selected_variant.id
    endif
    if card_url == blank
      assign card_url = product_obj.url
    endif
    if learn_url == blank
      assign learn_url = product_obj.url
    endif
  endif

  assign extra_discount_percent = section.settings.extra_discount_percent | default: 0
  assign sale_price = section.settings.price_text
  if selected_variant != blank and extra_discount_percent > 0
    assign discount_multiplier = 100 | minus: extra_discount_percent
    assign discounted_price = selected_variant.price | times: discount_multiplier | divided_by: 100
    assign sale_price = discounted_price | money
  elsif sale_price == blank and selected_variant != blank
    assign sale_price = selected_variant.price | money 
  endif

  assign compare_price = section.settings.compare_price_text
  if compare_price == blank and selected_variant != blank and selected_variant.compare_at_price > selected_variant.price
    assign compare_price = selected_variant.compare_at_price | money
  endif
%}

<section
  id="member-new-arrivel-{{ section.id }}"
  class="member-new-arrivel section-member-arrivel"
  style="
    --mna-bg-color: {{ section.settings.background_color }};
    --mna-text-color: {{ section.settings.text_color }};
    --mna-title-color: {{ section.settings.title_color }};
    --mna-title-accent: {{ section.settings.title_accent_color }};
    --mna-title-gradient-start: {{ section.settings.title_gradient_start }};
    --mna-title-gradient-end: {{ section.settings.title_gradient_end }};
    --mna-title-gradient-angle: {{ section.settings.title_gradient_angle }}deg;
    --mna-panel-rgb: {{ section.settings.panel_color | color_to_rgb | remove: 'rgb(' | remove: ')' }};
    --mna-panel-alpha: {{ section.settings.panel_opacity | divided_by: 100.0 }};
    --mna-feature-rgb: {{ section.settings.feature_bar_color | color_to_rgb | remove: 'rgb(' | remove: ')' }};
    --mna-feature-alpha: {{ section.settings.feature_bar_opacity | divided_by: 100.0 }};
    --mna-primary-color: {{ section.settings.primary_button_color }};
    --mna-primary-text: {{ section.settings.primary_button_text_color }};
    --mna-secondary-color: {{ section.settings.secondary_button_color }};
    --mna-secondary-text: {{ section.settings.secondary_button_text_color }};
    --mna-compare-color: {{ section.settings.compare_price_color }};
    {% if section.settings.background_image != blank %}
      --mna-bg-desktop: url('{{ section.settings.background_image | image_url: width: 2400 }}');
    {% endif %}
    {% if section.settings.mobile_background_image != blank %}
      --mna-bg-mobile: url('{{ section.settings.mobile_background_image | image_url: width: 900 }}');
    {% elsif section.settings.background_image != blank %}
      --mna-bg-mobile: url('{{ section.settings.background_image | image_url: width: 900 }}');
    {% endif %}
  "
>
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'header' -%}
        {% render 'xmas-section-header', block: block %}
    {%- endcase -%}
  {%- endfor -%}

  <div class="member-new-arrivel__inner">
    <div class="member-new-arrivel__card">
      <div class="member-new-arrivel__badge-wrap member-new-arrivel__badge-wrap--desktop">
        {% render 'common-badge',
          show: section.settings.badge_show,
          text: section.settings.badge_text,
          off_text: section.settings.badge_off_text,
          split: section.settings.badge_split,
          top: section.settings.badge_pc_top,
          left: 0,
          text_top: section.settings.badge_pc_text_top,
          text_left: section.settings.badge_pc_text_left,
          background: 'transparent',
          color: section.settings.badge_text_color,
          width: section.settings.badge_pc_width,
          height: section.settings.badge_pc_height,
          background_image: section.settings.badge_background_image
        %}
      </div>
      <div class="member-new-arrivel__mobile-visual">
        <div class="member-new-arrivel__badge-wrap member-new-arrivel__badge-wrap--mobile">
          {% render 'common-badge',
            show: section.settings.badge_show,
            text: section.settings.badge_text,
            off_text: section.settings.badge_off_text,
            split: section.settings.badge_split,
            top: section.settings.badge_mobile_top,
            left: section.settings.badge_mobile_left,
            text_top: section.settings.badge_mobile_text_top,
            text_left: section.settings.badge_mobile_text_left,
            background: 'transparent',
            color: section.settings.badge_text_color,
            width: section.settings.badge_mobile_width,
            height: section.settings.badge_mobile_height,
            width_mobile: section.settings.badge_mobile_width,
            height_mobile: section.settings.badge_mobile_height,
            background_image: section.settings.badge_background_image
          %}
        </div>
      </div>

      <div class="member-new-arrivel__content">
        {% if section.settings.title != blank %}
          <h2 class="member-new-arrivel__title">
            {{ section.settings.title | escape | newline_to_br }}
          </h2>
        {% endif %}

        {% if section.settings.subtitle != blank %}
          <div class="member-new-arrivel__subtitle">
            {{ section.settings.subtitle | escape | newline_to_br }}
          </div>
        {% endif %}

        

          {% assign gift_product_1 = section.settings.gift_product_1 %}
          {% assign gift_product_2 = section.settings.gift_product_2 %}
          {% assign show_gift_product_card = section.settings.show_gift_product_card %}
          {% if show_gift_product_card == nil %}
            {% assign show_gift_product_card = true %}
          {% endif %}
          {% assign has_gift_product_card_content = false %}
          {% assign gift_product_count = 0 %}
          {% if gift_product_1 != blank %}
            {% assign gift_product_count = gift_product_count | plus: 1 %}
          {% endif %}
          {% if gift_product_2 != blank %}
            {% assign gift_product_count = gift_product_count | plus: 1 %}
          {% endif %}
          {% if gift_product_count > 0 %}
            {% assign has_gift_product_card_content = true %}
          {% endif %}
          {% assign has_custom_gift_image = false %}
          {% if section.settings.custom_gift_image != blank or section.settings.mobile_custom_gift_image != blank %}
            {% assign has_custom_gift_image = true %}
          {% endif %}
          {% assign show_gift_area = false %}
          {% if show_gift_product_card and has_gift_product_card_content %}
            {% assign show_gift_area = true %}
          {% endif %}
          {% if has_custom_gift_image %}
            {% assign show_gift_area = true %}
          {% endif %}
          {% if show_gift_area %}
            <div class="member-new-arrivel__gift">
              {% if show_gift_product_card and has_gift_product_card_content %}
                {% if section.settings.gift_badge_image != blank or section.settings.mobile_gift_badge_image != blank %}
                  {% assign gift_badge_image = section.settings.gift_badge_image | default: section.settings.mobile_gift_badge_image %}
                  {% assign mobile_gift_badge_image = section.settings.mobile_gift_badge_image | default: gift_badge_image %}
                  <picture class="member-new-arrivel__gift-badge" aria-hidden="true">
                    {% if mobile_gift_badge_image != blank %}
                      <source media="(max-width: 849px)" srcset="{{ mobile_gift_badge_image | image_url: width: 160 }}">
                    {% endif %}
                    {{ gift_badge_image | image_url: width: 220 | image_tag: loading: 'lazy', alt: '' }}
                  </picture>
                {% endif %}
                <div class="member-new-arrivel__gift-inner">
                  {% if section.settings.gift_card_title != blank %}
                    <div class="member-new-arrivel__gift-heading">{{ section.settings.gift_card_title | escape }}</div>
                  {% endif %}
                  <div class="member-new-arrivel__gift-body {% if gift_product_count > 1 %}is-double{% else %}is-single{% endif %}">
                    {% for gift_index in (1..2) %}
                      {% liquid
                        if gift_index == 1
                          assign gift_product = gift_product_1
                          assign gift_title = section.settings.gift_product_1_title
                          assign gift_compare = section.settings.gift_product_1_compare_price
                        else
                          assign gift_product = gift_product_2
                          assign gift_title = section.settings.gift_product_2_title
                          assign gift_compare = section.settings.gift_product_2_compare_price
                        endif

                        assign gift_image = blank
                        if gift_product != blank
                          assign gift_image = gift_product.featured_image
                        endif
                        if gift_title == blank and gift_product != blank
                          assign gift_title = gift_product.title
                        endif
                        if gift_compare == blank and gift_product != blank
                          assign gift_compare = gift_product.price | money
                        endif
                      %}
                      {% if gift_product != blank %}
                        <a class="member-new-arrivel__gift-product" href="{{ gift_product.url | default: card_url | default: '#' }}">
                          <span class="member-new-arrivel__gift-product-media">
                            {% if gift_image != blank %}
                              {{ gift_image | image_url: width: 260 | image_tag: loading: 'lazy', alt: gift_title }}
                            {% endif %}
                          </span>
                          <span class="member-new-arrivel__gift-product-info">
                            <span class="member-new-arrivel__gift-product-title">{{ gift_title | escape }}</span>
                            <span class="member-new-arrivel__gift-product-price">
                              <span class="member-new-arrivel__gift-free">{{ section.settings.gift_free_label | default: 'FREE' | escape }}</span>
                              {% if gift_compare != blank %}
                                <s class="member-new-arrivel__gift-compare">{{ gift_compare | escape }}</s>
                              {% endif %}
                            </span>
                          </span>
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              {% endif %}

              {% if has_custom_gift_image %}
                {% assign custom_gift_image = section.settings.custom_gift_image | default: section.settings.mobile_custom_gift_image %}
                {% assign mobile_custom_gift_image = section.settings.mobile_custom_gift_image | default: custom_gift_image %}
                <div class="member-new-arrivel__custom-gift-image">
                  <picture>
                    {% if mobile_custom_gift_image != blank %}
                      <source media="(max-width: 849px)" srcset="{{ mobile_custom_gift_image | image_url: width: 900 }}">
                    {% endif %}
                    {{ custom_gift_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: section.settings.custom_gift_image_alt }}
                  </picture>
                </div>
              {% endif %}
            </div>
          {% endif %}


       

        <div class="member-new-arrivel__price-row">
          {% if sale_price != blank %}
            <div class="member-new-arrivel__price">{{ sale_price | escape }}</div>
          {% endif %}
          {% if compare_price != blank %}
            <div class="member-new-arrivel__compare">{{ compare_price | escape }}</div>
          {% endif %}
        </div>

        <div class="member-new-arrivel__actions">
          {% if section.settings.learn_label != blank %}
            <a
              class="member-new-arrivel__btn member-new-arrivel__btn--secondary"
              {% if learn_url != blank %}href="{{ learn_url }}"{% else %}role="link" aria-disabled="true"{% endif %}
            >
              {{ section.settings.learn_label | escape }}
            </a>
          {% endif %}
          {% if section.settings.shop_label != blank %}
            <a
              class="member-new-arrivel__btn member-new-arrivel__btn--primary"
              {% if card_url != blank %}href="{{ card_url }}"{% else %}role="link" aria-disabled="true"{% endif %}
              data-mna-shop
              data-variant-id="{{ variant_id }}"
              data-use-checkout="{{ section.settings.shop_direct_checkout }}"
              data-discount-code="{{ section.settings.extra_discount_code | escape }}"
            >
              {{ section.settings.shop_label | escape }}
            </a>
          {% endif %}
        </div>
        
      </div>
      <div class="member-new-arrivel__mobile-features">
          {% assign rendered_mobile_features = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'feature' and rendered_mobile_features < 4 %}
              {% assign rendered_mobile_features = rendered_mobile_features | plus: 1 %}
              <div class="member-new-arrivel__feature member-new-arrivel__mobile-feature" {{ block.shopify_attributes }}>
                <div class="member-new-arrivel__feature-icon">
                  {% if block.settings.icon_image != blank %}
                    {{ block.settings.icon_image | image_url: width: 100 | image_tag: loading: 'lazy', alt: block.settings.text }}
                  {% else %}
                    <svg viewBox="0 0 48 48" aria-hidden="true">
                      {% case block.settings.icon %}
                        {% when 'steam' %}
                          <path d="M17 9c-5 6 5 9 0 16m10-16c-5 6 5 9 0 16m10-16c-5 6 5 9 0 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3"/>
                        {% when 'drop' %}
                          <path d="M24 5s13 14 13 25c0 7-5 12-13 12S11 37 11 30C11 19 24 5 24 5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="3"/>
                        {% when 'wave' %}
                          <path d="M7 29c6-13 11-13 17 0s11 13 17 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3"/>
                        {% when 'pet' %}
                          <path d="M17 21c3 0 4-4 2-7s-6-2-7 1 1 6 5 6Zm14 0c4 0 6-3 5-6s-5-4-7-1-1 7 2 7ZM17 39c-5 0-7-5-4-9 2-3 5-4 7-7 2-2 6-2 8 0 2 3 5 4 7 7 3 4 1 9-4 9-3 0-5-2-7-2s-4 2-7 2Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="3"/>
                        {% else %}
                          <path d="m24 6 3 10 10 3-10 3-3 10-3-10-10-3 10-3 3-10Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="3"/>
                          <path d="m12 30 2 5 5 2-5 2-2 5-2-5-5-2 5-2 2-5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="2.5"/>
                      {% endcase %}
                    </svg>
                  {% endif %}
                </div>
                <div class="member-new-arrivel__feature-text">{{ block.settings.text | escape }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% if section.settings.bottom_image != blank or section.settings.mobile_bottom_image != blank %}
        <div class="member-new-arrivel__bottom-image">
          <picture>
            {% if section.settings.mobile_bottom_image != blank %}
              <source media="(max-width: 849px)" srcset="{{ section.settings.mobile_bottom_image | image_url: width: 900 }}">
            {% endif %}
            {% if section.settings.bottom_image != blank %}
              {{ section.settings.bottom_image | image_url: width: 1800 | image_tag: loading: 'lazy', alt: section.settings.bottom_image_alt }}
            {% else %}
              {{ section.settings.mobile_bottom_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.bottom_image_alt }}
            {% endif %}
          </picture>
        </div>
      {% else %}
        <div class="member-new-arrivel__features">
          {% assign rendered_features = 0 %}
          {% for block in section.blocks %}
            {% if block.type == 'feature' and rendered_features < 5 %}
              {% assign rendered_features = rendered_features | plus: 1 %}
              <div class="member-new-arrivel__feature" {{ block.shopify_attributes }}>
                <div class="member-new-arrivel__feature-icon">
                  {% if block.settings.icon_image != blank %}
                    {{ block.settings.icon_image | image_url: width: 120 | image_tag: loading: 'lazy', alt: block.settings.text }}
                  {% else %}
                    <svg viewBox="0 0 48 48" aria-hidden="true">
                      {% case block.settings.icon %}
                        {% when 'steam' %}
                          <path d="M17 9c-5 6 5 9 0 16m10-16c-5 6 5 9 0 16m10-16c-5 6 5 9 0 16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3"/>
                        {% when 'drop' %}
                          <path d="M24 5s13 14 13 25c0 7-5 12-13 12S11 37 11 30C11 19 24 5 24 5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="3"/>
                        {% when 'wave' %}
                          <path d="M7 29c6-13 11-13 17 0s11 13 17 0" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3"/>
                        {% when 'pet' %}
                          <path d="M17 21c3 0 4-4 2-7s-6-2-7 1 1 6 5 6Zm14 0c4 0 6-3 5-6s-5-4-7-1-1 7 2 7ZM17 39c-5 0-7-5-4-9 2-3 5-4 7-7 2-2 6-2 8 0 2 3 5 4 7 7 3 4 1 9-4 9-3 0-5-2-7-2s-4 2-7 2Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="3"/>
                        {% else %}
                          <path d="m24 6 3 10 10 3-10 3-3 10-3-10-10-3 10-3 3-10Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="3"/>
                          <path d="m12 30 2 5 5 2-5 2-2 5-2-5-5-2 5-2 2-5Z" fill="none" stroke="currentColor" stroke-linejoin="round" stroke-width="2.5"/>
                      {% endcase %}
                    </svg>
                  {% endif %}
                </div>
                <div class="member-new-arrivel__feature-text">{{ block.settings.text | escape }}</div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.getElementById('member-new-arrivel-{{ section.id }}');
    if (!section) return;

    const shopButton = section.querySelector('[data-mna-shop]');
    if (!shopButton) return;

    shopButton.addEventListener('click', (event) => {
      const variantId = shopButton.dataset.variantId;
      const useCheckout = shopButton.dataset.useCheckout === 'true';
      const discountCode = shopButton.dataset.discountCode;
      if (!variantId || !useCheckout) return;

      event.preventDefault();
      const checkoutPath = `/cart/${variantId}:1?checkout`;
      if (discountCode) {
        window.location.href = `/discount/${encodeURIComponent(discountCode)}?redirect=${encodeURIComponent(checkoutPath)}`;
        return;
      }

      window.location.href = checkoutPath;
    });
  })();
</script>

{% style %}
  #member-new-arrivel-{{ section.id }} {
    --vp-s: 1px;
    padding-top: calc({{ section.settings.padding_top }} * var(--vp-s));
    padding-bottom: calc({{ section.settings.padding_bottom }} * var(--vp-s));
    background: var(--mna-bg-color);
    color: var(--mna-text-color);
    overflow: visible;
  }

  @media screen and (min-width: 850px) and (max-width: 1500px) {
    #member-new-arrivel-{{ section.id }} {
      --vp-s: calc(100vw / 1500);
    }
  }

  @media screen and (max-width: 849px) {
    #member-new-arrivel-{{ section.id }} {
      --vp-s: calc(100vw / 375);
      padding-top: calc({{ section.settings.mobile_padding_top }} * var(--vp-s));
      padding-bottom: calc({{ section.settings.mobile_padding_bottom }} * var(--vp-s));
    }
  }

  #member-new-arrivel-{{ section.id }} * {
    box-sizing: border-box;
  }

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__inner {
    width: 100%;
    max-width: calc({{ section.settings.content_width }} * var(--vp-s));
    margin: 0 auto;
    padding-right: calc({{ section.settings.side_padding }} * var(--vp-s));
    padding-left: calc({{ section.settings.side_padding }} * var(--vp-s));
  }

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__card {
    position: relative;
    min-height: calc({{ section.settings.card_height }} * var(--vp-s));
    padding: calc({{ section.settings.card_padding_top }} * var(--vp-s)) calc({{ section.settings.card_padding_x }} * var(--vp-s)) calc({{ section.settings.card_padding_bottom }} * var(--vp-s));
    border-radius: calc({{ section.settings.card_radius }} * var(--vp-s));
    background-color: rgba(0, 0, 0, .18);
    background-image: linear-gradient(90deg, rgba(var(--mna-panel-rgb), var(--mna-panel-alpha)) 0%, rgba(var(--mna-panel-rgb), calc(var(--mna-panel-alpha) * .7)) 31%, rgba(var(--mna-panel-rgb), 0) 62%), var(--mna-bg-desktop);
    background-size: cover;
    background-position: {{ section.settings.background_position }};
    background-repeat: no-repeat;
    box-shadow: 0 calc(8 * var(--vp-s)) calc(24 * var(--vp-s)) rgba(0, 0, 0, .12);
    overflow: visible;
  }

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__content {
    width: max(calc({{ section.settings.content_area_width }} * var(--vp-s)), calc({{ section.settings.content_area_min_width }} * var(--vp-s)));
    max-width: 100%;
    position: relative;
    z-index: 2;
  }

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__title {
    max-width: min(100%, max(calc({{ section.settings.title_width }} * var(--vp-s)), calc({{ section.settings.title_min_width }} * var(--vp-s))));
    margin: 0 0 calc({{ section.settings.title_margin_bottom }} * var(--vp-s));
    color: var(--mna-title-color);
    font-size: calc({{ section.settings.title_size }} * var(--vp-s));
    line-height: calc({{ section.settings.title_line_height }} * var(--vp-s));
    font-weight: 800;
    letter-spacing: 0;
  }

  {% if section.settings.title_gradient_enabled %}
    #member-new-arrivel-{{ section.id }} .member-new-arrivel__title {
      color: transparent;
      background: linear-gradient(var(--mna-title-gradient-angle), var(--mna-title-gradient-start), var(--mna-title-gradient-end));
      -webkit-background-clip: text;
      background-clip: text;
    }
  {% endif %}

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__title strong,
  #member-new-arrivel-{{ section.id }} .member-new-arrivel__title em {
    color: var(--mna-title-accent);
    font-style: normal;
  }
  .sh-header_G6gLXj .xmax_section__title {
    margin-top: 20px;
  }
  #member-new-arrivel-{{ section.id }} .member-new-arrivel__subtitle {
    max-width: min(100%, max(calc({{ section.settings.subtitle_width }} * var(--vp-s)), calc({{ section.settings.subtitle_min_width }} * var(--vp-s))));
    margin-bottom: calc({{ section.settings.subtitle_margin_bottom }} * var(--vp-s));
    font-size: calc({{ section.settings.subtitle_size }} * var(--vp-s));
    line-height: calc({{ section.settings.subtitle_line_height }} * var(--vp-s));
    font-weight: 400;
    letter-spacing: 0;
  }
  #member-new-arrivel-{{ section.id }} .member-new-arrivel__gift {
    position: relative;
    width: calc({{ section.settings.gift_width }} * var(--vp-s));
    max-width: 100%;
    margin-bottom: calc({{ section.settings.gift_margin_bottom }} * var(--vp-s));
  }

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__gift-inner {
    overflow: hidden;
    border: calc(2 * var(--vp-s)) solid {{ section.settings.gift_card_border_color | default: '#4192FF' }};
    border-radius: calc(8 * var(--vp-s));
    background: {{ section.settings.gift_card_bg | default: '#FFFFFF' }};
  }

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__gift-badge {
    position: absolute;
    top: calc(-18 * var(--vp-s));
    left: calc(-16 * var(--vp-s));
    z-index: 2;
    width: calc(62 * var(--vp-s));
    transform: rotate(-14deg);
    pointer-events: none;
  }

  #member-new-arrivel-{{ section.id }} .member-new-arrivel__gift-badge img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

