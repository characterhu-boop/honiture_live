{% comment %} vd - clean section {% endcomment %}

<style>
  .vd-clean-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }
  .card-image-link{
    width: 100%;
    height: 100%;
  }
  .vd-clean-content {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }

  /* Large Card Styles */
  .vd-clean-grid-large {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 20px;
  }
 
  .vd-clean-card-large {
    display: flex;
    background: #fff;
    border-radius: 12px;
    /* overflow: hidden; */
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
  }
  
  .vd-clean-card-large .card-image {
    width: 64%;
    position: relative;
    background-color: #f9f9f9;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px 0 0 12px;
    /* overflow: hidden; */
  }
  
  .vd-clean-card-large .card-image img {
    flex: 1;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
    border-radius: 12px 0 0 12px;
  }
  
  .vd-clean-card-large:hover .card-image img {
    /* transform: scale(1.05); */
  }
  
 .vd-clean-grid-large .discount-badge {
    position: absolute;
    top: -9px;
    left: 20px;
    width: 80px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: bold;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    z-index: 2;
    text-align: center;
    line-height: 1.2;
    font-size: 16px;
  }

  .vd-clean-card-large .card-info {
    flex: 1;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: left;
  }

  .vd-clean-card-large .card-title {
    font-size: 24px;
    font-weight: 800;
    margin-bottom: 10px;
    color: #333;
    line-height: 1.3;
  }

  .vd-clean-card-large .card-desc {
    font-size: 16px;
    color: #666;
    margin-bottom: 20px;
    line-height: 1.5;
  }

  .vd-clean-card-large .custom-info-image {
    max-width: 100%;
    margin-bottom: 20px;
    display: block;
    object-fit: contain;
  }

  .vd-clean-card-large .price-container {
    margin-bottom: 15px;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  
  .vd-clean-card-large .price-current {
    font-size: 24px;
    font-weight: 800;
    color: #000;
  }
  
  .vd-clean-card-large .price-original {
    text-decoration: line-through;
    color: #999;
    font-size: 16px;
    font-weight: 500;
  }

  /* Small Card Styles */
  .vd-clean-grid-small {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    padding: 20px 0;
  }

  .vd-clean-card-small {
    display: flex;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    align-items: center;
    padding: 40px;
  }
  .vd-clean-card-small a{ 
    width: 100%;
    height: 100%;
  }

  .vd-clean-card-small .card-image {
    width: 45%;
    position: relative;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .vd-clean-card-small .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .vd-clean-card-small .card-info {
    width: 55%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .vd-clean-card-small .card-title {
    font-size: 18px;
    line-height: 1.4;
    font-weight: 700;
    margin-bottom: 8px;
    color: #333;
  }
  
  .vd-clean-card-small .card-desc {
    font-size: 14px;
    color: #666;
    margin-bottom: 10px;
    line-height: 1.4;
  }

  .vd-clean-card-small .price-container {
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  
  .vd-clean-card-small .price-current {
    font-size: 20px;
    font-weight: 700;
    color: #000;
  }
  
  .vd-clean-card-small .price-original {
    text-decoration: line-through;
    color: #999;
    font-size: 14px;
  }

  .vd-clean-card-small .discount-badge {
    position: absolute;
    top: -49px;
    left: 0;
    width: 80px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: bold;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
    z-index: 2;
    text-align: center;
    line-height: 1.2;
    font-size: 12px;
  }

  /* Shared Button & Code Styles */
  .vd-btn {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 10px 30px;
    background-color: #ff84a2;
    color: #fff;
    text-decoration: none;
    border-radius: 25px;
