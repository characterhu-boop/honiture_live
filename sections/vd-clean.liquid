    align-items: center;
    gap: 5px;
    font-size: 14px;
    color: #666;
    flex-wrap: wrap;
    justify-content: center;
  }
  
  .copy-btn {
    background: none;
    border: none;
    color: #ff4ea4;
    text-decoration: underline;
