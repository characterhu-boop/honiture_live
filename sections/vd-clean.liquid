<div class="vd-clean-section">
  <div class="row">
    <div class="small-12 columns">
      {% render 'xmas-section-header' %}

      <div class="vd-clean-content">
        <!-- Large Cards -->
        <div class="vd-clean-grid-large">
          {% for block in section.blocks %}
            {% if block.type == 'large_card' %}
              {% assign product = all_products[block.settings.product] %}
              {% assign title = block.settings.title | default: product.title %}
              {% assign description = block.settings.description | default: product.description %}
              {% assign image = block.settings.image | default: product.featured_image %}
              {% if block.settings.price != blank %}
                {% assign price = block.settings.price %}
              {% else %}
                {% assign extra_discount = block.settings.extra_discount %}
                {% assign multiplier = 100 | minus: extra_discount | divided_by: 100.0 %}
                {% assign price = product.price | times: multiplier | money %}
              {% endif %}
              {% assign compare_at_price = nil %}
              {% if product.compare_at_price > product.price %}
                {% assign compare_at_price = product.compare_at_price | money %}
              {% endif %}
              {% assign code = block.settings.code %}
              

              <div class="vd-clean-card-large" {{ block.shopify_attributes }}>
                <div class="card-image">
                  {% assign discount_text = block.settings.discount_text %}
                  {% if discount_text == blank and product.compare_at_price > product.price %}
                    {% assign discount_value = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                    {% assign discount_text = discount_value | append: '%' %}
                  {% endif %}
                  
                  {% if block.settings.discount_bg != blank or discount_text != blank %}
                    <div class="discount-badge" style="{% if block.settings.discount_bg != blank %}background-image: url({{ block.settings.discount_bg | image_url: width: 200 }});{% endif %}">
                      {{ discount_text }} {% if block.settings.discount_text_wrap %}<br>{% endif %} OFF
                    </div>
                  {% endif %}
                  {% if block.settings.gift_image != blank %}
                    <img class="gift-badge" src="{{ block.settings.gift_image | image_url: width: 200 }}" loading="lazy" alt="Gift">
                  {% endif %}
                  {% if image != blank %}
                    <a href="{{ product.url }}" target="_blank" class="card-image-link">
                      <img src="{{ image | image_url: width: 800 }}" loading="lazy" alt="{{ title | escape }}">
                    </a>
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag }}
                  {% endif %}
                </div>
                <div class="card-info">
                  <h3 class="card-title">{{ title }}</h3>
                  <div class="card-desc">{{ description }}</div>
                  
                  {% if block.settings.custom_icon != blank %}
                    <img class="custom-info-image" src="{{ block.settings.custom_icon | image_url: width: 400 }}" loading="lazy" alt="">
                  {% endif %}
                  
                  <div class="price-container">
                    <span class="price-current">{{ price }}</span>
                    {% if compare_at_price != blank %}
                      <span class="price-original">{{ compare_at_price }}</span>
                    {% endif %}
                  </div>

                  {% if code != blank %}
                    <div class="copy-code-container">
                      {{ block.settings.code_label | default: 'Code:' }} <strong>{{ code }}</strong>
                      <button class="copy-btn"
                        data-clipboard-text="{{ code }}"
                        data-copied-text="Copied"
                        data-reset-ms="3000"
                        onclick="xmasCopyCode(this)">Copy</button>
                    </div>
                  {% endif %}
                  
                  {% if block.settings.btn_link != blank %}
                    <a href="{{ block.settings.btn_link }}" class="vd-btn">{{ block.settings.btn_text | default: 'Shop Now' }}</a>
                  {% else %}
                    <a href="javascript:void(0)" onclick="addCleanItemToCart({{ product.selected_or_first_available_variant.id }})" class="vd-btn">{{ block.settings.btn_text | default: 'Shop Now' }}</a>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>

        <!-- Small Cards -->
        <div class="vd-clean-grid-small">
          {% for block in section.blocks %}
            {% if block.type == 'small_card' %}
              {% assign product = all_products[block.settings.product] %}
              {% assign title = block.settings.title | default: product.title %}
              {% assign description = block.settings.description | default: product.description | strip_html | truncatewords: 15 %}
              {% assign image = block.settings.image | default: product.featured_image %}
              {% assign extra_discount = block.settings.extra_discount %}
              {% assign multiplier = 100 | minus: extra_discount | divided_by: 100.0 %}
              {% assign price = product.price | times: multiplier | money %}
              {% assign compare_at_price = nil %}
              {% if product.compare_at_price > product.price %}
                {% assign compare_at_price = product.compare_at_price | money %}
              {% endif %}
              {% assign code = block.settings.code %}
              
              <div class="vd-clean-card-small" {{ block.shopify_attributes }}>
                <div class="card-image">
                  {% assign discount_text = block.settings.discount_text %}
                  {% if discount_text == blank and product.compare_at_price > product.price %}
                    {% assign discount_value = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                    {% assign discount_text = discount_value | append: '%' %}
                  {% endif %}
                  
                  {% if block.settings.discount_bg != blank or discount_text != blank %} 
                    <div class="discount-badge" style="{% if block.settings.discount_bg != blank %}background-image: url({{ block.settings.discount_bg | image_url: width: 200 }});{% endif %}">
                      {{ discount_text }} {% if block.settings.discount_text_wrap %}<br>{% endif %} OFF
                    </div>
                  {% endif %}

                   {% if block.settings.gift_image != blank %}
                    <img class="gift-badge" src="{{ block.settings.gift_image | image_url: width: 200 }}" loading="lazy" alt="Gift">
                   {% endif %}

                   {% if image != blank %}
                    <a href="{{ product.url }}" target="_blank">
                      <img src="{{ image | image_url: width: 600 }}" loading="lazy" alt="{{ title | escape }}">
                    </a>
                   {% else %}
                    {{ 'product-2' | placeholder_svg_tag }}
                   {% endif %}
                </div>
                <div class="card-info">
                  <h3 class="card-title">{{ title }}</h3>
                  <div class="card-desc">{{ description }}</div>
                  
                  <div class="price-container" >
                    <span class="price-current">{{ price }}</span>
                    {% if compare_at_price != blank %}
                      <span class="price-original">{{ compare_at_price }}</span>
                    {% endif %}
                  </div>

                  {% if code != blank %}
                    <div class="copy-code-container">
                      {{ block.settings.code_label | default: 'Code:' }} {{ code }}
                      <button class="copy-btn"
                        data-clipboard-text="{{ code }}"
                        data-copied-text="Copied"
                        data-reset-ms="3000"
                        onclick="xmasCopyCode(this)">Copy</button>
                    </div>
                  {% endif %}
                  
                  {% if block.settings.btn_link != blank %}
                    <a href="{{ block.settings.btn_link }}" class="vd-btn">{{ block.settings.btn_text | default: 'Shop Now' }}</a>
                  {% else %}
                    <a href="javascript:void(0)" onclick="addCleanItemToCart({{ product.selected_or_first_available_variant.id }})" class="vd-btn">{{ block.settings.btn_text | default: 'Shop Now' }}</a>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
{% render 'section-decorations', section: section %}
<script>
  if (!window.addCleanItemToCart) {
    window.addCleanItemToCart = function(id) {
      var form = document.createElement('form');
      form.method = 'POST';
      form.action = window.Shopify.routes.root + 'cart/add';
      form.target = '_blank';
      
      var idInput = document.createElement('input');
      idInput.setAttribute('name', 'id');
      idInput.setAttribute('value', id);
      idInput.setAttribute('type', 'hidden');
      
      var qtyInput = document.createElement('input');
      qtyInput.setAttribute('name', 'quantity');
      qtyInput.setAttribute('value', '1');
      qtyInput.setAttribute('type', 'hidden');
      
      form.appendChild(idInput);
      form.appendChild(qtyInput);
      
      document.body.appendChild(form);
      form.submit();
      document.body.removeChild(form);
    };
  }

  if (!window.xmasCopyCode) {
    window.xmasCopyCode = function(btn) {
      if (!btn) return;
      var originalText = (btn.textContent || '').trim() || 'Copy';
      var copiedText = btn.getAttribute('data-copied-text') || 'Copied';
      var resetMs = parseInt(btn.getAttribute('data-reset-ms') || '3000', 10);
      var code = btn.getAttribute('data-clipboard-text') || '';
      if (!code) return;

      function copyText(text) {
        if (navigator.clipboard && navigator.clipboard.writeText) {
          return navigator.clipboard.writeText(text);
        }
        return new Promise(function(resolve, reject) {
          try {
            var ta = document.createElement('textarea');
            ta.value = text;
            ta.style.position = 'fixed';
            ta.style.top = '-1000px';
            document.body.appendChild(ta);
            ta.focus();
            ta.select();
            var ok = document.execCommand('copy');
            document.body.removeChild(ta);
            if (ok) resolve(); else reject(new Error('execCommand failed'));
          } catch (e) { reject(e); }
        });
      }

      copyText(code).then(function() {
        btn.textContent = copiedText;
        btn.disabled = true;
        setTimeout(function() {
          btn.textContent = originalText;
          btn.disabled = false;
        }, isNaN(resetMs) ? 3000 : resetMs);
      });
    };
  }
</script>

