{{- 'image-with-text-overlay.css' | asset_url | stylesheet_tag -}}
{%- liquid
  assign full_width = section.settings.full_width
  assign image = section.settings.image
  assign mobile_image = section.settings.mobile_image
  assign mobile_image_fit = section.settings.mobile_image_fit
  assign image_parallax = section.settings.image_parallax
  assign desktop_height = section.settings.desktop_height
  assign mobile_height = section.settings.mobile_height
  assign desktop_custom_height = section.settings.desktop_custom_height
  assign mobile_custom_height = section.settings.mobile_custom_height

  assign content_width = section.settings.content_width
  assign desktop_content_width = section.settings.desktop_content_width
  assign content_position = section.settings.content_position
  assign text_alignment = section.settings.text_alignment
  assign mobile_text_alignment = section.settings.mobile_text_alignment

  assign text_color = section.settings.text_color
  assign overlay_color = section.settings.overlay_color
  assign overlay_opacity = section.settings.overlay_opacity

  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing

  case mobile_height
    when 'mobile-height-350'
      assign mobile_image_height = 350
    when 'mobile-height-400'
      assign mobile_image_height = 400
    when 'mobile-height-450'
      assign mobile_image_height = 450
    when 'mobile-height-500'
      assign mobile_image_height = 500
    else
      assign mobile_image_height = 900
  endcase

  if mobile_custom_height != blank
    assign mobile_image_height = mobile_custom_height
  endif

  assign priority = false
  assign heading_tag = 'h3'
  if section.index == 1
    assign priority = 'high'
    assign heading_tag = 'h1'
  endif
-%}
<div class="row {% if full_width %}full-width-row-full{% endif %}">
  <div class="small-12 columns">
    <image-with-text-overlay-custom
      class="image-with-text-overlay image-with-text-overlay--full-width-{{ full_width }} text-{{ text_alignment }} {{ mobile_height }} {{ desktop_height }} section-spacing{% if mobile_image_fit == 'contain' %} image-with-text-overlay--mobile-contain-natural{% endif %}{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}"
      style="--text-color: {{ text_color }}; --overlay-color-rgb: {{ overlay_color.rgb | replace: ' ' , ',' }}; --overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }}"
      data-enable-animations="{{ image_parallax }}"
      data-animations-src="{{ 'animations.min.js' | asset_url }}"
      data-mobile-text-alignment="{{ mobile_text_alignment }}"
    >
      <div class="image-with-text-overlay--bg parallax--false">
        {% if image %}
          {%- liquid
            assign small_width = image.src.height | times: '375' | divided_by: image.src.width
            assign master_width = image.src.width | append: 'x' | append: image.src.height
            assign width = '375x' | append: small_width | append: ',' | append: master_width

            assign class = ''

            if mobile_image
              assign class = class | append: ' image-with-text-overlay--desktop'
            endif
          -%}
          {%- render 'responsive-image', image: image, sizes: width, class: class, priority: priority -%}
        {% else %}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder_svg_tag' }}
        {% endif %}
        {%- if mobile_image -%}
          {%- liquid
            assign image = mobile_image
            assign master_width = image.src.width | append: 'x' | append: image.src.height
            assign width = '375x' | append: mobile_image_height | append: ',' | append: master_width

            assign class = ''

            assign class = class | append: ' image-with-text-overlay--mobile'
            if mobile_image_fit == 'contain'
              assign class = class | append: ' image-with-text-overlay--mobile-fit-contain'
            endif
          -%}
          {%- render 'responsive-image', image: image, sizes: width, class: class, priority: priority -%}
        {%- endif -%}
      </div>

      <div class="image-with-text-overlay--content content-{{ content_position }}">
        <div class="image-with-text-overlay--content-inner content-width-{{ content_width }}">
          {% for block in section.blocks %}
            {%- case block.type -%}
              {%- when 'badge' -%}
                <div {{ block.shopify_attributes }}>
                  <span
                    class="inline-badge"
                    style="--badge-bg: {{ block.settings.color_bg }};--badge-text: {{ block.settings.color_text }}"
                  >
                    {{- block.settings.text -}}
                  </span>
                </div>
              {%- when 'subheading' -%}
                <p class="subheading" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- when 'heading' -%}
                {%- liquid
                  if block.settings.heading_tag != 'adaptive'
                    assign heading_tag = block.settings.heading_tag
                  endif
                  assign heading_text = block.settings.text | replace: '</p><p>', '<br>' | replace: '<p>', '' | replace: '</p>', ''
                -%}
                <{{ heading_tag }}
                  class="{{ block.settings.heading_size }} image-with-text-overlay--heading"
                  style="{% if block.settings.desktop_font_size != blank %}--heading-desktop-font-size: {{ block.settings.desktop_font_size }}px;{% endif %}{% if block.settings.mobile_font_size != blank %}--heading-mobile-font-size: {{ block.settings.mobile_font_size }}px;{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- heading_text -}}
                </{{ heading_tag }}>
              {%- when 'text' -%}
                <div
                  class="rte description-size--{{ block.settings.description_size }}"
                  style="{% if block.settings.desktop_font_size != blank %}--text-desktop-font-size: {{ block.settings.desktop_font_size }}px;{% endif %}{% if block.settings.mobile_font_size != blank %}--text-mobile-font-size: {{ block.settings.mobile_font_size }}px;{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </div>
              {%- when 'packing_list' -%}
                <div
                  class="image-with-text-overlay--packing-list"
                  style="--packing-list-marker-bg: {{ block.settings.marker_bg }}; --packing-list-marker-text: {{ block.settings.marker_text }};"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.title != blank -%}
                    <h3 class="image-with-text-overlay--packing-list-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  <div class="image-with-text-overlay--packing-list-items">
                    {%- for index in (1..10) -%}
                      {%- liquid
                        assign item_key = 'item_' | append: index
                        assign item_text = block.settings[item_key]
                        assign item_lines = item_text | newline_to_br | split: '<br />'
                      -%}
                      {%- if item_text != blank -%}
                        <div class="image-with-text-overlay--packing-list-item">
                          <span class="image-with-text-overlay--packing-list-marker">{{ index }}</span>
                          <span class="image-with-text-overlay--packing-list-text">
                            <span class="image-with-text-overlay--packing-list-main-text">{{ item_lines[0] }}</span>
                            {%- for item_line in item_lines offset: 1 -%}
                              {%- if item_line != blank -%}
                                <span class="image-with-text-overlay--packing-list-sub-text">{{ item_line }}</span>
                              {%- endif -%}
                            {%- endfor -%}
                          </span>
                        </div>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- when 'icon_text' -%}
                <div
                  class="image-with-text-overlay--icon-text-grid"
                  style="--icon-text-desktop-offset-x: {{ block.settings.desktop_offset_x }}px;"
                  {{ block.shopify_attributes }}
                >
                  {%- for index in (1..4) -%}
                    {%- liquid
                      assign icon_key = 'icon_' | append: index
                      assign title_key = 'title_' | append: index
                      assign text_key = 'text_' | append: index
                      assign icon = block.settings[icon_key]
                      assign title = block.settings[title_key]
                      assign text = block.settings[text_key]
                      assign icon_height = 40
                      assign icon_mobile_height = 32
                      if index <= 2
                        assign icon_height = 32
                        assign icon_mobile_height = 22
                      endif
                    -%}
                    <div class="image-with-text-overlay--icon-text-item">
                      <div class="image-with-text-overlay--icon-text-item-inner">
                      {%- if icon != blank -%}
                        <img
                          class="image-with-text-overlay--icon-text-image"
                          src="{{ icon | image_url: width: 160 }}"
                          alt="{{ icon.alt | default: title | escape }}"
                          loading="lazy"
                          width="80"
                          height="{{ icon_height }}"
                          style="--icon-height: {{ icon_height }}px; --icon-mobile-height: {{ icon_mobile_height }}px;"
                        >
                      {%- endif -%}
                      {%- if title != blank -%}
                        <p class="image-with-text-overlay--icon-text-title">{{ title | newline_to_br }}</p>
                      {%- endif -%}
                      {%- if text != blank -%}
                        <p class="image-with-text-overlay--icon-text-text">{{ text }}</p>
                      {%- endif -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              {%- when 'button' -%}
                {% if block.settings.button_text != blank %}
                  <a
                    class="button {{ block.settings.button_color }}"
                    href="{{ block.settings.button_link }}"
                    role="button"
                    title="{{ block.settings.button_text | escape }}"
                    {{ block.shopify_attributes }}
                  >
                    {{- block.settings.button_text -}}
                  </a>
                {% endif %}
              {%- when 'newsletter' -%}
                <div class="image-with-text-overlay--newsletter" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <h4 class="newsletter-title">{{ block.settings.title }}</h4>
                  {%- endif -%}
                  {%- form 'customer', class: 'newsletter-form' -%}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="newsletter-form__field-wrapper">
                      <div class="field">
                        <input
                          id="NewsletterForm--{{ section.id }}"
                          type="email"
                          name="contact[email]"
                          class="field__input"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          capitalize="off"
                          autocomplete="email"
                          {% if form.errors %}
                            autofocus
                            aria-invalid="true"
                            aria-describedby="Newsletter-error--{{ section.id }}"
                          {% elsif form.posted_successfully? %}
                            aria-describedby="Newsletter-success--{{ section.id }}"
                          {% endif %}
                          placeholder="{{ block.settings.placeholder }}"
                          required
                        >
                        <button
                           type="submit"
                           class="newsletter-form__button"
                           name="commit"
                           id="Subscribe"
                           aria-label="{{ 'newsletter.button_label' | t }}"
                           style="background-color: {{ block.settings.btn_bg_color }}; color: {{ block.settings.btn_text_color }};"
                         >
                           <span class="button-text">{{ block.settings.button_text }}</span>
                           <div class="loading-overlay__spinner hidden">
                             <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                               <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                             </svg>
                           </div>
                         </button>
                       </div>
                       {%- if form.errors -%}
                         <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                           {{- form.errors.translated_fields.email | capitalize }}
                           {{ form.errors.messages.email -}}
                         </small>
                       {%- endif -%} 
                     </div>
                     {%- if form.posted_successfully? -%}
                       <h3
                         class="newsletter-form__message newsletter-form__message--success form__message header_sub_success_text"
                         id="Newsletter-success--{{ section.id }}"
                         tabindex="-1"
                         autofocus 
                       >
                         {{- 'newsletter.success' | t -}}
                       </h3>
                     {%- endif -%}
                     {%- if block.settings.agreement_text != blank -%}
                       <div class="newsletter-agreement">
                         <label class="agreement-checkbox">
                           <input type="checkbox" class="newsletter-checkbox">
                           <span class="checkmark"></span>
                           <div class="agreement-text">{{ block.settings.agreement_text }}</div>
                         </label>
                       </div>
                     {%- endif -%}
                   {%- endform -%}
                 </div>
              {% when 'space' %}
                <div style="height: {{ block.settings.height | append: 'px' }}" {{ block.shopify_attributes }}></div>
            {%- endcase -%}
          {% endfor %}
        </div>
        {% for block in section.blocks %}
          {%- if block.type == 'floating_image' and block.settings.image != blank -%}
            <div
              class="image-with-text-overlay--floating-image"
              style="
                --floating-image-desktop-left: {{ block.settings.desktop_left }}px;
                --floating-image-desktop-top: {{ block.settings.desktop_top }}px;
                --floating-image-desktop-width: {{ block.settings.desktop_width }}px;
                --floating-image-mobile-left: {{ block.settings.mobile_left }}px;
                --floating-image-mobile-top: {{ block.settings.mobile_top }}px;
                --floating-image-mobile-width: {{ block.settings.mobile_width }}px;
              "
              {{ block.shopify_attributes }}
            >
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            </div>
          {%- endif -%}
        {% endfor %}
      </div>
    </image-with-text-overlay-custom>
  </div>
</div>
<script src="{{ 'image-with-text-overlay-custom.js' | asset_url }}" defer="defer"></script>

<style>
  image-with-text-overlay-custom[data-enable-animations="true"] .image-with-text-overlay--heading,
  image-with-text-overlay-custom[data-enable-animations="true"] .rte,
  image-with-text-overlay-custom[data-enable-animations="true"] .button,
  image-with-text-overlay-custom[data-enable-animations="true"] .image-with-text-overlay--packing-list-title,
  image-with-text-overlay-custom[data-enable-animations="true"] .image-with-text-overlay--packing-list-item,
  image-with-text-overlay-custom[data-enable-animations="true"] .image-with-text-overlay--icon-text-item {
    opacity: 0;
    transform: translateY(28px);
  }
  image-with-text-overlay-custom[data-enable-animations="true"] .image-with-text-overlay--floating-image {
    opacity: 0;
  }
  #shopify-section-{{ section.id }} image-with-text-overlay-custom.image-with-text-overlay,
  #shopify-section-{{ section.id }} .image-with-text-overlay--bg {
    background-color: #000;
  }
  @media only screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .image-with-text-overlay--heading[style*="--heading-desktop-font-size"] {
      font-size: var(--heading-desktop-font-size);
    }
    #shopify-section-{{ section.id }} .rte[style*="--text-desktop-font-size"] {
      font-size: var(--text-desktop-font-size);
    }
  }
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .image-with-text-overlay--heading[style*="--heading-mobile-font-size"] {
      font-size: var(--heading-mobile-font-size);
    }
    #shopify-section-{{ section.id }} .rte[style*="--text-mobile-font-size"] {
      font-size: var(--text-mobile-font-size);
    }
  }
  {%- if desktop_content_width != blank -%}
    @media only screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} .image-with-text-overlay--content-inner {
        max-width: {{ desktop_content_width }}px;
      }
    }
  {%- endif -%}
  {%- if desktop_custom_height != blank -%}
    @media only screen and (min-width: 768px) {
      #shopify-section-{{ section.id }} image-with-text-overlay-custom.image-with-text-overlay {
        height: auto;
        min-height: {{ desktop_custom_height }}px;
      }
    }
  {%- endif -%}
  {%- if mobile_custom_height != blank -%}
    @media only screen and (max-width: 767px) {
      #shopify-section-{{ section.id }} image-with-text-overlay-custom.image-with-text-overlay {
        height: auto;
        min-height: {{ mobile_custom_height }}px;
      }
    }
  {%- endif -%}
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .image-with-text-overlay--mobile-fit-contain {
      object-fit: contain;
      object-position: center center;
    }
    #shopify-section-{{ section.id }} .image-with-text-overlay--mobile-contain-natural {
      height: auto;
      min-height: 0;
      padding-top: 0;
      padding-bottom: 0;
      overflow: visible;
      background-color: #000;
    }
    #shopify-section-{{ section.id }} .image-with-text-overlay--mobile-contain-natural .image-with-text-overlay--bg {
      position: relative;
      height: auto;
      top: auto;
      left: auto;
      background-color: #000;
    }
    #shopify-section-{{ section.id }} .image-with-text-overlay--mobile-contain-natural .image-with-text-overlay--bg:after {
      background: transparent;
    }
    #shopify-section-{{ section.id }} .image-with-text-overlay--mobile-contain-natural .image-with-text-overlay--bg img,
    #shopify-section-{{ section.id }} .image-with-text-overlay--mobile-contain-natural .image-with-text-overlay--bg svg {
      width: 100%;
      height: auto;
      object-fit: contain;
    }
    #shopify-section-{{ section.id }} .image-with-text-overlay--mobile-contain-natural .image-with-text-overlay--content {
      position: absolute;
      inset: 0;
    }
  } 
  #shopify-section-{{ section.id }} .image-with-text-overlay--bg .lazyloading,
  #shopify-section-{{ section.id }} .image-with-text-overlay--bg .lazyloaded,
  #shopify-section-{{ section.id }} .image-with-text-overlay--bg .lazyload {
    filter: none !important;
    -webkit-filter: none !important;
    opacity: 1 !important;
  }
  .image-with-text-overlay--icon-text-grid {
    display: grid;
    width: min(100%, 388px);
    min-height: 234px;
    margin-top: 20px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 0;
    row-gap: 28px;
    justify-items: stretch;
    color: var(--text-color, #fff);
  }
  @media only screen and (min-width: 768px) {
    .image-with-text-overlay--icon-text-grid {
      transform: translateX(var(--icon-text-desktop-offset-x, 0));
    }
  }
  .image-with-text-overlay--icon-text-item {
    display: flex;
    width: 100%;
    min-height: 103px;
    margin: 0;
    padding: 0;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
  }
  .image-with-text-overlay--icon-text-item-inner {
    display: flex;
    width: 160px;
    max-width: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    text-align: center;
  }
  .image-with-text-overlay--icon-text-image {
    display: block;
    width: 80px;
    height: var(--icon-height, 40px);
    margin: 0 auto 0;
    object-fit: contain;
  }
  .image-with-text-overlay--icon-text-title,
  .image-with-text-overlay--icon-text-text {
    margin: 0;
    color: inherit;
    text-align: center;
  }
  .image-with-text-overlay--icon-text-title {
    font-family: 'Source Han Sans CN', var(--font-heading-family, inherit);
    font-weight: 500;
    font-size: 20px;
    line-height: 1;
    padding: 10px 0;
  }
  .image-with-text-overlay--icon-text-text {
    font-family: 'Isidora Sans', var(--font-body-family, inherit);
    font-weight: 400;
    font-size: 16px;
    line-height: 19px;
    white-space: nowrap;
  }
  .image-with-text-overlay--packing-list {
    width: min(100%, 1280px);
    color: var(--text-color, #fff);
  }
  .image-with-text-overlay--packing-list-title {
    margin: 0 0 45px;
    color: inherit;
    font-family: 'Isidora Sans', var(--font-heading-family, inherit);
    font-size: 38px;
    font-weight: 700;
    line-height: 48px;
    text-align: left;
  } 
  .image-with-text-overlay--packing-list-items {
    display: grid;
    grid-auto-flow: column;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(5, auto);
    column-gap: 60px;
    row-gap: 24px;
    max-width: 760px;
  }
  .image-with-text-overlay--packing-list-item {
    display: flex;
    min-width: 0;
    align-items: flex-start;
    gap: 16px;
    color: inherit;
    text-align: left;
  }
  .image-with-text-overlay--packing-list-marker {
    display: inline-flex;
    width: 27px;
    height: 27px;
    flex: 0 0 27px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--packing-list-marker-bg, #b99a83);
    color: var(--packing-list-marker-text, #ffffff);
    font-family: 'Isidora Sans', var(--font-body-family, inherit);
    font-size: 20px;
    font-weight: 500;
    line-height: 24px;
  }
  .image-with-text-overlay--packing-list-text {
    display: block;
    min-width: 0;
    color: inherit;
    font-family: 'Isidora Sans', var(--font-body-family, inherit);
    font-weight: 500;
    text-align: left;
  }
  .image-with-text-overlay--packing-list-main-text,
  .image-with-text-overlay--packing-list-sub-text {
    display: block;
  }
  .image-with-text-overlay--packing-list-main-text {
    font-size: 20px;
    line-height: 24px;
  }
  .image-with-text-overlay--packing-list-sub-text {
    margin-top: 2px;
    font-size: 14px;
    line-height: 17px;
  }
  .image-with-text-overlay--floating-image {
    position: absolute;
    z-index: 6;
    left: var(--floating-image-desktop-left, 0px);
    top: var(--floating-image-desktop-top, 0px);
    width: var(--floating-image-desktop-width, 300px);
    max-width: 100%;
    pointer-events: none;
  }
  .image-with-text-overlay--floating-image img {
    display: block;
    width: 100%;
    height: auto;
  }
  .image-with-text-overlay--newsletter {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(10px);
    padding: 20px;
    border-radius: 20px;
    max-width: 500px;
    /* margin: 0 auto; */
    text-align: left;
  }
  .image-with-text-overlay--newsletter .newsletter-title {
    margin: 0 0 20px 0;
    font-size: 18px;
    font-weight: 600;
    color: #333;
  }
  .image-with-text-overlay--newsletter .newsletter-form__field-wrapper .field {
    display: flex;
    background: #fff;
    border-radius: 30px;
    overflow: hidden;
    border: 1px solid #e5e5e5;
    height: 50px;
  }
  .image-with-text-overlay--newsletter .field__input {
    flex: 1;
    border: none !important;
    padding: 0 20px;
    height: 100%;
    outline: none;
    box-shadow: none !important;
    background: transparent;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button {
    border-radius: 0 30px 30px 0;
    border: none;
    padding: 0 30px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    height: 100%;
    transition: opacity 0.3s;
    margin: 0;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button:hover {
    opacity: 0.9;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button .loading-overlay__spinner {
    width: 20px;
    height: 20px;
    display: inline-block;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button .loading-overlay__spinner.hidden {
