 <script>
   document.addEventListener('DOMContentLoaded', function() {
     const newsletterForms = document.querySelectorAll('.newsletter-form');
     
     newsletterForms.forEach(form => {
       const checkbox = form.querySelector('.newsletter-checkbox');
       const agreementLabel = form.querySelector('.agreement-checkbox');
       const submitBtn = form.querySelector('.newsletter-form__button');
       const btnText = submitBtn.querySelector('.button-text');
       const spinner = submitBtn.querySelector('.loading-overlay__spinner');
       
       form.addEventListener('submit', function(e) {
         // 校验复选框
         if (checkbox && !checkbox.checked) {
           e.preventDefault();
           e.stopImmediatePropagation();
           if (agreementLabel) {
             agreementLabel.classList.add('has-error');
           }
           return false;
         }
         
         // 显示 loading 状态
         if (submitBtn) {
           submitBtn.setAttribute('disabled', 'disabled');
           if (btnText) btnText.classList.add('hidden');
           if (spinner) spinner.classList.remove('hidden');
         }
       }, true); // 使用捕获阶段确保优先执行
       
       // 当复选框状态改变时移除错误样式
       if (checkbox) {
         checkbox.addEventListener('change', function() {
           if (this.checked && agreementLabel) {
             agreementLabel.classList.remove('has-error');
           }
         });
       }
     });
   });
 </script>

