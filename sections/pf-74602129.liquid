  Code:
  <span class="copy-discount-code" style="color: #ee6819; cursor: pointer; text-decoration: underline;" data-code-index="0"></span>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 折扣码数组 - 可以根据需要添加更多折扣码
    const discountCodes = [
      'HALLOW10',
      'HALLOW8',
      'HALLOW8',
    ];
    
    // 获取所有折扣码按钮
    const copyButtons = document.querySelectorAll('.copy-discount-code');
    
    copyButtons.forEach((button, index) => {
      // 为每个按钮分配对应的折扣码
      const codeIndex = parseInt(button.getAttribute('data-code-index')) || index;
      const assignedCode = discountCodes[codeIndex % discountCodes.length];
      
      // 设置按钮显示的文本
      button.textContent = ` ${assignedCode}`;
      button.setAttribute('data-original-text', assignedCode);
      button.setAttribute('data-discount-code', assignedCode);
      
      // 添加点击事件
      button.addEventListener('click', function() {
        const codeTooCopy = this.getAttribute('data-discount-code');
        const originalText = this.getAttribute('data-original-text');
        
        console.log('Copying code:', codeTooCopy);
        
        // 使用现代的 Clipboard API 或回退到旧方法
        if (navigator.clipboard && window.isSecureContext) {
          // 使用现代 Clipboard API
          navigator.clipboard.writeText(codeTooCopy).then(() => {
            console.log('Code copied successfully');
          }).catch(err => {
            console.error('Failed to copy code:', err);
            // 回退到旧方法
            fallbackCopyTextToClipboard(codeTooCopy);
          });
        } else {
          // 回退到旧方法
          fallbackCopyTextToClipboard(codeTooCopy);
        }
        
        // 修改按钮文本为"Copied"
        this.textContent = 'Copied';
        
        // 2秒后恢复原始文本
        setTimeout(() => {
          this.textContent = ` ${originalText}`;
        }, 2000);
      });
    });
    
    // 回退复制方法
    function fallbackCopyTextToClipboard(text) {
      const tempInput = document.createElement('textarea');
      tempInput.value = text;
      tempInput.style.position = 'fixed';
      tempInput.style.left = '-999999px';
      tempInput.style.top = '-999999px';
      document.body.appendChild(tempInput);
      tempInput.focus();
      tempInput.select();
      
      try {
        document.execCommand('copy');
        console.log('Fallback: Code copied successfully');
      } catch (err) {
        console.error('Fallback: Failed to copy code:', err);
      }
      
      document.body.removeChild(tempInput);
    }
  });
</script></div><button data-product-id="{{ product.id }}" data-checkout="checkout" data-soldout="Sold out" data-adding="Adding..." data-added="Thank you!" name="add" type="button" data-pf-type="ProductATC2" class="sc-jBqsaa Eamsq pf-271_ pf-button-1 cus-icon-button">Buy Now <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" data-pf-type="Icon2" class="sc-lgjIEp eKorth pf-272_ pf-icon2-1"><path d="M0 24C0 10.7 10.7 0 24 0H69.5c22 0 41.5 12.8 50.6 32h411c26.3 0 45.5 25 38.6 50.4l-41 152.3c-8.5 31.4-37 53.3-69.5 53.3H170.7l5.4 28.5c2.2 11.3 12.1 19.5 23.6 19.5H488c13.3 0 24 10.7 24 24s-10.7 24-24 24H199.7c-34.6 0-64.3-24.6-70.7-58.5L77.4 54.5c-.7-3.8-4-6.5-7.9-6.5H24C10.7 48 0 37.3 0 24zM128 464a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm336-48a48 48 0 1 1 0 96 48 48 0 1 1 0-96z"></path></svg></button><button data-product-id="{{ product.id }}" data-checkout="same" data-soldout="Sold out" data-adding="Adding..." data-added="Thank you!" name="add" type="button" data-pf-type="ProductATC2" class="sc-jBqsaa ceQZtx pf-273_ pf-button-1 pf-lg-hide pf-md-hide">Add To Cart</button></div></div></div>{% endform %}{% endif %}</div></div>{% endfor %}{% endpaginate %}{% assign product = defaultProduct %}<button type="button" aria-label="Previous" style="visibility:hidden" class="pf-slider-prev nav-style-1"></button><button type="button" aria-label="Next" style="visibility:hidden" class="pf-slider-next nav-style-1"></button><div class="pf-slider-nav pagination-style-1"></div></div></div><div data-pf-type="Custom.HTML" class="sc-bWJTsT bqQLUR pf-275_ pf-lg-hide pf-md-hide"><script>
