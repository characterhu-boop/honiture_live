{% comment %}
  M7 cleaning system section
  Separate desktop/mobile background images with scroll-activated feature points.
{% endcomment %}

<section
  id="m7-cleaning-system-{{ section.id }}"
  class="m7-cleaning-system"
  data-m7-cleaning-system
>
  <div class="m7-cleaning-system__media">
    {%- liquid
      assign mobile_video = section.settings.video_mobile
      if mobile_video == blank
        assign mobile_video = section.settings.video_pc
      endif
    -%}

    {%- if section.settings.video_pc != blank -%}
      {{
        section.settings.video_pc
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          class: 'm7-cleaning-system__video m7-cleaning-system__video--desktop'
      }}
    {%- elsif section.settings.image_pc != blank -%}
      <img 
        class="m7-cleaning-system__image m7-cleaning-system__image--desktop"
        src="{{ section.settings.image_pc | image_url: width: 1800 }}"
        srcset="
          {{ section.settings.image_pc | image_url: width: 900 }} 900w,
          {{ section.settings.image_pc | image_url: width: 1400 }} 1400w,
          {{ section.settings.image_pc | image_url: width: 1800 }} 1800w
        "
        sizes="100vw"
        alt="{{ section.settings.image_pc.alt | default: section.settings.title | escape }}"
        loading="lazy"
      >
    {%- endif -%}

    {%- if mobile_video != blank -%}
      {{
        mobile_video
        | video_tag:
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          playsinline: true,
          class: 'm7-cleaning-system__video m7-cleaning-system__video--mobile'
      }}
    {%- elsif section.settings.image_mobile != blank -%}
      <img
        class="m7-cleaning-system__image m7-cleaning-system__image--mobile"
        src="{{ section.settings.image_mobile | image_url: width: 900 }}"
        srcset="
          {{ section.settings.image_mobile | image_url: width: 480 }} 480w,
          {{ section.settings.image_mobile | image_url: width: 720 }} 720w,
          {{ section.settings.image_mobile | image_url: width: 900 }} 900w
        "
        sizes="100vw"
        alt="{{ section.settings.image_mobile.alt | default: section.settings.title | escape }}"
        loading="lazy"
      >
    {%- elsif section.settings.image_pc != blank -%}
      <img
        class="m7-cleaning-system__image m7-cleaning-system__image--mobile"
        src="{{ section.settings.image_pc | image_url: width: 900 }}"
        srcset="
          {{ section.settings.image_pc | image_url: width: 480 }} 480w,
          {{ section.settings.image_pc | image_url: width: 720 }} 720w,
          {{ section.settings.image_pc | image_url: width: 900 }} 900w
        "
        sizes="100vw"
        alt="{{ section.settings.image_pc.alt | default: section.settings.title | escape }}"
        loading="lazy"
      >
    {%- endif -%}
  </div>

  <div class="m7-cleaning-system__content">
    {%- if section.settings.title != blank -%}
      <h2 class="m7-cleaning-system__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="m7-cleaning-system__description">{{ section.settings.description }}</div>
    {%- endif -%}

    <ol class="m7-cleaning-system__points" aria-label="{{ section.settings.title | escape }}">
      {%- if section.settings.point_1 != blank -%}
        <li class="m7-cleaning-system__point is-active" data-m7-cleaning-point>
          <span class="m7-cleaning-system__dot"></span>
          <span class="m7-cleaning-system__point-text">{{ section.settings.point_1 }}</span>
        </li>
      {%- endif -%}
      {%- if section.settings.point_2 != blank -%}
        <li class="m7-cleaning-system__point" data-m7-cleaning-point>
          <span class="m7-cleaning-system__dot"></span>
          <span class="m7-cleaning-system__point-text">{{ section.settings.point_2 }}</span>
        </li>
      {%- endif -%}
      {%- if section.settings.point_3 != blank -%}
        <li class="m7-cleaning-system__point" data-m7-cleaning-point>
          <span class="m7-cleaning-system__dot"></span>
          <span class="m7-cleaning-system__point-text">{{ section.settings.point_3 }}</span>
        </li>
      {%- endif -%}
    </ol>
  </div>
</section>

{%- style -%}
  #m7-cleaning-system-{{ section.id }} {
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.desktop_height }}px;
    background: {{ section.settings.background }};
    color: {{ section.settings.text_color }};
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__image,
  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__video {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: {{ section.settings.desktop_image_position }};
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__image--mobile,
  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__video--mobile {
    display: none;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__content {
    position: relative;
    z-index: 1;
    width: min({{ section.settings.content_width }}px, calc(100% - 40px));
    padding-top: {{ section.settings.content_top }}px;
    margin-left: max(20px, calc((100vw - {{ section.settings.max_width }}px) / 2 + {{ section.settings.content_left }}px));
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__title {
    margin: 0 0 12px;
    color: {{ section.settings.title_color }};
    font-family: "Isidora Sans", var(--font-body-family), Arial, sans-serif;
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.08;
    font-weight: 800;
    letter-spacing: 0;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__description {
    margin: 0;
    color: {{ section.settings.description_color }};
    font-family: "Isidora Sans", var(--font-body-family), Arial, sans-serif;
    font-size: {{ section.settings.description_size }}px;
    line-height: 1.35;
    font-weight: 400;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__description p {
    margin: 0;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__points {
    --point-idle: {{ section.settings.point_idle_color }};
    --point-active: {{ section.settings.point_active_color }};
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.point_gap }}px;
    margin: {{ section.settings.point_margin_top }}px 0 0;
    padding: 0;
    list-style: none;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__point {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
    min-height: 18px;
    color: var(--point-idle);
    font-size: {{ section.settings.point_size }}px;
    line-height: 1.25;
    font-weight: 500;
    transition: color 260ms ease, opacity 260ms ease;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__point:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 16px;
    width: 1px;
    height: calc({{ section.settings.point_gap }}px + 6px);
    background: currentColor;
    opacity: 0.55;
    transition: background 260ms ease, opacity 260ms ease;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__dot {
    position: relative;
    z-index: 1;
    flex: 0 0 9px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 0 0 rgba(255, 255, 255, 0);
    transition: background 260ms ease, box-shadow 260ms ease, transform 260ms ease;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__point.is-active {
    color: var(--point-active);
    font-weight: 700;
  }

  #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__point.is-active .m7-cleaning-system__dot {
    transform: scale(1.08);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.14);
  }

  @media (max-width: 768px) {
    #m7-cleaning-system-{{ section.id }} {
      min-height: {{ section.settings.mobile_height }}px;
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__image--desktop,
    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__video--desktop {
      display: none;
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__image--mobile,
    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__video--mobile {
      display: block;
      object-position: {{ section.settings.mobile_image_position }};
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__content {
      width: calc(100% - 48px);
      padding-top: {{ section.settings.mobile_content_top }}px;
      margin: 0 auto;
      text-align: center;
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__title {
      font-size: {{ section.settings.mobile_title_size }}px;
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__description {
      max-width: 300px;
      margin: 0 auto;
      font-size: {{ section.settings.mobile_description_size }}px;
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__points {
      width: fit-content;
      margin-top: {{ section.settings.mobile_point_margin_top }}px;
      text-align: left;
      gap: {{ section.settings.mobile_point_gap }}px;
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__point {
      font-size: {{ section.settings.mobile_point_size }}px;
    }

    #m7-cleaning-system-{{ section.id }} .m7-cleaning-system__point:not(:last-child)::after {
      height: calc({{ section.settings.mobile_point_gap }}px + 6px);
    }
  }
{%- endstyle -%}

<script>
  (function() {
    var section = document.getElementById('m7-cleaning-system-{{ section.id }}');
    if (!section) return;

    var points = Array.prototype.slice.call(section.querySelectorAll('[data-m7-cleaning-point]'));
    if (!points.length) return;

    function setActive(count) {
      points.forEach(function(point, index) {
        point.classList.toggle('is-active', index < count);
      });
    }

    function update() {
      var rect = section.getBoundingClientRect();
      var viewport = window.innerHeight || document.documentElement.clientHeight;
      var visibleProgress = (viewport - rect.top) / (viewport + rect.height);
      var count = 1;

      if (visibleProgress >= 0.34) count = 2;
      if (visibleProgress >= 0.42) count = 3;

      setActive(Math.min(count, points.length));
    }

    var ticking = false;
    function requestUpdate() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(function() {
        update();
        ticking = false;
      });
    }

    update();
    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate);

    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail && event.detail.sectionId === '{{ section.id }}') {
        update();
      }
    });
  })();
</script>

{% schema %}
{
