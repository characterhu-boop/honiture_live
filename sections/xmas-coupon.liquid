{%- comment -%} Xmas Coupon Section | 三个卡片的代金券分区 {%- endcomment -%}

<section id="xmas-coupon-{{ section.id }}" class="xmas-coupon">
  <div class="xmas-coupon__container">
        {% comment %} 这个模块有两个标题，这里改为使用block实现 {% endcomment %}
        {% for block in section.blocks %}
          {% if block.type == 'section-header-extra' %}
            {% render 'xmas-section-header', section: block %}
          {% endif %}
        {% endfor %}
    <div class="xmas-coupon__grid" style="--cards-per-row: {{ section.settings.cards_per_row | default: 3 }};">
      {%- for block in section.blocks -%}
      {% if block.type == 'coupon' %}
        <div class="coupon-card" {{ block.shopify_attributes }}
             style="
               {%- if block.settings.card_bg != blank -%}
                 --bg-desktop: url('{{ block.settings.card_bg | image_url: width: 1200 }}');
               {%- endif -%}
               {%- if block.settings.card_bg_mobile != blank -%}
                 --bg-mobile: url('{{ block.settings.card_bg_mobile | image_url: width: 900 }}');
               {%- endif -%}
             ">
          <div class="coupon-card__inner">
          {%- if block.settings.image_m != blank or block.settings.image != blank -%}
            <div class="coupon-card__image">
              <picture>
                {%- if block.settings.image_m != blank -%}
                  <source media="(max-width: 768px)" srcset="{{ block.settings.image_m | image_url: width: 900 }}">
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 1200 }}" alt="{{ block.settings.title | escape | default: 'Coupon image' }}" loading="lazy">
                {%- else -%}
                  <img src="{{ block.settings.image_m | image_url: width: 900 }}" alt="{{ block.settings.title | escape | default: 'Coupon image' }}" loading="lazy">
                {%- endif -%}
              </picture>
            </div>
          {%- endif -%}

          <div class="coupon-card__body">
            <div class="coupon-card__title">{{ block.settings.title | escape }}</div>
            <div class="coupon-card__sub">{{ block.settings.daily_text | default: 'Only 20 available per day' }}</div>

            <div class="coupon-card__prices">
              {%- if block.settings.sale_price != blank -%}
              <span class="price price--sale">{{ block.settings.sale_price }}</span>
              {%- endif -%}
              {%- if block.settings.original_price != blank -%}
              <span class="price price--original">{{ block.settings.original_price }}</span>
              {%- endif -%}
            </div>

            {% comment %} <div class="coupon-card__progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="100">
              <div class="coupon-progress__track">
                <div class="coupon-progress__fill"></div>
              </div>
              <div class="coupon-progress__hint">{{ '数量进度' | default: '' }}</div>
            </div> {% endcomment %}

            <!-- 移动端：进度条下方并排显示价格与按钮 -->
            <div class="coupon-card__cta">
              <div class="coupon-card__prices coupon-card__prices--mobile">
                {%- if block.settings.sale_price != blank -%}
                <span class="price price--sale">{{ block.settings.sale_price }}</span>
                {%- endif -%}
                {%- if block.settings.original_price != blank -%}
                <span class="price price--original">{{ block.settings.original_price }}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.buy_link != blank -%}
                <a class="coupon-card__btn" href="{{ block.settings.buy_link }}">
                  {{ block.settings.buy_label | default: 'Buy now' }}
                </a>
              {%- else -%}
                <button class="coupon-card__btn" type="button">
                  {{ block.settings.buy_label | default: 'Buy now' }}
                </button>
              {%- endif -%}
            </div>

            </div>
            </div>
        </div>
      {% endif %}
      {%- endfor -%}
    </div>


  {% comment %} 第二部分，两个coupon {% endcomment %}
  <div class="xmas-coupon-p2">
    {% if section.settings.p2_snow_image %}
      <div class="p2-snow">
        {{ section.settings.p2_snow_image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: section.settings.p2_snow_alt | default: 'Snow strip' }}
      </div>
    {% endif %}
    {% render 'xmas-section-header', section: section %}

    <div class="p2-coupons" aria-label="subscriber benefits coupons">
      <div class="p2-coupon">
        {% if section.settings.p2_left_image %}
          <button class="p2-coupon__img-btn" type="button" data-code="{{ section.settings.p2_left_code | escape }}" aria-label="Copy coupon code {{ section.settings.p2_left_code | escape }}">
            {{ section.settings.p2_left_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.p2_left_alt | default: 'Coupon image' }}
          </button>
        {% endif %}
      </div>

      <div class="p2-coupon">
        {% if section.settings.p2_right_image %}
          <button class="p2-coupon__img-btn" type="button" data-code="{{ section.settings.p2_right_code | escape }}" aria-label="Copy coupon code {{ section.settings.p2_right_code | escape }}">
            {{ section.settings.p2_right_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.p2_right_alt | default: 'Coupon image' }}
          </button>
        {% endif %}
      </div>
    </div>

    <div class="p2-cta">
      <div class="p2-cta__text">
        <div class="p2-cta__title">{{ section.settings.p2_cta_title }}</div>
        <div class="p2-cta__desc">{{ section.settings.p2_cta_desc }}</div>
      </div>
      <a class="p2-cta__btn" href="{{ section.settings.p2_cta_target }}">{{ section.settings.p2_cta_btn_label }}</a>
    </div>

    <div class="p2-toast" aria-live="polite" role="status"></div>
  </div>
</div>
</section>

