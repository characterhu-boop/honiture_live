        }
        #xmas-coupon-{{ section.id }} .coupon-card__inner { 
            display: flex;
            justify-content: center;
            align-items: center;
        }
        #xmas-coupon-{{ section.id }} .price--sale { font-size: 12px; }
        #xmas-coupon-{{ section.id }} .coupon-card__body { padding: 5px; }
    #xmas-coupon-{{ section.id }} .coupon-card__title { font-size: 12px; }
    #xmas-coupon-{{ section.id }} .coupon-card__sub { font-size: 10px; }
    #xmas-coupon-{{ section.id }} .coupon-card__prices { margin: 5px 0; }
