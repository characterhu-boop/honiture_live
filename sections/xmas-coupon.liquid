}
  #xmas-coupon-{{ section.id }} .coupon-card__btn:hover { background: #d4392e; }
  
.coupon-card__prices--mobile{
  display: none!important;
}
    #xmas-coupon-{{ section.id }} .coupon-card__cta { margin-top: 80px; }
