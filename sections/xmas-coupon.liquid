              margin: 0;
        width: auto;
        font-size: 10px;
        padding: 4px 10px;
        white-space: nowrap;
     }
  }
</style>

<script>
  (function(){
    function percentRemainingToday(){
      var now = new Date();
      var start = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      var end = new Date(now.getFullYear(), now.getMonth(), now.getDate()+1);
      var total = (end - start) / 1000; // seconds
      var elapsed = (now - start) / 1000;
      var remaining = Math.max(total - elapsed, 0);
      var percent = Math.round((remaining / total) * 100);
      return Math.max(0, Math.min(100, percent));
    }

    function updateProgress(){
      var container = document.querySelector('#xmas-coupon-{{ section.id }}');
      if(!container) return;
      var percent = percentRemainingToday();
      container.querySelectorAll('.coupon-progress__fill').forEach(function(el){
        el.style.width = percent + '%';
        var progress = el.closest('.coupon-card__progress');
        if(progress){ progress.setAttribute('aria-valuenow', String(percent)); }
      });
    }

    // 第二部分：复制折扣码与锚点跳转
    function showToast(msg){
      var toast = document.querySelector('#xmas-coupon-{{ section.id }} .p2-toast');
      if(!toast) return;
      toast.textContent = msg;
      toast.classList.add('is-visible');
      setTimeout(function(){ toast.classList.remove('is-visible'); }, 2000);
    }

    function copyCode(code){
      if(!code) return;
      if(navigator.clipboard && navigator.clipboard.writeText){
        navigator.clipboard.writeText(code).then(function(){ showToast('Coupon code copied: ' + code); });
      } else {
        var ta = document.createElement('textarea');
        ta.value = code; document.body.appendChild(ta); ta.select();
        try { document.execCommand('copy'); showToast('Coupon code copied: ' + code); } catch(e){}
        document.body.removeChild(ta);
      }
    }

    function bindCouponCopy(){
      document.querySelectorAll('#xmas-coupon-{{ section.id }} .p2-coupon__img-btn').forEach(function(btn){
        btn.addEventListener('click', function(){ copyCode(btn.getAttribute('data-code')); });
      });
    }

    function bindAnchorScroll(){
      var btn = document.querySelector('#xmas-coupon-{{ section.id }} .p2-cta__btn');
      if(!btn) return;
      btn.addEventListener('click', function(ev){
        var href = btn.getAttribute('href') || '';
        if(href.startsWith('#')){
          var target = document.querySelector(href);
          if(target){
            ev.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    }
    document.addEventListener('DOMContentLoaded', function(){
      updateProgress();
      // 每分钟刷新一次，体现“每天从100%减到0”的效果
      setInterval(updateProgress, 60000);
      // 绑定第二部分交互
      bindCouponCopy();
      bindAnchorScroll();
    });
  })();
</script>

