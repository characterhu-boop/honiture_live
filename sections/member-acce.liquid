<script>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var root = document.getElementById('member-acce-{{ section.id }}');
      if (!root) return;

      // Copy Code Functionality
      root.querySelectorAll('.btn-copy').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var code = btn.getAttribute('data-code');
          if (code) {
            navigator.clipboard.writeText(code).then(function() {
              var msg = btn.parentElement.querySelector('.copy-success-msg');
              if (msg) {
                msg.classList.add('show');
                setTimeout(function() { msg.classList.remove('show'); }, 2000);
              }
              btn.textContent = 'Copied';
              setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
            }).catch(function(err) {
              console.error('Failed to copy text: ', err);
            });
          }
        });
      });

      // 展开/收起更多配件
      var grid = root.querySelector('.acce__grid');
      var toggleBtn = root.querySelector('.acce-toggle__btn');
      var toggleLabel = toggleBtn ? toggleBtn.querySelector('.acce-toggle__label') : null;
      var toggleWrap = root.querySelector('.acce__toggle');
      var preExpandViewportOffset = null; // 记录展开前按钮相对视口的位置
      if (grid && toggleBtn && toggleWrap) {
        toggleBtn.addEventListener('click', function() {
          var isCollapsed = grid.classList.contains('is-collapsed');
          if (isCollapsed) {
            // 展开前记录按钮相对视口的偏移量（不依赖页面滚动绝对值）
            var rect = toggleWrap.getBoundingClientRect();
            preExpandViewportOffset = rect.top;
            grid.classList.remove('is-collapsed');
            if (toggleLabel) { toggleLabel.textContent = 'Show less'; }
            toggleBtn.setAttribute('aria-expanded', 'true');
            toggleWrap.classList.add('is-expanded');
          } else {
            grid.classList.add('is-collapsed');
            if (toggleLabel) { toggleLabel.textContent = 'Show more'; }
            toggleBtn.setAttribute('aria-expanded', 'false');
            toggleWrap.classList.remove('is-expanded');
            // 收起后平滑滚动，使按钮回到点击时的相同视口位�?
            if (preExpandViewportOffset !== null) {
              window.requestAnimationFrame(function() {
                var newRectTop = toggleWrap.getBoundingClientRect().top;
                var currentScroll = window.scrollY;
                var targetScroll = currentScroll + newRectTop - preExpandViewportOffset;
                window.scrollTo({ top: Math.max(targetScroll, 0), behavior: 'smooth' });
              });
            }
          }
        });
      }
    });
  })();
</script>

