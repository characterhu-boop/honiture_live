{% comment %}
  Xmas Accessories Year Section (Customized)
  - Title via snippet `xmas-section-header`
  - Banner with subtitle, no button
  - Product cards with:
    - Discount badge
    - Custom description
    - Discount code with copy function
{% endcomment %}


    <section id="member-acce-{{ section.id }}" class="member-acce">
    {% render 'xmas-section-header', section: section %}
    <div class="acce__container">
        {% if section.settings.snow_image %}
        <div class="spin-section-snow">
            {{ section.settings.snow_image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: 'Snow strip' }}
        </div>
        {% endif %}

        {% if section.settings.banner_bg != blank or section.settings.banner_bg_mobile != blank %}
        <div class="acce-banner">
            <div class="acce-banner__content">
            {% if section.settings.banner_richtext != blank %}
                <div class="acce-banner__text">{{ section.settings.banner_richtext }}</div>
            {% endif %}
            {% if section.settings.banner_subtitle != blank %}
                <div class="acce-banner__subtitle">{{ section.settings.banner_subtitle }}</div>
            {% endif %}
            </div>
            {% if section.settings.banner_bg_link_url != blank %}
              <a href="{{ section.settings.banner_bg_link_url }}" class="acce-banner__link" target="_blank" rel="noopener noreferrer">
                {{ section.settings.banner_bg_link_label | default: 'Learn More' }}
              </a>
            {% endif %}
        </div>
        {% endif %}

        {% assign acce_blocks = section.blocks | where: 'type', 'acce_product' %}
        {% assign acce_total = acce_blocks.size %}
        <div class="acce__grid{% if acce_total > 4 %} is-collapsed{% endif %}">
        {% for block in section.blocks %}
            {% if block.type == 'acce_product' %}
            {% assign prod = block.settings.product %}
            {% assign has_prod = prod.id %}
            {% if has_prod %}
                {% assign variant_id = block.settings.variant_id | default: prod.selected_or_first_available_variant.id %}
                {% assign variant = prod.variants | where: 'id', variant_id | first %}
                {% if variant == blank %}{% assign variant = prod.selected_or_first_available_variant %}{% endif %}
                {% assign price = variant.price %}
                {% assign compare = variant.compare_at_price %}
                {% assign extra_discount_percent = block.settings.extra_discount_percent | plus: 0 %}
                {% if extra_discount_percent > 100 %}
                  {% assign extra_discount_percent = 100 %}
                {% endif %}
                {% if extra_discount_percent > 0 %}
                  {% assign discount_multiplier = 100 | minus: extra_discount_percent %}
                  {% assign discounted_price_raw = price | times: discount_multiplier | divided_by: 100.0 %}
                  {% assign discounted_price = discounted_price_raw | ceil %}
                  {% if discounted_price < price %}
                    {% if compare == blank or compare <= price %}
                      {% assign compare = price %}
                    {% endif %}
                    {% assign price = discounted_price %}
                  {% endif %}
                {% endif %}
                {% assign img = block.settings.image | default: prod.featured_image %}
                {% assign title = block.settings.title | default: prod.title %}
                {% assign gift_product = block.settings.gift_product %}
                {% assign gift_title = block.settings.gift_product_title | default: gift_product.title %}
                {% assign gift_image = block.settings.gift_product_image | default: gift_product.featured_image %}
                {% assign gift_image_mobile = block.settings.gift_product_image_mobile | default: gift_image %}
                {% assign gift_compare_text = block.settings.gift_compare_price %}
                {% if gift_compare_text == blank and gift_product != blank %}
                  {% assign gift_compare_text = gift_product.price | money %}
                {% endif %}
                {% assign gift_heading = block.settings.gift_heading %}
                {% if gift_heading == blank %}
                  {% capture gift_heading %}Gifts for {{ title | strip_html }}{% endcapture %}
                {% endif %}
                {% assign show_gift_product = false %}
                {% if gift_product != blank or gift_title != blank or gift_image != blank %}
                  {% assign show_gift_product = true %}
                {% endif %}
                {% assign block_discount_code = block.settings.discount_code %}
                {% assign code_label = block.settings.code_label | default: section.settings.code_label %}
                {% assign discount_code = block.settings.discount_code | default: section.settings.discount_code %}
                {% assign show_discount_code = false %}
                {% if block_discount_code != blank or section.settings.show_discount_code %}
                  {% assign show_discount_code = true %}
                {% endif %}

                <div
                  class="acce-card"
                  style="
                    --discount-code-bg: {{ block.settings.discount_code_bg_gradient | default: 'linear-gradient(90deg, #FFA63A 0%, #FF9432 100%)' }};
                    --discount-code-color: {{ block.settings.discount_code_text_color | default: '#FFFFFF' }};
                    --discount-code-btn-bg: {{ block.settings.discount_code_button_bg | default: '#FFFFFF' }};
                    --discount-code-btn-color: {{ block.settings.discount_code_button_text_color | default: '#111111' }};
                  "
                  {{ block.shopify_attributes }}
                >
                <div class="acce-card__media">
                    {% render 'common-badge',
                      show: section.settings.show_discount_badge,
                      product: prod,
                      sale_price: price,
                      compare_price: compare,
                      text: block.settings.discount_badge_percent | default: section.settings.discount_badge_percent,
                      off_text: section.settings.discount_badge_off_text,
                      split: section.settings.discount_badge_text_split,
                      background: section.settings.discount_badge_bg,
                      color: section.settings.discount_badge_color,
                      background_image: section.settings.discount_badge_bg_image,
                      width: section.settings.discount_badge_width,
                      height: section.settings.discount_badge_height,
                      width_mobile: section.settings.discount_badge_width_mobile,
                      height_mobile: section.settings.discount_badge_height_mobile,
                      top: section.settings.discount_badge_top,
                      left: section.settings.discount_badge_left,
                      text_top: section.settings.discount_badge_text_top,
                      text_left: section.settings.discount_badge_text_left
                    %}
                    {% if img %}
                    <a href="{{ prod.url }}" target="_blank" class="acce-card__link">
                    <img src="{{ img | image_url: width: 600 }}" alt="{{ title | escape }}" loading="lazy" />
                    </a>{% endif %}
                </div>
                <div class="acce-card__content">
                  {% if block.settings.gift_image != blank %}
                    <div class="acce-card__gift">
                      {{ block.settings.gift_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: title }}
                    </div>
                  {% endif %}
                  {% if show_gift_product %}
                    <div
                      class="acce-card__gift-product"
                      style="
                        --gift-product-width: {{ block.settings.gift_product_width | default: 330 }};
                        --gift-product-width-mobile: {{ block.settings.gift_product_width_mobile | default: 280 }};
                        --gift-product-image-width: {{ block.settings.gift_product_image_width | default: 96 }};
                        --gift-product-image-width-mobile: {{ block.settings.gift_product_image_width_mobile | default: 74 }};
                        --gift-product-icon-width: {{ block.settings.gift_corner_icon_width | default: 76 }};
                        --gift-product-icon-width-mobile: {{ block.settings.gift_corner_icon_width_mobile | default: 58 }};
                        --gift-product-icon-top: {{ block.settings.gift_corner_icon_top | default: -20 }};
                        --gift-product-icon-left: {{ block.settings.gift_corner_icon_left | default: -18 }};
                        --gift-product-icon-top-mobile: {{ block.settings.gift_corner_icon_top_mobile | default: -16 }};
                        --gift-product-icon-left-mobile: {{ block.settings.gift_corner_icon_left_mobile | default: -12 }};
                        --gift-product-border: {{ block.settings.gift_border_color | default: '#418EFF' }};
                        --gift-product-heading-bg: {{ block.settings.gift_heading_bg | default: '#418EFF' }};
                        --gift-product-heading-color: {{ block.settings.gift_heading_color | default: '#FFFFFF' }};
                        --gift-product-free-color: {{ block.settings.gift_free_color | default: '#00C7C9' }};
                      "
                    >
                      {% if block.settings.gift_corner_icon != blank or block.settings.gift_corner_icon_mobile != blank %}
                        {% assign gift_corner_icon = block.settings.gift_corner_icon | default: block.settings.gift_corner_icon_mobile %}
                        {% assign gift_corner_icon_mobile = block.settings.gift_corner_icon_mobile | default: gift_corner_icon %}
                        <picture class="acce-card__gift-product-icon">
                          {% if gift_corner_icon_mobile != blank %}
                            <source media="(max-width: 849px)" srcset="{{ gift_corner_icon_mobile | image_url: width: 200 }}">
                          {% endif %}
                          {{ gift_corner_icon | image_url: width: 240 | image_tag: loading: 'lazy', alt: '' }}
                        </picture>
                      {% endif %}
                      <div class="acce-card__gift-product-inner">
                        <div class="acce-card__gift-product-heading">{{ gift_heading | escape }}</div>
                        <div class="acce-card__gift-product-body">
                          <a class="acce-card__gift-product-media" href="{{ gift_product.url | default: prod.url }}" target="_blank" rel="noopener">
                            {% if gift_image != blank %}
                              <picture>
                                {% if gift_image_mobile != blank %}
                                  <source media="(max-width: 849px)" srcset="{{ gift_image_mobile | image_url: width: 300 }}">
                                {% endif %}
                                {{ gift_image | image_url: width: 360 | image_tag: loading: 'lazy', alt: gift_title }}
                              </picture>
                            {% endif %}
                          </a>
                          <div class="acce-card__gift-product-info">
                            {% if gift_title != blank %}
                              <a class="acce-card__gift-product-title" href="{{ gift_product.url | default: prod.url }}" target="_blank" rel="noopener">{{ gift_title | escape }}</a>
                            {% endif %}
                            <div class="acce-card__gift-product-price">
                              <span>{{ block.settings.gift_free_label | default: 'FREE' | escape }}</span>
                              {% if gift_compare_text != blank %}
                                <s>{{ gift_compare_text | escape }}</s>
                              {% endif %}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  {% endif %}
                  {% if show_discount_code and discount_code != blank %}
                    {% render 'xmas-copy-code', section: section, code_label: code_label, discount_code: discount_code %}
                  {% endif %}
                    <div class="acce-card__title">{{ title }}</div>

                    {% if block.settings.custom_description != blank %}
                    <div class="acce-card__desc">
                        {{ block.settings.custom_description }}
                    </div>
                    {% endif %}

                    {% comment %} {% if block.settings.discount_code != blank %}
                    <div class="acce-card__code-box">
                        <span class="code-label">Code: <strong>{{ block.settings.discount_code }}</strong></span>
                        <button type="button" class="btn-copy" data-code="{{ block.settings.discount_code }}">Copy</button>
                        <span class="copy-success-msg">Copied!</span>
                    </div>
                    {% endif %} {% endcomment %}

                    {% if block.settings.footer_custom_description != blank %}
                    <div
                      class="acce-card__footer-desc rte"
                      style="
                        --footer-desc-color: {{ block.settings.footer_custom_description_color | default: '#000000' }};
                        --footer-desc-size: {{ block.settings.footer_custom_description_size | default: 14 }};
                        --footer-desc-line-height: {{ block.settings.footer_custom_description_line_height | default: 18 }};
                        --footer-desc-size-mobile: {{ block.settings.footer_custom_description_size_mobile | default: 12 }};
                        --footer-desc-line-height-mobile: {{ block.settings.footer_custom_description_line_height_mobile | default: 16 }};
                      "
                    >
                      {{ block.settings.footer_custom_description }}
                    </div>
                    {% endif %}

                    <div class="member-acce-card-footer">
                      <div class="acce-card__price">
                      {{ price | money }}
                      {% if compare %}<span class="acce-card__compare">{{ compare | money }}</span>{% endif %}
                      </div>

                      <div class="acce-card__actions">
                      <a href="{{ prod.url }}" class="acce-card__btn--shop" target="_blank">Shop now</a>
                      </div>
                    </div>
                    {% capture installment_form_id %}member-acce-installment-{{ section.id }}-{{ block.id }}{% endcapture %}
                    {%- form 'product', prod, id: installment_form_id, class: 'acce-card__custom-label acce-card__installments' -%}
                      <input type="hidden" name="id" value="{{ variant.id }}">
                      {{ form | payment_terms }}
                    {%- endform -%}
                    {% if block.settings.show_compact_label and block.settings.compact_label != blank %}
                      <div
                        class="acce-card__custom-cumpact"
                        style="
                          --compact-bg: {{ block.settings.compact_label_bg | default: '#4094F7' }};
                          --compact-color: {{ block.settings.compact_label_color | default: '#A8F5E8' }};
                          --compact-height: {{ block.settings.compact_label_height | default: 46 }};
                          --compact-height-mobile: {{ block.settings.compact_label_height_mobile | default: 34 }};
                          --compact-radius: {{ block.settings.compact_label_radius | default: 12 }};
                          --compact-radius-mobile: {{ block.settings.compact_label_radius_mobile | default: 10 }};
                          --compact-font-size: {{ block.settings.compact_label_size | default: 20 }};
                          --compact-font-size-mobile: {{ block.settings.compact_label_size_mobile | default: 13 }};
                          --compact-margin-top: {{ block.settings.compact_label_margin_top | default: 10 }};
                          --compact-margin-top-mobile: {{ block.settings.compact_label_margin_top_mobile | default: 8 }};
                        "
                      >
                        {% if block.settings.compact_label_link != blank %}
                          <a href="{{ block.settings.compact_label_link }}" target="_blank" rel="noopener">
                            {{ block.settings.compact_label | escape }}
                          </a>
                        {% else %}
                          <span>{{ block.settings.compact_label | escape }}</span>
                        {% endif %}
                      </div>
                    {% endif %}
                </div>
                </div>
            {% endif %}
            {% endif %}
        {% endfor %}
        </div>

        {% if acce_total > 4 %}
        <div class="acce__toggle">
            <button type="button" class="acce-toggle__btn" aria-expanded="false">
            <span class="acce-toggle__label">Show more</span>
            <!-- 向下箭头（折叠态） -->
            <svg class="arrow arrow--down" viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.41 8.59 12 13.17l4.59-4.58L18 10l-6 6-6-6z" fill="currentColor"/>
            </svg>
            <!-- 向上箭头（展开态） -->
            <svg class="arrow arrow--up" viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.41 15.41 12 10.83l4.59 4.58L18 14l-6-6-6 6z" fill="currentColor"/>
            </svg>
            </button>
        </div>
        {% endif %}
    </div>

    <div class="acce__toast" role="status" aria-live="polite"></div>
    </section>
{% render 'section-decorations', section: section %}
<style>
  .member-acce {
    --vp-s: 1px;
    --shop-btn-bg: {{ section.settings.shop_button_bg_gradient | default: 'linear-gradient(90deg, #FF84A2 0%, #FF6F95 100%)' }};
    --common-badge-top-mobile: {{ section.settings.discount_badge_top_mobile | default: section.settings.discount_badge_top | default: 0 }};
    --common-badge-left-mobile: {{ section.settings.discount_badge_left_mobile | default: section.settings.discount_badge_left | default: 10 }};
    --common-badge-text-top-mobile: {{ section.settings.discount_badge_text_top_mobile | default: section.settings.discount_badge_text_top | default: 0 }};
    --common-badge-text-left-mobile: {{ section.settings.discount_badge_text_left_mobile | default: section.settings.discount_badge_text_left | default: 0 }};
    background: {{ section.settings.background_color | default: 'transparent' }};
    padding: calc({{ section.settings.padding_top | default: 24 }} * var(--vp-s)) 0 calc({{ section.settings.padding_bottom | default: 24 }} * var(--vp-s));
  }

  @media screen and (min-width: 850px) and (max-width: 1500px) {
    .member-acce {
      --vp-s: calc(100vw / 1500);
    }
  }

  @media screen and (max-width: 849px) {
    .member-acce {
      --vp-s: calc(100vw / 375);
    }
  }


  .member-acce .xmax_section__header.sh-{{ section.id }} {
    margin-bottom: calc({{ section.settings.header_margin_bottom | default: 50 }} * var(--vp-s));
  }
  .member-acce .xmax_section__title {
    font-size: calc({{ section.settings.title_size | default: 36 }} * var(--vp-s));
  }
  .member-acce .xmas-sub-heading {
    font-size: calc({{ section.settings.sub_heading_size | default: 18 }} * var(--vp-s));
  }

  .member-acce .acce__container {
    max-width: calc({{ section.settings.content_max_width | default: 1300 }} * var(--vp-s));
    margin: 0 auto;
    border-radius: calc(30 * var(--vp-s)) calc(30 * var(--vp-s)) calc(10 * var(--vp-s)) calc(10 * var(--vp-s));
    position: relative;
  }
  .member-acce .spin-section-snow {
    position: absolute;
    top: calc(-20 * var(--vp-s));
    left: 0;
  }
  .member-acce .acce-card__custom-label {
    margin-top: calc(10 * var(--vp-s));
    margin-bottom: 0;
    padding: 0;
    font-size: calc(14 * var(--vp-s));
    line-height: calc(24 * var(--vp-s));
    font-weight: 400;
    color: #555555;
  }
  .member-acce .acce-card__custom-label shopify-payment-terms {
    display: block;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }
  .member-acce .acce-card__custom-cumpact {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--compact-height, 46) * var(--vp-s));
    margin-top: calc(var(--compact-margin-top, 10) * var(--vp-s));
    padding: calc(6 * var(--vp-s)) calc(16 * var(--vp-s));
    border-radius: 0 0 calc(var(--compact-radius, 12) * var(--vp-s)) calc(var(--compact-radius, 12) * var(--vp-s));
    background: var(--compact-bg, #4094F7);
    color: var(--compact-color, #A8F5E8);
    font-size: calc(var(--compact-font-size, 20) * var(--vp-s));
    line-height: calc(24 * var(--vp-s));
    font-weight: 400;
    text-align: center;
  }
  .member-acce .acce-card__custom-cumpact a,
  .member-acce .acce-card__custom-cumpact span {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: calc(3 * var(--vp-s));
  }
  .member-acce .acce-banner {
    position: relative;
    background-size: 100%;
    background-position: center;
    background-repeat: no-repeat;
    border-radius: calc(12 * var(--vp-s));
    min-height: calc(160 * var(--vp-s));
    display: flex;
    align-items: center;
    padding: calc(42 * var(--vp-s));
    margin-bottom: calc(18 * var(--vp-s));
    height: calc({{ section.settings.banner_height | default: 460 }} * var(--vp-s));
  }
  #member-acce-{{ section.id }} .acce-banner {
    background-image: url({{ section.settings.banner_bg | default: section.settings.banner_bg_mobile | image_url: width: 1600 }});
  }
  .member-acce .acce-banner__content {
    max-width: calc(700 * var(--vp-s));
    color: #fff;
  }
  .member-acce .acce-banner__text {
    margin-bottom: calc(10 * var(--vp-s));
    color: {{ section.settings.banner_text_color | default: '#333333' }};
  }
  .member-acce .acce-banner__text strong { color: {{ section.settings.banner_text_color | default: '#333333' }}; }
  .member-acce .acce-banner__text p {
    margin-bottom: 0;
    color: {{ section.settings.banner_text_color | default: '#333333' }};
    font-size: calc(36 * var(--vp-s));
    line-height: calc(44 * var(--vp-s));
    font-weight: 700;
  }
  .member-acce .acce-banner__subtitle {
    font-size: calc(24 * var(--vp-s));
    line-height: calc(32 * var(--vp-s));
    color: {{ section.settings.banner_subtitle_color | default: '#333333' }};
    margin-top: calc(5 * var(--vp-s));
  }
  .member-acce .acce-banner__link {
    position: absolute;
    right: calc(24 * var(--vp-s));
    bottom: calc(24 * var(--vp-s));
    display: inline-block;
    background: linear-gradient(90deg, #4DE0E6 0%, #76E8E6 100%);
    color: #fff;
    border-radius: calc(20 * var(--vp-s));
    padding: calc(8 * var(--vp-s)) calc(20 * var(--vp-s));
    font-size: calc(14 * var(--vp-s));
    font-weight: 600;
    text-decoration: none;
  }
  .member-acce .acce-banner__link:hover { opacity: 0.9; }

  .member-acce .acce__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: calc(16 * var(--vp-s));
    padding-top: calc(10 * var(--vp-s));
  }
  .member-acce .acce__grid.is-collapsed .acce-card:nth-child(n+5) { display: none; }
  .member-acce .acce__toggle {
    display: flex;
    justify-content: center;
    margin-top: calc(14 * var(--vp-s));
  }
  .member-acce .acce-toggle__btn {
    cursor: pointer;
    border: calc(1 * var(--vp-s)) solid #fff;
    background: transparent;
    color: #fff;
    border-radius: calc(999 * var(--vp-s));
    padding: calc(8 * var(--vp-s)) calc(16 * var(--vp-s));
    font-size: calc(14 * var(--vp-s));
    display: inline-flex;
    align-items: center;
    gap: calc(8 * var(--vp-s));
  }
  .member-acce .acce-toggle__btn:hover { background: rgba(255,255,255,0.12); }
  .member-acce .acce-toggle__btn .arrow {
    width: calc(16 * var(--vp-s));
    height: calc(16 * var(--vp-s));
    color: #fff;
  }
  .member-acce .acce__toggle .arrow--up { display: none; }
  .member-acce .acce__toggle.is-expanded .arrow--up { display: inline; }
  .member-acce .acce__toggle.is-expanded .arrow--down { display: none; }

  .member-acce .acce-card {
    background: #fff;
    border-radius: calc(10 * var(--vp-s));
    box-shadow: 0 calc(1 * var(--vp-s)) calc(6 * var(--vp-s)) rgba(0,0,0,0.08);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-align: left;
    position: relative;
  }
  .member-acce .acce-card__media {
    padding: calc(10 * var(--vp-s));
    position: relative;
    text-align: center;
  }
  .member-acce .acce-card__media img {
    width: 100%;
    height: auto;
    display: block;
    margin: 0 auto;
  }
  .member-acce .acce-card__content {
    padding: calc(12 * var(--vp-s)) calc(16 * var(--vp-s)) calc(20 * var(--vp-s));
    text-align: left;
  }
  .member-acce .acce-card__gift {
    margin-bottom: calc(10 * var(--vp-s));
    text-align: center;
  }
  .member-acce .acce-card__gift img {
    display: block;
    width: 100%;
    max-width: none;
    height: auto;
    margin: 0 auto;
  }
  .member-acce .acce-card__title {
    font-size: calc({{ section.settings.product_title_size | default: 14 }} * var(--vp-s));
    font-weight: 600;
    margin-bottom: calc(4 * var(--vp-s));
    color: {{ section.settings.product_title_color | default: '#000' }};
  }
  .member-acce .acce-card__desc {
    font-size: calc(18 * var(--vp-s));
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: calc(10 * var(--vp-s));
    color: #000;
  }
  .member-acce .acce-card__footer-desc {
