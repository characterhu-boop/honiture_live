{{- 'media-grid.css' | asset_url | stylesheet_tag -}}
{%- liquid
  assign desktop_height = section.settings.desktop_height
  assign mobile_height = section.settings.mobile_height
  assign column_spacing = section.settings.column_spacing
  assign mobile_swipe = section.settings.mobile_swipe

  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing
-%}
<div class="media-grid section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}">
  <div
    class="media-grid--inner column-spacing--{{ column_spacing }}{% if mobile_swipe %} swipe-on-mobile{% endif %}"
    style="--desktop-height:{{ desktop_height | append: 'px' }}; --mobile-height:{{ mobile_height | append: 'px' }}"
  >
    {%- for block in section.blocks -%}
      {%- liquid
        assign image = block.settings.image
        assign slide_link = block.settings.slide_link
        assign use_video = block.settings.use_video
        assign video_hosted = block.settings.video_hosted
        assign heading_size = block.settings.heading_size
        assign content_position = block.settings.content_position
        assign text_alignment = block.settings.text_alignment
        assign color_bg = block.settings.color_bg
        assign color_bg_gradient = block.settings.color_bg_gradient
        assign color_text = block.settings.color_text
        assign color_link = block.settings.color_link
        assign overlay_color = block.settings.overlay_color
        assign overlay_opacity = block.settings.overlay_opacity
        assign column = block.settings.column
        assign row = block.settings.row
        assign column_mobile = column
        if column > 2
          assign column_mobile = 2
        endif
      -%}
      <div
        class="media-grid--item media-grid--item index-{{ forloop.index }} content-{{ content_position }} has-link--{% if slide_link != blank %}true{% endif %}"
        style="
          --column-span: {{ column }};
          --row-span: {{ row }};
          --column-span--mobile: {{ column_mobile }};
          --color-bg: {{ color_bg }};
          {% if color_bg_gradient != blank -%}--color-bg-gradient: {{ color_bg_gradient }};{%- endif -%}
          --color-text: {{ color_text }};
          --color-accent: {{ color_link }};
          --overlay-color-rgb: {{ overlay_color.rgb | replace: ' ', ',' }};
          --overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }};
          --heading-font-size: {{ block.settings.heading_font_size | append: 'rem' }};
          --heading-color: {{ block.settings.heading_color }};
          --subheading-font-size: {{ block.settings.subheading_font_size | append: 'rem' }};
          --subheading-color: {{ block.settings.subheading_color }};
          --link-font-size: {{ block.settings.link_font_size | append: 'rem' }};
          --link-color: {{ block.settings.link_color }};
          --link-top: {{ block.settings.link_top | append: '%' }};
          --link-left: {{ block.settings.link_left | append: '%' }};
          --link-width: {{ block.settings.link_width | append: '%' }};
          --link-height: {{ block.settings.link_height | append: '%' }}
        "
        {{ block.shopify_attributes }}
      >
        <div class="media-grid--bg">
          {%- if use_video -%}
            {%- if video_hosted != blank -%}
              {{
                video_hosted
                | video_tag: autoplay: true, loop: true, controls: false, muted: true, image_size: '1280x'
              }}
            {%- endif -%}
            {% if block.settings.video_controls %}
              <div class="grid-video__controls">
                <button id="VideoPlayToggle-{{ section.id }}-{{ forloop.index }}" type="button">
                  <span class="grid-video__controls-play">{% render 'svg-icons' with 'thb-video-play' %}</span>
                  <span class="grid-video__controls-pause">{% render 'svg-icons' with 'thb-video-pause' %}</span>
                </button>
              </div>
            {% endif %}
          {%- elsif image != blank -%}
            {%- liquid
              render 'responsive-image', image: image, sizes: '345x,610x,1280x'
            -%}
          {%- endif -%}
        </div>
        <div
          class="media-grid--content text-{{ text_alignment }}"
          style="width: {{ block.settings.content_width | append: '%' }};margin-left: {{ block.settings.content_m_left | append: 'px' }};"
        >
          {% if block.settings.heading != blank %}
            <h4 class="{{ heading_size }}{% if block.settings.button_text == blank %} media-grid--heading-no-margin{% endif %}">
              {{ block.settings.heading | newline_to_br }}
            </h4>
          {% endif %}
          {% if block.settings.subheading != blank %}
            <p class="subheading">{{ block.settings.subheading }}</p>
          {% endif %}
          {% if block.settings.button_text != blank %}
            {% render 'text-button',
              url: block.settings.button_link,
              title: block.settings.button_text,
              class: 'always-show-button'
            %}
          {% endif %}
          {% if slide_link != blank and slide_link != '' %}
            <a
              href="{{ slide_link }}"
              class="media-grid--link"
              tabindex="-1"
              aria-label="{% if block.settings.heading != blank %}{{ block.settings.heading | escape }}{% endif %}"
            ></a>
          {% endif %}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', () => {
        const button = document.querySelector(".media-grid--item.index-3");
        const video = document.querySelector('.media-grid--bg video');
        if (!video) return;

        const playIcon = document.querySelector('.media-grid--bg .grid-video__controls-play');
        const pauseIcon = document.querySelector('.media-grid--bg .grid-video__controls-pause');

        function updateButtonState() {
          console.log(video.paused,999)
          if (video.paused) {
            playIcon.style.display = 'inline-block';
            pauseIcon.style.display = 'none';
          } else {
            playIcon.style.display = 'none';
            pauseIcon.style.display = 'inline-block';
          }
        }
        const isListened = button.getAttribute('listened')
        if(button&&!isListened){
          button.setAttribute('listened', true)
          button.addEventListener('click', function () {
            console.log('clicked')
            if (video.paused) {
              video.play();
            } else {
              video.pause();
            }
            updateButtonState();
          });
        }

        // 初始化状态
        // updateButtonState();

        // 监听视频状态变化（例如自动播放结束）
        // video.addEventListener('play', updateButtonState);
        // video.addEventListener('pause', updateButtonState);
      });
</script>
<style>
  .grid-video__controls{
    position: absolute;
    bottom: 20px;
    right: 20px;
    z-index: 40;
    cursor: pointer;
  }
  .grid-video__controls button {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    line-height: 0;
    background: var(--color-drawer-bg, #fff);
  }
     .grid-video__controls-pause {
        display: block; }
       .grid-video__controls-play {
        display: none; }
</style>

{% schema %}
  {
  "name": "Media grid",
  "class": "section-media-grid",
  "settings": [
    {
      "type": "range",
      "id": "desktop_height",
      "min": 200,
      "max": 400,
      "step": 5,
      "default": 300,
      "label": "Desktop row height"
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 100,
      "max": 600,
      "step": 5,
      "default": 250,
      "label": "Mobile row height"
    },
    {
      "type": "select",
      "id": "column_spacing",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium",
      "label": "Column spacing"
    },
    {
      "type": "checkbox",
      "id": "mobile_swipe",
      "default": true,
      "label": "Enable swipe on mobile"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_top_spacing",
      "default": false,
      "label": "Remove top spacing"
    },
    {
      "type": "checkbox",
      "id": "disable_bottom_spacing",
      "default": false,
      "label": "Remove bottom spacing"
    }
  ],
  "blocks": [
    {
      "type": "media",
      "name": "Media",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "1250 x 1250 .jpg recommended."
        },
        {
          "id": "slide_link",
          "type": "url",
          "label": "Block link",
          "info": "Adds a link to block"
        },
        {
          "type": "header",
          "content": "Customization for h4, Subheading, and Link"
        },
        {
          "type": "range",
          "id": "heading_font_size",
          "min": 1,
          "max": 3,
          "step": 0.1,
          "unit": "rem",
          "default": 1.5,
          "label": "Heading font size"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading font color",
          "default": "#2c2d2e"
        },
        {
          "type": "range",
          "id": "subheading_font_size",
          "min": 0.8,
          "max": 2,
          "step": 0.1,
          "unit": "rem",
          "default": 1,
          "label": "Subheading font size"
        },
        {
          "type": "color",
          "id": "subheading_color",
          "label": "Subheading font color",
          "default": "#2c2d2e"
        },
        {
          "type": "range",
          "id": "link_font_size",
          "min": 0.8,
          "max": 2,
          "step": 0.1,
          "unit": "rem",
          "default": 1,
          "label": "Link font size"
        },
        {
          "type": "color",
          "id": "link_color",
          "label": "Link font color",
          "default": "#3F72E5"
        },
        {
          "type": "range",
          "id": "link_top",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0,
          "label": "Link top position"
        },
        {
          "type": "range",
          "id": "link_left",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 0,
          "label": "Link left position"
        },
        {
          "type": "range",
          "id": "link_width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100,
          "label": "Link width"
        },
        {
          "type": "range",
          "id": "link_height",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100,
          "label": "Link height"
        },
        {
          "type": "checkbox",
          "id": "use_video",
          "default": false,
          "label": "Use video instead of image"
        },
        {
          "type": "video",
          "id": "video_hosted",
          "label": "Shopify-hosted video"
        },
        {
          "type": "checkbox",
          "id": "video_controls",
          "label": "Display video controls",
          "default": true
        },
        {
          "type": "range",
          "id": "column",
          "min": 1,
          "max": 4,
          "step": 0.1,
          "default": 1,
          "label": "Column"
        },
        {
          "type": "range",
          "id": "row",
          "min": 1,
          "max": 4,
          "step": 0.1,
