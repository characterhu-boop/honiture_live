        {
          "type": "range",
          "id": "content_width",
          "min": 10,
          "max": 100,
          "step": 1,
          "default": 100,
          "label": "Content width"
        },
                {
          "type": "range",
          "id": "content_m_left",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 0,
          "label": "Content margin to left"
        },
        {
          "type": "color",
          "id": "color_bg",
          "label": "Background",
          "default": "#ffffff"
        },
        {
          "type": "color_background",
          "id": "color_bg_gradient",
          "label": "Background gradient"
        },
        {
          "type": "color",
          "id": "color_text",
          "label": "Text",
          "default": "#2c2d2e"
        },
        {
          "type": "color",
          "id": "color_link",
          "label": "Link",
          "default": "#3F72E5"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Overlay opacity",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Media grid",
      "blocks": [
        { "type": "media" },
        { "type": "media" },
        { "type": "media" }
      ]
    }
  ],
  "enabled_on": {
    "templates": ["*"],
    "groups": ["header", "footer"]
  }
}
