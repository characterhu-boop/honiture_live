
<style>
  .section-{{ section.id }}.flip-win .xmax_section__header{
  margin-bottom: 100px;
}

  .section-{{ section.id }}.flip-win .xmax_section__title{
    text-align: center; 
    line-height: 1.4;
    font-size: 36px;
  }
  .spin-section-snow{
    position: absolute;
    top: -20px;
    left: 0;
  }
  .section-{{ section.id }} {
    /* background: #f9f6ec; */
    padding: 0 0 60px 0;
    background-image: {% if section.settings.bg_image != blank %}url('{{ section.settings.bg_image | image_url: width: 1920 }}'){% endif %};
    background-size: 1500px;
    background-position: bottom;
    background-repeat: no-repeat;
    position: relative;
  }


  .section-{{ section.id }} .section-header{
    text-align: center;
  }
  
  .section-{{ section.id }} .section-header .section-header-title{
    width: max-content;
    margin: 0 auto;
    font-size: 56px;
    position: relative;
    text-shadow: 1px 0 0 rgba(255, 255, 255, 0.521), -1px 0 0 rgba(255, 255, 255, 0.432), 0 1px 0 rgba(255, 255, 255, 0.418), 0 -1px 0 rgba(255, 255, 255, 0.473), 0 0 30px #FF3333, 0 0 40px #FF3333, 0 0 50px #FF6666;
  }
  
  .section-{{ section.id }} .section-header .section-header-title::before,
  .section-{{ section.id }} .section-header .section-header-title::after {
    content: '';
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    background-image: url({{ 'spin-icon.png' | asset_url }});
    background-size: cover;
    background-repeat: no-repeat;
    width: 88px;
    height: 88px;
  }

  .section-{{ section.id }}.flip-win .spin-eligibility_text{
    color: #000;
    margin-top: 30px;
    transform: translate(24px, 30px);
    max-width: 400px; 
  }
  .section-{{ section.id }} .content-wrapper{
    display: flex;
    flex-direction: column;
    max-width: 768px;
    margin: 30px auto;
    /* background: #06503F; */
    border-radius: 30px 30px 10px 10px;
    position: relative;
    padding-bottom: 122px;
  }  
  .section-{{ section.id }} .content-right{
    z-index: 1;
    width: 100%;
    color: {{ section.settings.fontColor }};
  }
  .section-{{ section.id }} .spin-desc{
    font-size: 16px;
    line-height: 1.8;
    margin-top: 30px;
    display: block;
  }
  .section-{{ section.id }} .mobile-only{
    display: none;
  }
  .section-{{ section.id }} .pc-only{
    display: block;
  }
  /* 表单样式*/ 
  .section-{{ section.id }} .form-container {
    text-align: left;
  }
  
  .section-{{ section.id }} .form-container label{
    font-size: 16px;
  }
  
  .section-{{ section.id }} .form-container input[type="text"], 
  .section-{{ section.id }} .form-container input[type="email"] {
    width: 100%;
    padding: 10px;
    margin: 10px 0;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 16px;
    outline: none;
    transition: 0.3s;
  }
  
  .section-{{ section.id }} .btn-wrap{
    width: 100%;
    text-align: center;
    margin: 30px 0;
  }
  
  .section-{{ section.id }} .form-container button {
    background: linear-gradient(45deg, #7c5f34, #e8d8c1);
    color: white;
    padding: 8px 26px;
    border: none;
    border-radius: 99px;
    cursor: pointer;
    font-size: 20px;
    transition: 0.3s;
  }
  
  .section-{{ section.id }} .form-container button:hover {
    background: linear-gradient(45deg,rgb(99, 76, 41),rgb(219, 187, 143));
  }
  
  .section-{{ section.id }} #spin-tip{
    color: #FF0000;
    font-size: 20px;
    display: block;
    width: 100%;
    height: 30px;
    text-align: center;
    transition: 0.3s;
  }
  .section-{{ section.id }}.flip-win{
    /* background: #ae3028; */
        transform: scale(0.85);
  } 
  /* 移动端适配 */
  @media screen and (max-width: 1024px) {
    .section-{{ section.id }} {
      padding-top: 60px;
      padding-bottom: 15vw;
    }

    .section-{{ section.id }} .content-wrapper {
      margin: 60px auto;
    }
    

  @media screen and (max-width: 768px) {
      .section-{{ section.id }}.flip-win{
    /* background: #ae3028; */
        transform: scale(1);
  } 
        .section-{{ section.id }} {
      padding-top: 0;
    }
      .section-{{ section.id }}.flip-win .xmax_section__header{
        margin-bottom: 50px;
      }
      .section-{{ section.id }}.flip-win .spin-eligibility_text{
        color: #000;
        margin-top: 10px;
        transform: unset;
        font-size: 10px;
      }
      .section-{{ section.id }}.flip-win .spin-eligibility_text p{
        margin-bottom: 0;
        line-height: 1.2;
      }
      .section-{{ section.id }} .content-wrapper{
        padding-bottom: 10px;
      }  

      .section-{{ section.id }}.flip-win .xmax_section__title{
        font-size: 24px;
      }
      .flip-win .subscribe-box input[type="email"],.flip-win .signup-container label{
        height: 30px!important;
      }
      .section-{{ section.id }} {
        background-image: none;
      }
    .section-{{ section.id }}  .content-wrapper{
      padding-top: 0;
      padding-bottom: 20px;
      background-image: none;
      position: relative;
    }
    .section-{{ section.id }}  .content-wrapper::before{
      content: '';
      position: absolute;
      top: -10vw;
      left: 50%;
      transform: translateX(-50%);
      width: 100vw;
      height: 100vh;
      background-size: contain;
      background-repeat: no-repeat;
      background-position: top center;
      background-image: {% if section.settings.bg_image_mobile != blank %}
        url('{{ section.settings.bg_image_mobile | image_url: width: 1080 }}')
      {% elsif section.settings.bg_image != blank %}
        url('{{ section.settings.bg_image | image_url: width: 1080 }}')
      {% endif %};
      z-index: 0;
      pointer-events: none;
    }
    .section-{{ section.id }}  .content-wrapper > *{
      position: relative;
      z-index: 1;
    }
    .section-{{ section.id }} #spin-tip{ 
      font-size: 14px;
    }
      .section-{{ section.id }} .content-wrapper {
           flex-direction: column;
            margin: 0 auto;
            border-radius: 10px;
            max-width: 74vw;
      }
    }

    .section-{{ section.id }} .btn-wrap{
      margin: 10px 0;
    }

    
    .section-{{ section.id }} .spin-desc {
      font-size: 14px;
      display: none;
      margin-top: 0px;
        color: #fff;
        padding: 0 20px;
        text-align: center;
    }
    .section-{{ section.id }} .mobile-only{
      display: block;
    }
    .section-{{ section.id }} .pc-only{
      display: none;
    }
    
    .section-{{ section.id }} #spin-tip {
      font-size: 16px;
      height: 24px;
    }
    
    .section-{{ section.id }} .form-container button {
      font-size: 18px;
      padding: 10px 20px;
    }
  }

</style>

<div class="section-{{ section.id }} flip-win">
    {% render 'xmas-section-header', section: section %}
    <div class="content-wrapper">
    {% if section.settings.snow_image %}
      <div class="spin-section-snow">
        {{ section.settings.snow_image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: 'Snow strip' }}
      </div>
    {% endif %}
    {% render 'flip-card', section: section %}
    <div class="spin-eligibility_text">
      {{ section.settings.eligibility_text }}
    </div>
   </div>
</div>

    

