<style>
  .section-{{ section.id }}.email-prize-draw {
    --vp-s: 1px;
    --epd-bg: {{ section.settings.page_background }};
    --epd-accent: {{ section.settings.accent_color }};
    --epd-text: {{ section.settings.text_color }};
    --epd-muted: {{ section.settings.muted_color }};
    --epd-error: {{ section.settings.error_color }};
    --epd-modal-text: {{ section.settings.modal_text_color }};
    background: var(--epd-bg);
    color: var(--epd-text);
    padding-top: calc({{ section.settings.padding_top_desktop }} * var(--vp-s));
    padding-bottom: calc({{ section.settings.padding_bottom_desktop }} * var(--vp-s));
    overflow: hidden;
  }

  .section-{{ section.id }} .epd__inner {
    position: relative;
    width: calc(1253 * var(--vp-s));
    max-width: calc(100% - calc(40 * var(--vp-s)));
    min-height: calc(686 * var(--vp-s));
    margin: 0 auto;
  }

  .section-{{ section.id }} .epd__panel {
    position: absolute;
    top: calc(184 * var(--vp-s));
    left: 0;
    width: calc(1253 * var(--vp-s));
    height: calc(415 * var(--vp-s));
    border-radius: calc(15 * var(--vp-s));
    background: {{ section.settings.panel_background }};
  }

  .section-{{ section.id }} .epd__game {
    position: absolute;
    top: calc(29 * var(--vp-s));
    left: calc(-1 * var(--vp-s));
    width: calc(629 * var(--vp-s));
    height: calc(657 * var(--vp-s));
    background-color: transparent;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% 100%;
    z-index: 2;
    pointer-events: none;
  }

  {% if section.settings.board_image != blank %}
    .section-{{ section.id }} .epd__game {
      background-image: url('{{ section.settings.board_image | image_url: width: 1400 }}');
    }
  {% endif %}

  .section-{{ section.id }} .epd__grid {
    position: absolute;
    top: calc(144 * var(--vp-s));
    left: calc(76 * var(--vp-s));
    display: grid;
    grid-template-columns: repeat(3, calc(144.5 * var(--vp-s)));
    grid-template-rows: repeat(3, calc(144.5 * var(--vp-s)));
    gap: calc(7.8 * var(--vp-s));
    width: calc(449 * var(--vp-s));
    height: calc(449 * var(--vp-s));
    pointer-events: auto;
  }

  .section-{{ section.id }} .epd__grid::before {
    content: "";
    position: absolute;
    top: calc(-8 * var(--vp-s));
    left: calc(-8 * var(--vp-s));
    width: calc(465 * var(--vp-s));
    height: calc(465 * var(--vp-s));
    border-radius: calc(22 * var(--vp-s));
    background: rgba(0, 0, 0, 0.15);
    pointer-events: none;
    z-index: 0;
  }

  .section-{{ section.id }} .epd__tile,
  .section-{{ section.id }} .epd__open {
    position: relative;
    z-index: 1;
    width: calc(144.5 * var(--vp-s));
    height: calc(144.5 * var(--vp-s));
    border: 0;
    border-radius: calc(15.6 * var(--vp-s));
    padding: 0;
    overflow: hidden;
    cursor: pointer;
    background: #ffffff;
    box-shadow: 0 calc(4 * var(--vp-s)) calc(9 * var(--vp-s)) rgba(54, 38, 12, 0.22);
    transition: transform 160ms ease, filter 160ms ease, box-shadow 160ms ease;
  }

  .section-{{ section.id }} .epd__tile::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    box-shadow: inset 0 0 0 calc(4 * var(--vp-s)) rgba(255, 255, 255, 0.35);
    pointer-events: none;
  }

  .section-{{ section.id }} .epd__tile.is-active {
    transform: translateY(calc(-5 * var(--vp-s))) scale(1.035);
    box-shadow: 0 calc(10 * var(--vp-s)) calc(20 * var(--vp-s)) rgba(255, 155, 24, 0.55);
    filter: saturate(1.18) brightness(1.06);
  }

  .section-{{ section.id }} .epd__tile img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .section-{{ section.id }} .epd__tile--1 { grid-column: 1; grid-row: 1; }
  .section-{{ section.id }} .epd__tile--2 { grid-column: 2; grid-row: 1; }
  .section-{{ section.id }} .epd__tile--3 { grid-column: 3; grid-row: 1; }
  .section-{{ section.id }} .epd__tile--4 { grid-column: 1; grid-row: 2; }
  .section-{{ section.id }} .epd__tile--5 { grid-column: 3; grid-row: 2; }
  .section-{{ section.id }} .epd__tile--6 { grid-column: 1; grid-row: 3; }
  .section-{{ section.id }} .epd__tile--7 { grid-column: 2; grid-row: 3; }
  .section-{{ section.id }} .epd__tile--8 { grid-column: 3; grid-row: 3; }

  .section-{{ section.id }} .epd__open {
    grid-column: 2;
    grid-row: 2;
    background-color: #ffbc3f;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% 100%;
  }

  {% if section.settings.open_button_image != blank %}
    .section-{{ section.id }} .epd__open {
      background-image: url('{{ section.settings.open_button_image | image_url: width: 500 }}');
    }

    .section-{{ section.id }} .epd__open span {
      position: absolute;
      width: calc(1 * var(--vp-s));
      height: calc(1 * var(--vp-s));
      overflow: hidden;
      clip: rect(0 0 0 0);
    }
  {% endif %}

  .section-{{ section.id }} .epd__open span,
  .section-{{ section.id }} .epd__tile-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: #ffffff;
    font-size: calc(32.5 * var(--vp-s));
    font-weight: 800;
    line-height: calc(33 * var(--vp-s));
    text-align: center;
    text-shadow: calc(2.1 * var(--vp-s)) calc(2.1 * var(--vp-s)) 0 rgba(234, 114, 39, 0.9);
  }

  .section-{{ section.id }} .epd__tile-placeholder {
    color: #8c6d32;
    font-size: calc(18 * var(--vp-s));
    line-height: calc(24 * var(--vp-s));
    text-shadow: none;
  }

  .section-{{ section.id }} .epd__open:hover,
  .section-{{ section.id }} .epd__tile:hover {
    transform: translateY(calc(-3 * var(--vp-s)));
  }

  .section-{{ section.id }} .epd__open[disabled],
  .section-{{ section.id }} .epd__tile[disabled] {
    cursor: wait;
  }

  .section-{{ section.id }} .epd__content {
    position: absolute;
    top: calc(224 * var(--vp-s));
    left: calc(674 * var(--vp-s));
    width: calc(527 * var(--vp-s));
    z-index: 0;
  }

  .section-{{ section.id }} .epd__title {
    width: calc(373 * var(--vp-s));
    max-width: 100%;
    margin: 0 0 calc(25 * var(--vp-s));
    color: var(--epd-text);
    font-size: calc({{ section.settings.title_size_desktop }} * var(--vp-s));
    font-weight: 700;
    line-height: calc({{ section.settings.title_line_height_desktop }} * var(--vp-s));
    letter-spacing: 0;
    white-space: pre-line;
  }

  .section-{{ section.id }} .epd__form {
    width: calc(323 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__field,
  .section-{{ section.id }} .epd__submit {
    display: block;
    width: 100%;
    height: calc(45 * var(--vp-s));
    border-radius: calc(33 * var(--vp-s));
    font-family: Poppins, Arial, sans-serif;
    letter-spacing: 0;
  }

  .section-{{ section.id }} .epd__field {
    border: calc(1 * var(--vp-s)) solid var(--epd-accent);
    padding: 0 calc(21 * var(--vp-s));
    background: #ffffff;
    color: #222222;
    font-size: calc(15 * var(--vp-s));
    font-weight: 500;
    line-height: calc(23 * var(--vp-s));
    text-align: center;
    outline: none;
  }

  .section-{{ section.id }} .epd__field::placeholder {
    color: #9c9c9c;
    opacity: 1;
  }

  .section-{{ section.id }} .epd__submit {
    margin-top: calc(13 * var(--vp-s));
    border: 0;
    background: var(--epd-accent);
    color: #ffffff;
    cursor: pointer;
    font-size: calc(17 * var(--vp-s));
    font-weight: 600;
    line-height: calc(20 * var(--vp-s));
    transition: opacity 180ms ease, transform 180ms ease;
  }

  .section-{{ section.id }} .epd__submit:hover {
    transform: translateY(calc(-2 * var(--vp-s)));
  }

  .section-{{ section.id }} .epd__submit[disabled] {
    cursor: wait;
    opacity: 0.72;
    transform: none;
  }

  .section-{{ section.id }} .epd__message {
    min-height: calc(18 * var(--vp-s));
    margin-top: calc(6 * var(--vp-s));
    color: var(--epd-error);
    font-size: calc(11 * var(--vp-s));
    line-height: calc(16 * var(--vp-s));
    text-align: center;
  }

  .section-{{ section.id }} .epd__rules-title {
    margin: calc(13 * var(--vp-s)) 0 calc(9 * var(--vp-s));
    color: var(--epd-text);
    font-size: calc(15 * var(--vp-s));
    font-weight: 600;
    line-height: calc(23 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__rules {
    width: calc(527 * var(--vp-s));
    max-width: 100%;
    color: var(--epd-muted);
    font-size: calc({{ section.settings.desc_size_desktop }} * var(--vp-s));
    line-height: calc({{ section.settings.desc_line_height_desktop }} * var(--vp-s));
    white-space: pre-line;
  }

  .section-{{ section.id }} .epd__modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: calc(24 * var(--vp-s));
    background: rgba(0, 0, 0, 0.7);
  }

  .section-{{ section.id }} .epd__modal.is-open {
    display: flex;
  }

  .section-{{ section.id }} .epd__dialog {
    position: relative;
    width: min(calc(720 * var(--vp-s)), 96vw);
    max-height: min(calc(720 * var(--vp-s)), 92vh);
    overflow: auto;
    padding: calc(54 * var(--vp-s)) calc(46 * var(--vp-s)) calc(42 * var(--vp-s));
    border-radius: calc(24 * var(--vp-s));
    background:
      {% if section.settings.modal_bg != blank %}
        url('{{ section.settings.modal_bg | image_url: width: 1200 }}') center / 100% 100% no-repeat,
      {% endif %}
      #ffffff;
    color: var(--epd-modal-text);
    text-align: center;
    box-shadow: 0 calc(24 * var(--vp-s)) calc(60 * var(--vp-s)) rgba(0, 0, 0, 0.28);
  }

  .section-{{ section.id }} .epd__close {
    position: absolute;
    top: calc(16 * var(--vp-s));
    right: calc(16 * var(--vp-s));
    width: calc(34 * var(--vp-s));
    height: calc(34 * var(--vp-s));
    border: 0;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.22);
    color: #ffffff;
    font-size: calc(24 * var(--vp-s));
    line-height: calc(34 * var(--vp-s));
    cursor: pointer;
  }

  .section-{{ section.id }} .epd__prize-title {
    margin: 0 0 calc(15 * var(--vp-s));
    color: var(--epd-modal-text);
    font-size: calc(36 * var(--vp-s));
    font-weight: 700;
    line-height: calc(46 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__prize-desc {
    margin: 0 0 calc(18 * var(--vp-s));
    color: #8a6734;
    font-size: calc(16 * var(--vp-s));
    line-height: calc(24 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__prize-name {
    margin-bottom: calc(14 * var(--vp-s));
    font-size: calc(30 * var(--vp-s));
    font-weight: 700;
    line-height: calc(38 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__prize-image {
    display: none;
    width: calc(140 * var(--vp-s));
    height: calc(140 * var(--vp-s));
    object-fit: contain;
    margin: 0 auto calc(18 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__prize-code {
    display: none;
    width: fit-content;
    max-width: 100%;
    margin: calc(26 * var(--vp-s)) auto 0;
    padding: calc(12 * var(--vp-s)) calc(48 * var(--vp-s));
    border: calc(1 * var(--vp-s)) dashed var(--epd-accent);
    border-radius: calc(8 * var(--vp-s));
    background: #ffffff;
    color: var(--epd-accent);
    font-size: calc(28 * var(--vp-s));
    line-height: calc(36 * var(--vp-s));
    cursor: pointer;
  }

  .section-{{ section.id }} .epd__address {
    display: none;
    margin-top: calc(18 * var(--vp-s));
    padding: calc(20 * var(--vp-s));
    border-radius: calc(12 * var(--vp-s));
    background: rgba(255, 255, 255, 0.86);
    color: #482c00;
    text-align: left;
  }

  .section-{{ section.id }} .epd__address-display {
    margin-bottom: calc(14 * var(--vp-s));
    font-size: calc(17 * var(--vp-s));
    line-height: calc(24 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__address-form {
    display: none;
  }

  .section-{{ section.id }} .epd__address-form.is-open {
    display: block;
  }

  .section-{{ section.id }} .epd__form-group {
    margin-bottom: calc(12 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__form-group label {
    display: block;
    margin-bottom: calc(5 * var(--vp-s));
    font-size: calc(14 * var(--vp-s));
    font-weight: 700;
  }

  .section-{{ section.id }} .epd__form-group input {
    width: 100%;
    height: calc(42 * var(--vp-s));
    padding: 0 calc(12 * var(--vp-s));
    border: calc(1 * var(--vp-s)) solid #dddddd;
    border-radius: calc(6 * var(--vp-s));
    font-size: calc(14 * var(--vp-s));
    outline: none;
  }

  .section-{{ section.id }} .epd__address-actions,
  .section-{{ section.id }} .epd__form-actions {
    display: flex;
    justify-content: center;
    gap: calc(10 * var(--vp-s));
    margin-top: calc(14 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__small-btn {
    border: 0;
    border-radius: calc(6 * var(--vp-s));
    padding: calc(8 * var(--vp-s)) calc(18 * var(--vp-s));
    background: var(--epd-accent);
    color: #ffffff;
    cursor: pointer;
    font-size: calc(16 * var(--vp-s));
    line-height: calc(22 * var(--vp-s));
  }

  .section-{{ section.id }} .epd__small-btn--muted {
    background: #cccccc;
    color: #333333;
  }

  .section-{{ section.id }} .epd__save-message {
    color: var(--epd-error);
    font-size: calc(14 * var(--vp-s));
    line-height: calc(20 * var(--vp-s));
    text-align: center;
  }

  @media screen and (min-width: 850px) and (max-width: 1500px) {
    .section-{{ section.id }}.email-prize-draw {
      --vp-s: calc(100vw / 1500);
    }
  }

  @media screen and (max-width: 849px) {
    .section-{{ section.id }}.email-prize-draw {
      --vp-s: calc(100vw / 375);
      padding-top: calc({{ section.settings.padding_top_mobile }} * var(--vp-s));
      padding-bottom: calc({{ section.settings.padding_bottom_mobile }} * var(--vp-s));
    }

    .section-{{ section.id }} .epd__inner {
      width: calc(343 * var(--vp-s));
      max-width: calc(100% - calc(32 * var(--vp-s)));
      min-height: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .section-{{ section.id }} .epd__panel,
    .section-{{ section.id }} .epd__game,
    .section-{{ section.id }} .epd__content {
      position: relative;
      top: auto;
      left: auto;
    }

    .section-{{ section.id }} .epd__panel {
      order: 2;
      width: calc(343 * var(--vp-s));
      height: auto;
      min-height: calc(350 * var(--vp-s));
      margin-top: calc(-55 * var(--vp-s));
      border-radius: calc(14 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__game {
      order: 1;
      width: calc(343 * var(--vp-s));
      height: calc(374 * var(--vp-s));
      z-index: 2;
    }

    .section-{{ section.id }} .epd__grid {
      top: calc(68 * var(--vp-s));
      left: calc(20 * var(--vp-s));
      grid-template-columns: repeat(3, calc(93 * var(--vp-s)));
      grid-template-rows: repeat(3, calc(93 * var(--vp-s)));
      gap: calc(6 * var(--vp-s));
      width: calc(291 * var(--vp-s));
      height: calc(291 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__grid::before {
      top: calc(-6 * var(--vp-s));
      left: calc(-6 * var(--vp-s));
      width: calc(303 * var(--vp-s));
      height: calc(303 * var(--vp-s));
      border-radius: calc(14 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__tile,
    .section-{{ section.id }} .epd__open {
      width: calc(93 * var(--vp-s));
      height: calc(93 * var(--vp-s));
      border-radius: calc(8 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__content {
      order: 3;
      width: calc(287 * var(--vp-s));
      margin-top: calc(-298 * var(--vp-s));
      padding-bottom: calc(28 * var(--vp-s));
      z-index: 3;
    }

    .section-{{ section.id }} .epd__title {
      margin-bottom: calc(18 * var(--vp-s));
      font-size: calc({{ section.settings.title_size_mobile }} * var(--vp-s));
      line-height: calc({{ section.settings.title_line_height_mobile }} * var(--vp-s));
      text-align: left;
    }

    .section-{{ section.id }} .epd__field,
    .section-{{ section.id }} .epd__submit {
      height: calc(42 * var(--vp-s));
      font-size: calc(14 * var(--vp-s));
      line-height: calc(20 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__rules-title {
      font-size: calc(15 * var(--vp-s));
      line-height: calc(19 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__rules {
      font-size: calc({{ section.settings.desc_size_mobile }} * var(--vp-s));
      line-height: calc({{ section.settings.desc_line_height_mobile }} * var(--vp-s));
    }

    .section-{{ section.id }} .epd__dialog {
      padding: calc(44 * var(--vp-s)) calc(18 * var(--vp-s)) calc(28 * var(--vp-s));
      border-radius: calc(18 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__prize-title {
      font-size: calc(24 * var(--vp-s));
      line-height: calc(32 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__prize-desc {
      font-size: calc(13 * var(--vp-s));
      line-height: calc(20 * var(--vp-s));
    }

    .section-{{ section.id }} .epd__prize-name {
      font-size: calc(20 * var(--vp-s));
      line-height: calc(28 * var(--vp-s));
    }
  }
</style>

<div
  class="section-{{ section.id }} email-prize-draw"
  data-email-prize-draw
  data-section-id="{{ section.id }}"
  data-activity-id="{{ section.settings.activity_id | escape }}"
  data-is-test="{{ section.settings.is_test }}"
>
  <div class="epd__inner">
    <div class="epd__panel"></div>

    <div class="epd__game" aria-label="Prize draw game">
      <div class="epd__grid">
        {%- for index in (1..8) -%}
          <button class="epd__tile epd__tile--{{ index }}" type="button" data-prize-tile aria-label="{{ section.settings.tile_alt | escape }}">
            {%- if section.settings.tile_image != blank -%}
              <img src="{{ section.settings.tile_image | image_url: width: 400 }}" alt="{{ section.settings.tile_alt | escape }}" loading="lazy">
            {%- else -%}
              <span class="epd__tile-placeholder">{{ section.settings.tile_alt }}</span>
            {%- endif -%}
          </button>
        {%- endfor -%}

        <button class="epd__open" type="button" data-open-draw aria-label="{{ section.settings.open_button_label | escape }}">
          <span>{{ section.settings.open_button_label }}</span>
        </button>
      </div>
    </div>

    <div class="epd__content">
      {%- if section.settings.title != blank -%}
        <h2 class="epd__title">{{ section.settings.title }}</h2>
      {%- endif -%}

      <div class="epd__form">
        <input class="epd__field" type="email" autocomplete="email" placeholder="{{ section.settings.email_placeholder | escape }}" aria-label="{{ section.settings.email_placeholder | escape }}">
        <button class="epd__submit" type="button">{{ section.settings.button_label }}</button>
        <div class="epd__message" aria-live="polite"></div>
      </div>

      {%- if section.settings.rules_title != blank -%}
        <div class="epd__rules-title">{{ section.settings.rules_title }}</div>
      {%- endif -%}
      {%- if section.settings.rules != blank -%}
        <div class="epd__rules">{{ section.settings.rules }}</div>
      {%- endif -%}
    </div>
  </div>

  <div class="epd__modal" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="epd__dialog">
      <button class="epd__close" type="button" aria-label="Close">&times;</button>
      <h2 class="epd__prize-title"></h2>
      <p class="epd__prize-desc"></p>
      <div class="epd__prize-name"></div>
      <img class="epd__prize-image" alt="Prize">
      <div class="epd__prize-code" role="button" tabindex="0"></div>

      <div class="epd__address">
        <div class="epd__address-display"></div>
        <div class="epd__address-actions">
          <button class="epd__small-btn epd__edit-address" type="button">Edit Address</button>
        </div>
        <div class="epd__address-form">
          <div class="epd__form-group">
            <label>Consignee</label>
            <input type="text" data-field="consignee">
          </div>
          <div class="epd__form-group">
            <label>Country</label>
            <input type="text" data-field="countryCode" disabled>
          </div>
          <div class="epd__form-group">
            <label>State/Province</label>
            <input type="text" data-field="stateOrProvinceCode">
          </div>
          <div class="epd__form-group">
            <label>City</label>
            <input type="text" data-field="city">
          </div>
          <div class="epd__form-group">
            <label>Address Line 1</label>
            <input type="text" data-field="addressLineOne">
          </div>
          <div class="epd__form-group">
            <label>Address Line 2</label>
            <input type="text" data-field="addressLineTwo">
          </div>
          <div class="epd__form-group">
            <label>Postal Code</label>
            <input type="text" data-field="postalCode">
          </div>
          <div class="epd__form-group">
            <label>Phone</label>
            <input type="text" data-field="phone">
          </div>
          <div class="epd__form-group">
            <label>Email</label>
            <input type="email" data-field="email">
          </div>
          <div class="epd__save-message"></div>
          <div class="epd__form-actions">
            <button class="epd__small-btn epd__save-address" type="button">Save</button>
            <button class="epd__small-btn epd__small-btn--muted epd__cancel-address" type="button">Cancel</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const section = document.querySelector('[data-email-prize-draw][data-section-id="{{ section.id }}"]');
    if (!section) return;

    const baseUrlTest = 'https://shopify-api-test-01.external.sub.puture-in.com';
    const baseUrl = 'https://shopify-api.puture-in.com';
    const activityId = section.dataset.activityId;
    const isTest = section.dataset.isTest === 'true';
    const apiBase = isTest ? baseUrlTest : baseUrl;
    const emailInput = section.querySelector('.epd__field');
    const submitBtn = section.querySelector('.epd__submit');
    const openBtn = section.querySelector('[data-open-draw]');
    const tileBtns = Array.from(section.querySelectorAll('[data-prize-tile]'));
    const message = section.querySelector('.epd__message');
    const modal = section.querySelector('.epd__modal');
    const closeBtn = section.querySelector('.epd__close');
    const prizeTitle = section.querySelector('.epd__prize-title');
    const prizeDesc = section.querySelector('.epd__prize-desc');
    const prizeName = section.querySelector('.epd__prize-name');
    const prizeImage = section.querySelector('.epd__prize-image');
    const prizeCode = section.querySelector('.epd__prize-code');
    const addressBox = section.querySelector('.epd__address');
    const addressDisplay = section.querySelector('.epd__address-display');
    const addressForm = section.querySelector('.epd__address-form');
    const editAddressBtn = section.querySelector('.epd__edit-address');
    const saveAddressBtn = section.querySelector('.epd__save-address');
    const cancelAddressBtn = section.querySelector('.epd__cancel-address');
    const saveMessage = section.querySelector('.epd__save-message');

    const prizeTips = {
      0: {
        title: {{ section.settings.no_prize_title | json }},
        description: {{ section.settings.no_prize_description | json }}
      },
      1: {
        title: {{ section.settings.coupon_title | json }},
        description: {{ section.settings.coupon_description | json }}
      },
      2: {
        title: {{ section.settings.gift_title | json }},
        description: {{ section.settings.gift_description | json }}
      }
    };

    let currentRecord = null;
    let isRunning = false;
    let spinTimer = null;

    function validateEmail(email) {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function setMessage(text) {
      message.textContent = text || '';
    }

    function setInteractiveDisabled(state) {
      submitBtn.disabled = state;
      openBtn.disabled = state;
      emailInput.disabled = state;
      tileBtns.forEach((tile) => {
        tile.disabled = state;
      });
    }

    function setLoading(state) {
      isRunning = state;
      setInteractiveDisabled(state);
      submitBtn.textContent = state ? {{ section.settings.loading_label | json }} : {{ section.settings.button_label | json }};
    }

    function clearTileState() {
      tileBtns.forEach((tile) => {
        tile.classList.remove('is-active');
      });
    }

    function startTileSpin() {
      let index = 0;
      clearTileState();
      spinTimer = window.setInterval(() => {
        clearTileState();
        if (tileBtns[index]) tileBtns[index].classList.add('is-active');
        index = (index + 1) % tileBtns.length;
      }, 110);
    }

    function stopTileSpin(prize) {
      window.clearInterval(spinTimer);
      const seed = String((prize && (prize.prizeId || prize.id || prize.discountCode || prize.prizeName)) || Date.now());
      const finalIndex = seed.split('').reduce((sum, char) => sum + char.charCodeAt(0), 0) % Math.max(tileBtns.length, 1);
      clearTileState();
      if (tileBtns[finalIndex]) tileBtns[finalIndex].classList.add('is-active');
      window.setTimeout(clearTileState, 900);
    }

    async function drawPrize(email) {
      const response = await fetch(`${apiBase}/draw-records/draw`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          activityId: Number(activityId),
          userEmail: email,
          drawType: 'subscribe'
        })
      });
      const result = await response.json();
      if (!result || result.code !== 200) {
        throw new Error((result && result.msg) || 'Draw failed, please try again later.');
      }
      return result.data || {};
    }

    function openModal() {
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      addressForm.classList.remove('is-open');
    }

    function displayAddress(record) {
      const addressLines = [
        record.consignee,
        record.addressLineOne,
        record.addressLineTwo,
        [record.city, record.stateOrProvinceCode, record.postalCode].filter(Boolean).join(', '),
        record.countryCode,
        record.email,
        record.phone
      ].filter((line) => line && String(line).trim() !== '');

      addressDisplay.innerHTML = `<strong>Shipping Address:</strong><br>${addressLines.join('<br>')}`;
    }

    function fillAddressForm(record) {
      addressForm.querySelectorAll('[data-field]').forEach((input) => {
        input.value = record[input.dataset.field] || '';
      });
    }

    function showPrize(prize) {
      currentRecord = prize;
      const type = Number(prize.prizeType);
      const tip = prizeTips[type] || prizeTips[0];

      prizeTitle.innerHTML = tip.title || '';
      prizeDesc.textContent = tip.description || '';
      prizeName.textContent = prize.prizeName || prize.title || prize.name || '';
      prizeImage.style.display = 'none';
      prizeImage.removeAttribute('src');
      prizeCode.style.display = 'none';
      prizeCode.textContent = '';
      addressBox.style.display = 'none';

      const imageUrl = prize.prizeImageUrl || prize.imageUrl || prize.imgUrl;
      if (type === 1) {
        prizeCode.textContent = `Code: ${prize.discountCode || 'COUPONCODE'}`;
        prizeCode.style.display = 'block';
      } else if (type === 2) {
        if (imageUrl) {
          prizeImage.src = imageUrl;
          prizeImage.style.display = 'block';
        }
        addressBox.style.display = 'block';
        displayAddress(prize);
      } else if (imageUrl) {
        prizeImage.src = imageUrl;
        prizeImage.style.display = 'block';
      }

      openModal();
    }

    async function handleSubmit() {
      if (isRunning) return;
      const email = emailInput.value.trim();
      if (!activityId) {
        setMessage('Please configure activity ID.');
        return;
      }
      if (!validateEmail(email)) {
        setMessage('Please enter a valid email.');
        return;
      }

      setMessage('');
      setLoading(true);
      startTileSpin();
      try {
        try {
          localStorage.setItem('emailPrizeDrawEmail', email);
        } catch (error) {}
        const startedAt = Date.now();
        const prize = await drawPrize(email);
        const remaining = Math.max(0, 900 - (Date.now() - startedAt));
        window.setTimeout(() => {
          stopTileSpin(prize);
          showPrize(prize);
        }, remaining);
      } catch (error) {
        window.clearInterval(spinTimer);
        clearTileState();
        setMessage(error && error.message ? error.message : 'Something went wrong.');
      } finally {
        window.setTimeout(() => {
          setLoading(false);
        }, 900);
      }
    }

    function copyPrizeCode() {
      const code = prizeCode.textContent.replace('Code: ', '').trim();
      if (!code) return;
      navigator.clipboard.writeText(code).then(() => {
        prizeCode.textContent = 'Copied!';
        window.setTimeout(() => {
          prizeCode.textContent = `Code: ${code}`;
        }, 1800);
      }).catch(() => {});
    }

    async function saveAddress() {
      if (!currentRecord) return;
      const updatedData = {
        id: currentRecord.id,
        activityId: currentRecord.activityId,
        orderNumber: currentRecord.orderNumber
      };

      addressForm.querySelectorAll('[data-field]').forEach((input) => {
        updatedData[input.dataset.field] = input.value;
      });

      saveMessage.textContent = '';
      const response = await fetch(`${apiBase}/draw-records/updateAddress`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updatedData)
      });
      const result = await response.json();
      if (result && result.code === 200) {
        currentRecord = Object.assign({}, currentRecord, updatedData);
        displayAddress(currentRecord);
        addressForm.classList.remove('is-open');
      } else {
        saveMessage.textContent = (result && result.msg) || 'Failed to update address. Please try again.';
      }
    }

    submitBtn.addEventListener('click', handleSubmit);
    openBtn.addEventListener('click', handleSubmit);
    tileBtns.forEach((tile) => {
      tile.addEventListener('click', handleSubmit);
    });
    emailInput.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        handleSubmit();
      }
    });
    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });
    prizeCode.addEventListener('click', copyPrizeCode);
    prizeCode.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        copyPrizeCode();
      }
    });
    editAddressBtn.addEventListener('click', () => {
      if (!currentRecord) return;
      fillAddressForm(currentRecord);
      addressForm.classList.add('is-open');
    });
    cancelAddressBtn.addEventListener('click', () => {
      addressForm.classList.remove('is-open');
      saveMessage.textContent = '';
    });
    saveAddressBtn.addEventListener('click', () => {
      saveAddress().catch((error) => {
        saveMessage.textContent = error && error.message ? error.message : 'Failed to update address. Please try again.';
      });
    });
  })();
</script>

