      "type": "checkbox",
      "id": "disable_autoplay_on_interaction",
      "label": "Disable autoplay on user interaction",
      "default": true
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "color",
      "id": "navigation_color",
      "label": "Navigation color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Pagination"
    },
    {
