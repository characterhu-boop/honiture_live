    {
      "type": "color_background",
      "id": "acc_item_background",
      "label": "Accessory Item Background",
      "default": "linear-gradient(90deg, #EEFED6 0%, #78DAB3 100%)"
    },
    {
      "type": "color_background",
      "id": "plus_background",
      "label": "Plus Icon Background",
      "default": "#a3d653"
