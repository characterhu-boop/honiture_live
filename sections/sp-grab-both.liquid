  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Grab Both & Save More"
    },
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Subtitle"
    },
    {
      "type": "checkbox",
      "id": "show_sub_heading",
      "label": "Show Subtitle",
      "default": true
    },
    {
      "type": "text",
      "id": "view_more_label",
