{%- liquid
  assign countdown_blocks = section.blocks | where: 'type', 'count-down'
-%}

<style>
  .fd-best--{{ section.id }} {
    --vp-s: 1px;
    background: {{ section.settings.bg_color | default: '#f4f8ff' }};
    padding: calc({{ section.settings.padding_top | default: 48 }} * var(--vp-s)) 0 calc({{ section.settings.padding_bottom | default: 64 }} * var(--vp-s));
    overflow: hidden;
  }

  @media screen and (min-width: 850px) and (max-width: 1500px) {
    .fd-best--{{ section.id }} {
      --vp-s: calc(100vw / 1500);
    }
  }

  @media screen and (max-width: 849px) {
    .fd-best--{{ section.id }} {
      --vp-s: calc(100vw / 375);
    }
  }

  .fd-best--{{ section.id }} .fd-best__container {
    max-width: calc(1200 * var(--vp-s));
    margin: 0 auto;
    padding: 0 calc(16 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__header {
    margin-bottom: calc(18 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .xmax_section__title {
    color: {{ section.settings.title_color | default: '#191919' }};
  }

  .fd-best--{{ section.id }} .xmas-sub-heading {
    color: {{ section.settings.sub_heading_color | default: '#5c6470' }};
  }

  .fd-best--{{ section.id }} .fd-best__countdown {
    display: flex;
    justify-content: center;
    margin: calc(8 * var(--vp-s)) 0 calc(28 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: calc(20 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__card {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: minmax(0, 1.12fr) minmax(0, 0.88fr);
    grid-template-areas: "media info";
    background: #fff;
    border-radius: calc(16 * var(--vp-s));
    overflow: visible;
    box-shadow: 0 calc(10 * var(--vp-s)) calc(30 * var(--vp-s)) rgba(0, 35, 92, 0.08);
  }

  .fd-best--{{ section.id }} .fd-best__small-card {
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr;
    background: #fff;
    border-radius: calc(8 * var(--vp-s));
    overflow: hidden;
    box-shadow: 0 calc(10 * var(--vp-s)) calc(30 * var(--vp-s)) rgba(0, 35, 92, 0.08);
  }

  .fd-best--{{ section.id }} .fd-best__small-media {
    position: relative;
    height: calc(var(--fd-small-image-height, 332) * var(--vp-s));
    background: linear-gradient(135deg, #d9ebff 0%, #a8d5ff 100%);
    overflow: hidden;
  }

  .fd-best--{{ section.id }} .fd-best__small-media a,
  .fd-best--{{ section.id }} .fd-best__small-media img {
    display: block;
    width: 100%;
    height: 100%;
  }

  .fd-best--{{ section.id }} .fd-best__small-media img {
    object-fit: cover;
  }

  .fd-best--{{ section.id }} .common-badge {
    position: absolute;
    top: calc(var(--common-badge-top, 0) * var(--vp-s));
    left: calc(var(--common-badge-left, 24) * var(--vp-s));
    z-index: 2;
    display: inline-grid;
    place-items: center;
    width: calc(var(--common-badge-width, 56) * var(--vp-s));
    min-width: calc(var(--common-badge-width, 56) * var(--vp-s));
    height: calc(var(--common-badge-height, 70) * var(--vp-s));
    min-height: calc(var(--common-badge-height, 70) * var(--vp-s));
    padding: calc(8 * var(--vp-s)) calc(8 * var(--vp-s)) calc(16 * var(--vp-s));
    background: var(--common-badge-bg, #ff9f35);
    color: var(--common-badge-color, #fff);
    font-size: calc(var(--common-badge-font-size, 18) * var(--vp-s));
    font-weight: 900;
    line-height: 1.05;
    text-align: center;
    white-space: pre-line;
    clip-path: polygon(0 0, 100% 0, 100% 78%, 50% 100%, 0 78%);
    pointer-events: none;
  }

  .fd-best--{{ section.id }} .common-badge__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .fd-best--{{ section.id }} .common-badge__bg--mobile {
    display: none;
  }

  .fd-best--{{ section.id }} .common-badge__text {
    position: relative;
    z-index: 1;
    transform: translate(calc(var(--common-badge-text-left, 0) * var(--vp-s)), calc(var(--common-badge-text-top, 0) * var(--vp-s)));
  }

  .fd-best--{{ section.id }} .fd-best__small-info {
    display: grid;
    align-content: start;
    gap: calc(16 * var(--vp-s));
    padding: calc(34 * var(--vp-s)) calc(26 * var(--vp-s)) calc(26 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__small-title {
    margin: 0;
    color: #191919;
    font-size: calc(24 * var(--vp-s));
    font-weight: 900;
    line-height: 1.2;
  }

  .fd-best--{{ section.id }} .fd-best__small-points {
    display: grid;
    justify-items: start;
    gap: calc(8 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__small-point {
    display: inline-flex;
    min-width: calc(260 * var(--vp-s));
    padding: calc(3 * var(--vp-s)) calc(8 * var(--vp-s));
    background: var(--fd-small-point-bg, #d8e5ff);
    color: var(--fd-small-point-color, #2f3642);
    font-size: calc(13 * var(--vp-s));
    line-height: 1.1;
  }

  .fd-best--{{ section.id }} .fd-best__small-coupon .fd-best__coupon.is-custom {
    width: 100%;
    min-width: 0;
    min-height: calc(46 * var(--vp-s));
    padding: calc(6 * var(--vp-s)) calc(10 * var(--vp-s)) calc(6 * var(--vp-s)) calc(44 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__small-bottom {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1fr);
    gap: calc(20 * var(--vp-s));
    align-items: stretch;
  }

  .fd-best--{{ section.id }} .fd-best__small-prices {
    justify-content: center;
    flex-direction: column;
    align-items: flex-start;
    gap: calc(8 * var(--vp-s));
    height: 100%;
  }

  .fd-best--{{ section.id }} .fd-best__small-actions {
    display: grid;
    gap: calc(12 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__small-actions .fd-best__btn {
    width: 100%;
    height: calc(46 * var(--vp-s));
    min-height: calc(46 * var(--vp-s));
    padding: 0 calc(24 * var(--vp-s));
    line-height: 1;
  }

  .fd-best--{{ section.id }} .fd-best__card.is-image-right {
    grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
    grid-template-areas: "info media";
  }

  .fd-best--{{ section.id }} .fd-best__card.is-image-right .fd-best__media {
    border-radius: 0 calc(16 * var(--vp-s)) calc(16 * var(--vp-s)) 0;
  }

  .fd-best--{{ section.id }} .fd-best__media {
    grid-area: media;
    position: relative;
    min-height: 100%;
    background: linear-gradient(135deg, #d9ebff 0%, #a8d5ff 100%);
    display: grid;
    place-items: center;
    border-radius: calc(16 * var(--vp-s)) 0 0 calc(16 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__media-link {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    overflow: hidden;
  }

  .fd-best--{{ section.id }} .fd-best__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fd-best--{{ section.id }} .fd-best__badge {
    position: absolute;
    top: calc(var(--fd-badge-top, 14) * var(--vp-s));
    left: calc(var(--fd-badge-left, 14) * var(--vp-s));
    z-index: 2;
    width: calc(106 * var(--vp-s));
    height: calc(88 * var(--vp-s));
    display: grid;
    place-items: center;
    pointer-events: none;
  }

  .fd-best--{{ section.id }} .fd-best__badge img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .fd-best--{{ section.id }} .fd-best__card.is-image-right .fd-best__badge {
    left: auto;
    right: calc(var(--fd-badge-left, 14) * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__badge-text {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: calc(20 * var(--vp-s));
    font-weight: 900;
    color: #fff;
    text-align: center;
    line-height: 1;
    padding: calc(8 * var(--vp-s)) calc(16 * var(--vp-s)) 0 calc(10 * var(--vp-s));
    transform: rotate(var(--fd-badge-text-rotate, -14deg));
  }

  .fd-best--{{ section.id }} .fd-best__info {
    grid-area: info;
    padding: calc(22 * var(--vp-s)) calc(22 * var(--vp-s)) calc(24 * var(--vp-s));
    display: grid;
    align-content: center;
    gap: calc(14 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__title {
    display: flex;
    flex-direction: column;
    gap: calc(10 * var(--vp-s));
    margin: 0;
    font-size: calc(24 * var(--vp-s));
    line-height: 1.18;
    font-weight: 900;
    color: #191919;
    text-align: var(--fd-title-align, left);
  }

  .fd-best--{{ section.id }} .fd-best__title-label {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: var(--fd-title-label-width, auto);
    min-height: 2em;
    margin-right: 0.34em;
    padding: 0.14em 1.2em 0.14em var(--fd-title-label-padding-left, 3.2em);
    border-radius: calc(999 * var(--vp-s));
    background: var(--fd-title-label-bg, linear-gradient(90deg, #0db7d7 0%, #35d9de 100%));
    color: #fff;
    font-size: 0.67em;
    font-weight: 900;
    line-height: 1;
    vertical-align: 0.18em;
    white-space: nowrap;
  }

  .fd-best--{{ section.id }} .fd-best__title-label-icon {
    position: absolute;
    top: var(--fd-title-label-icon-top, 50%);
    left: var(--fd-title-label-icon-left, -0.42em);
    width: var(--fd-title-label-icon-size, 2.7em);
    height: var(--fd-title-label-icon-size, 2.7em);
    object-fit: contain;
    transform: translateY(-50%);
  }

  .fd-best--{{ section.id }} .fd-best__mobile-title-label {
    display: none;
  }

  .fd-best--{{ section.id }} .fd-best__desc {
    color: rgba(25, 25, 25, 0.7);
    font-size: calc(15 * var(--vp-s));
    line-height: 1.55;
    text-align: var(--fd-desc-align, left);
  }

  .fd-best--{{ section.id }} .fd-best__desc > *:first-child {
    margin-top: 0;
  }

  .fd-best--{{ section.id }} .fd-best__desc > *:last-child {
    margin-bottom: 0;
  }

  .fd-best--{{ section.id }} .fd-best__gift {
    position: relative;
    width: var(--fd-gift-width, calc(440 * var(--vp-s)));
    max-width: 100%;
    margin-top: calc(4 * var(--vp-s));
    margin-left: var(--fd-gift-align-margin-left, 0);
    margin-right: var(--fd-gift-align-margin-right, auto);
    padding-top: calc(22 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__gift.is-center {
    --fd-gift-align-margin-left: auto;
    --fd-gift-align-margin-right: auto;
  }

  .fd-best--{{ section.id }} .fd-best__gift-icon {
    position: absolute;
    top: 0;
    left: calc(var(--fd-gift-icon-left, -30) * var(--vp-s));
    z-index: 2;
    width: var(--fd-gift-icon-width, calc(78 * var(--vp-s)));
    height: auto;
    transform: rotate(var(--fd-gift-icon-rotate, -14deg));
    pointer-events: none;
  }

  .fd-best--{{ section.id }} .fd-best__gift-inner {
    overflow: hidden;
    border: calc(2 * var(--vp-s)) solid var(--fd-gift-border, #418eff);
    border-radius: calc(8 * var(--vp-s));
    background: var(--fd-gift-bg, #fff);
  }

  .fd-best--{{ section.id }} .fd-best__gift-heading {
    min-height: calc(32 * var(--vp-s));
    padding: calc(7 * var(--vp-s)) calc(18 * var(--vp-s)) calc(6 * var(--vp-s));
    background: var(--fd-gift-heading-bg, #418eff);
    color: var(--fd-gift-heading-color, #fff);
    font-size: calc(16 * var(--vp-s));
    font-weight: 900;
    line-height: 1.2;
    text-align: center;
  }

  .fd-best--{{ section.id }} .fd-best__gift-divider {
    position: relative;
    width: calc(310 * var(--vp-s));
    max-width: calc(100% - calc(88 * var(--vp-s)));
    height: calc(13 * var(--vp-s));
    margin: 0 auto;
  }

  .fd-best--{{ section.id }} .fd-best__gift-divider::before,
  .fd-best--{{ section.id }} .fd-best__gift-divider::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .fd-best--{{ section.id }} .fd-best__gift-divider::before {
    width: 100%;
    border-top: calc(1 * var(--vp-s)) dashed var(--fd-gift-border, #418eff);
  }

  .fd-best--{{ section.id }} .fd-best__gift-divider::after {
    width: calc(14 * var(--vp-s));
    height: calc(14 * var(--vp-s));
    background:
      linear-gradient(var(--fd-gift-border, #418eff), var(--fd-gift-border, #418eff)) center / calc(1 * var(--vp-s)) 100% no-repeat,
      linear-gradient(var(--fd-gift-border, #418eff), var(--fd-gift-border, #418eff)) center / 100% calc(1 * var(--vp-s)) no-repeat,
      var(--fd-gift-bg, #fff);
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .fd-best--{{ section.id }} .fd-best__gift-body {
    display: grid;
    grid-template-columns: var(--fd-gift-image-width, calc(110 * var(--vp-s))) minmax(0, 1fr);
    align-items: center;
    gap: calc(22 * var(--vp-s));
    min-height: calc(84 * var(--vp-s));
    padding: calc(6 * var(--vp-s)) calc(36 * var(--vp-s)) calc(16 * var(--vp-s)) calc(36 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__gift-media {
    display: block;
    width: var(--fd-gift-image-width, calc(110 * var(--vp-s)));
  }

  .fd-best--{{ section.id }} .fd-best__gift-media img,
  .fd-best--{{ section.id }} .fd-best__gift-media svg {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .fd-best--{{ section.id }} .fd-best__gift-title {
    display: block;
    color: var(--fd-gift-title-color, #191919);
    font-size: calc(14 * var(--vp-s));
    font-weight: 400;
    line-height: 1.25;
    text-decoration: none;
  }

  .fd-best--{{ section.id }} .fd-best__gift-price {
    display: flex;
    align-items: baseline;
    gap: calc(16 * var(--vp-s));
    margin-top: calc(8 * var(--vp-s));
    font-size: calc(15 * var(--vp-s));
    line-height: 1;
  }

  .fd-best--{{ section.id }} .fd-best__gift-free {
    color: var(--fd-gift-free-color, #00c7c9);
    font-weight: 900;
  }

  .fd-best--{{ section.id }} .fd-best__gift-compare {
    color: rgba(25, 25, 25, 0.42);
    font-weight: 500;
    text-decoration: line-through;
  }

  .fd-best--{{ section.id }} .fd-best__desc-image {
    display: block;
    width: 100%;
    max-width: calc(var(--fd-desc-image-width, 220) * var(--vp-s));
    height: auto;
    margin: 0 0 calc(2 * var(--vp-s));
    object-fit: contain;
  }

  .fd-best--{{ section.id }} .fd-best__desc-image-wrap {
    display: flex;
    width: 100%;
  }

  .fd-best--{{ section.id }} .fd-best__desc-image-wrap.is-left {
    justify-content: flex-start;
  }

  .fd-best--{{ section.id }} .fd-best__desc-image-wrap.is-center {
    justify-content: center;
  }

  .fd-best--{{ section.id }} .fd-best__progress {
    display: grid;
    gap: calc(8 * var(--vp-s));
    margin-top: calc(2 * var(--vp-s));
  }

  .fd-best--{{ section.id }} .fd-best__progress-text {
    font-size: calc(13 * var(--vp-s));
    font-weight: 800;
    color: {{ section.settings.primary_color | default: '#10b7d7' }};
    line-height: 1;
  }

  .fd-best--{{ section.id }} .fd-best__progress-track {
    height: calc(7 * var(--vp-s));
    border-radius: calc(999 * var(--vp-s));
    background: rgba(17, 24, 39, 0.12);
    overflow: hidden;
  }

  .fd-best--{{ section.id }} .fd-best__progress-fill {
    display: block;
    width: 0%;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #11b6d7 0%, #4de0e4 100%);
  }

  .fd-best--{{ section.id }} .fd-best__coupon {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    width: fit-content;
    max-width: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .fd-best--{{ section.id }} .fd-best__coupon img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .fd-best--{{ section.id }} .fd-best__coupon.is-custom {
    justify-content: space-between;
    gap: calc(16 * var(--vp-s));
    min-width: calc(368 * var(--vp-s));
    min-height: calc(44 * var(--vp-s));
    padding: calc(6 * var(--vp-s)) calc(10 * var(--vp-s)) calc(6 * var(--vp-s)) calc(40 * var(--vp-s));
    border-radius: calc(999 * var(--vp-s));
    background: var(--fd-coupon-bg, #ff9f35);
    color: var(--fd-coupon-color, #fff);
    font-size: calc(16 * var(--vp-s));
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .fd-best--{{ section.id }} .fd-best__coupon-text {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fd-best--{{ section.id }} .fd-best__coupon-claim {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: calc(78 * var(--vp-s));
    min-height: calc(26 * var(--vp-s));
    padding: calc(4 * var(--vp-s)) calc(16 * var(--vp-s));
    border-radius: calc(999 * var(--vp-s));
    background: var(--fd-coupon-claim-bg, #fff);
    color: var(--fd-coupon-claim-color, #1f1f1f);
    font-size: calc(14 * var(--vp-s));
    font-weight: 800;
    line-height: 1;
    text-decoration: underline;
    flex: 0 0 auto;
  }

  .fd-best--{{ section.id }} .fd-best__toast {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: rgba(0, 0, 0, 0.82);
    color: #fff;
    font-size: calc(14 * var(--vp-s));
    font-weight: 700;
    line-height: 1;
    padding: calc(12 * var(--vp-s)) calc(20 * var(--vp-s));
    border-radius: calc(999 * var(--vp-s));
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .fd-best--{{ section.id }} .fd-best__toast.is-show {
    opacity: 1;
  }

  .fd-best--{{ section.id }} .fd-best__price-row {
    display: grid;
    gap: calc(18 * var(--vp-s));
    margin-top: calc(2 * var(--vp-s));
    padding-top: calc(14 * var(--vp-s));
    border-top: calc(1 * var(--vp-s)) solid rgba(17, 24, 39, 0.12);
  }

  .fd-best--{{ section.id }} .fd-best__coupon-row {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .fd-best--{{ section.id }} .fd-best__purchase-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: calc(18 * var(--vp-s));
    width: 100%;
  }

  .fd-best--{{ section.id }} .fd-best__prices {
    display: flex;
    align-items: baseline;
    gap: calc(10 * var(--vp-s));
    flex-wrap: wrap;
    min-width: 0;
  }

  .fd-best--{{ section.id }} .fd-best__actions {
    display: inline-flex;
    align-items: center;
    gap: calc(12 * var(--vp-s));
    flex: 0 0 auto;
  }

  .fd-best--{{ section.id }} .fd-best__cta {
    display: inline-flex;
    align-items: stretch;
    overflow: hidden;
    border-radius: calc(999 * var(--vp-s));
    flex: 0 0 auto;
  }

  .fd-best--{{ section.id }} .fd-best__cta-main,
  .fd-best--{{ section.id }} .fd-best__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0;
    text-decoration: none;
    cursor: pointer;
    color: #fff;
  }

  .fd-best--{{ section.id }} .fd-best__cta-main {
    padding: 0 calc(24 * var(--vp-s));
    min-height: calc(56 * var(--vp-s));
    background: linear-gradient(90deg, #11b6d7 0%, #35d9de 100%);
    font-size: calc(16 * var(--vp-s));
    font-weight: 900;
    white-space: nowrap;
  }

  .fd-best--{{ section.id }} .fd-best__cta-icon {
    width: calc(64 * var(--vp-s));
    background: #15386a;
    flex: 0 0 calc(64 * var(--vp-s));
  }

