            </div>
          </div>
        </article>
          {%- when 'small_card' -%}
        <article class="fd-best__small-card" {{ block.shopify_attributes }}
          style="--fd-small-image-height: {{ block.settings.image_height | default: 332 }}; --fd-small-image-height-mobile: {{ block.settings.image_height_mobile | default: 220 }}; --fd-small-point-bg: {{ block.settings.selling_point_bg | default: '#d8e5ff' }}; --fd-small-point-color: {{ block.settings.selling_point_color | default: '#2f3642' }}; --fd-coupon-bg: {{ block.settings.coupon_background | default: '#ff9f35' }}; --fd-coupon-color: {{ block.settings.coupon_text_color | default: '#ffffff' }}; --fd-coupon-claim-bg: {{ block.settings.coupon_claim_bg | default: '#ffffff' }}; --fd-coupon-claim-color: {{ block.settings.coupon_claim_color | default: '#1f1f1f' }}; --fd-small-learn-bg: {{ block.settings.learn_button_bg | default: '#d9d9d9' }}; --fd-small-learn-color: {{ block.settings.learn_button_color | default: '#ffffff' }}; --fd-small-shop-bg: {{ block.settings.shop_button_bg | default: 'linear-gradient(90deg, #0db7d7 0%, #35d9de 100%)' }}; --fd-small-shop-color: {{ block.settings.shop_button_color | default: '#ffffff' }};">
          <div class="fd-best__small-media">
            {% render 'common-badge',
