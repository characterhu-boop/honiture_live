<section class="fd-best fd-best--{{ section.id }}" data-fdbs-section="{{ section.id }}" data-cart-add-url="{{ routes.cart_add_url }}" data-checkout-url="{{ routes.checkout_url }}">
  <div class="fd-best__container">
    <div class="fd-best__header">
      {% render 'xmas-section-header' %}
    </div>

    {%- for block in countdown_blocks -%}
      <div class="fd-best__countdown" {{ block.shopify_attributes }}>
        {% render 'count-down', block: block, cusId: section.id %}
      </div>
    {%- endfor -%}

    <div class="fd-best__grid">
      {%- for block in section.blocks -%}
        {%- unless block.type == 'large_card' or block.type == 'small_card' -%}
          {%- continue -%}
        {%- endunless -%}
        {%- assign product = block.settings.product -%}
        {%- assign variant = blank -%}
        {%- assign title = block.settings.title -%}
        {%- assign description = block.settings.description -%}
        {%- assign image = block.settings.image -%}
        {%- assign shop_now_link = block.settings.btn_link -%}
        {%- assign button_label = block.settings.button_label | default: 'Shop Now' -%}
        {%- assign sale_price = 0 -%}
        {%- assign compare_price = 0 -%}
        {%- assign original_sale_price = 0 -%}
        {%- if product != blank -%}
          {%- assign variant = product.selected_or_first_available_variant -%}
          {%- if title == blank -%}
            {%- assign title = product.title -%}
          {%- endif -%}
          {%- if description == blank -%}
            {%- assign description = product.description -%}
          {%- endif -%}
          {%- if image == blank -%}
            {%- assign image = product.featured_image -%}
          {%- endif -%}
          {%- assign sale_price = product.price -%}
          {%- assign original_sale_price = sale_price -%}
          {%- assign compare_price = product.compare_at_price_max -%}
          {%- if block.settings.extra_discount > 0 -%}
            {%- assign discount_multiplier = 100 | minus: block.settings.extra_discount -%}
            {%- assign sale_price = sale_price | times: discount_multiplier | divided_by: 100 -%}
            {%- if compare_price == blank or compare_price <= sale_price -%}
              {%- assign compare_price = original_sale_price -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
        {%- if block.settings.price != blank -%}
          {%- assign sale_price_text = block.settings.price -%}
        {%- else -%}
          {%- assign sale_price_text = sale_price | money -%}
        {%- endif -%}

        {%- case block.type -%}
          {%- when 'large_card' -%}
        {%- liquid
          assign gift_product = block.settings.gift_card_product
          assign gift_title = block.settings.gift_card_item_title
          assign gift_image = block.settings.gift_card_image
          assign gift_compare_text = block.settings.gift_card_compare_price
          assign gift_heading = block.settings.gift_card_heading
          assign show_gift_card = false

          if gift_title == blank and gift_product != blank
            assign gift_title = gift_product.title
          endif

          if gift_image == blank and gift_product != blank
            assign gift_image = gift_product.featured_image
          endif

          if gift_compare_text == blank and gift_product != blank
            assign gift_compare_text = gift_product.price | money
          endif

          if gift_heading == blank
            if title != blank
              capture gift_heading
                echo 'Gifts for '
                echo title | strip_html
              endcapture
            else
              assign gift_heading = 'Gifts'
            endif
          endif

          if gift_product != blank or gift_title != blank or gift_image != blank
            assign show_gift_card = true
          elsif block.settings.show_gift_card
            assign show_gift_card = true
          endif
        -%}
        <article class="fd-best__card {% if block.settings.layout_direction == 'right' %}is-image-right{% endif %}" {{ block.shopify_attributes }}
          style="--fd-desc-image-width: {{ block.settings.description_image_width | default: section.settings.description_image_width | default: 220 }}; --fd-desc-image-width-mobile: {{ block.settings.description_image_width_mobile | default: section.settings.description_image_width_mobile | default: 180 }}; --fd-badge-top: {{ block.settings.badge_top | default: 14 }}; --fd-badge-left: {{ block.settings.badge_left | default: 14 }}; --fd-badge-top-mobile: {{ block.settings.badge_top_mobile | default: 10 }}; --fd-badge-left-mobile: {{ block.settings.badge_left_mobile | default: 10 }}; --fd-badge-text-rotate: {{ block.settings.badge_text_rotate | default: -14 }}deg; --fd-title-label-bg: {{ block.settings.title_label_bg | default: 'linear-gradient(90deg, #0db7d7 0%, #35d9de 100%)' }}; {%- if block.settings.title_label_width != blank -%} --fd-title-label-width: calc({{ block.settings.title_label_width }} * var(--vp-s));{%- endif -%} {%- if block.settings.title_label_width_mobile != blank -%} --fd-title-label-width-mobile: calc({{ block.settings.title_label_width_mobile }} * var(--vp-s));{%- endif -%} --fd-title-label-icon-size: calc({{ block.settings.title_label_icon_size | default: 54 }} * var(--vp-s)); --fd-title-label-icon-left: calc({{ block.settings.title_label_icon_left | default: -8 }} * var(--vp-s)); --fd-title-label-icon-top: {{ block.settings.title_label_icon_top | default: 50 }}%; --fd-title-label-padding-left: calc({{ block.settings.title_label_padding_left | default: 54 }} * var(--vp-s)); --fd-title-align: {{ block.settings.title_text_align | default: 'left' }}; --fd-title-align-mobile: {{ block.settings.title_text_align_mobile | default: block.settings.title_text_align | default: 'center' }}; --fd-desc-align: {{ block.settings.description_text_align | default: 'left' }}; --fd-desc-align-mobile: {{ block.settings.description_text_align_mobile | default: block.settings.description_text_align | default: 'center' }};"
          data-progress-start="{{ block.settings.progress_start_time | escape }}"
          data-progress-end="{{ block.settings.progress_end_time | escape }}"
          data-progress-bezier="{{ block.settings.progress_bezier | escape }}"
          data-progress-label="{{ block.settings.progress_label | escape }}"
          data-progress-fallback="{{ block.settings.progress_fallback_percent }}"
          data-progress-min="{{ block.settings.progress_min_percent }}"
          data-progress-enabled="{{ block.settings.show_progress_bar }}">
          <div class="fd-best__media">
            {%- if block.settings.discount_bg != blank or block.settings.discount_text != blank -%}
              <div class="fd-best__badge" aria-hidden="true">
                {%- if block.settings.discount_bg != blank -%}
                  <img src="{{ block.settings.discount_bg | image_url: width: 240 }}" alt="" loading="lazy">
                {%- endif -%}
                {%- if block.settings.discount_text != blank -%}
                  <span class="fd-best__badge-text{% if block.settings.badge_text_nowrap == false %} is-wrap{% endif %}">{{ block.settings.discount_text }}{% if block.settings.badge_text_nowrap == false %}<br>{% endif %}OFF</span>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if image != blank -%}
              <a class="fd-best__media-link" href="{{ product.url | default: '#' }}" target="_blank" rel="noopener">
                <img src="{{ image | image_url: width: 1200 }}" alt="{{ title | escape }}" loading="lazy">
              </a>
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>

          <div class="fd-best__info">
            {%- if block.settings.title_label != blank -%}
              <div class="fd-best__mobile-title-label">
                <span class="fd-best__title-label">
                  {%- if block.settings.title_label_icon != blank -%}
                    <img class="fd-best__title-label-icon" src="{{ block.settings.title_label_icon | image_url: width: 120 }}" alt="" loading="lazy">
                  {%- endif -%}
                  <span>{{ block.settings.title_label | escape }}</span>
                </span>
              </div>
            {%- endif -%}
            <h3 class="fd-best__title">
              {%- if block.settings.title_label != blank -%}
                <span class="fd-best__title-label">
                  {%- if block.settings.title_label_icon != blank -%}
                    <img class="fd-best__title-label-icon" src="{{ block.settings.title_label_icon | image_url: width: 120 }}" alt="" loading="lazy">
                  {%- endif -%}
                  <span>{{ block.settings.title_label | escape }}</span>
                </span>
              {%- endif -%}
              <a href="{{ product.url | default: '#' }}" target="_blank" rel="noopener">{{ title }}</a>
            </h3>

            {%- if description != blank -%}
              <div class="fd-best__desc rte">{{ description }}</div>
            {%- endif -%}

            {%- if show_gift_card -%}
              <div class="fd-best__gift {% if block.settings.gift_card_align == 'center' %}is-center{% endif %}"
                style="--fd-gift-width: calc({{ block.settings.gift_card_width | default: 440 }} * var(--vp-s)); --fd-gift-width-mobile: calc({{ block.settings.gift_card_width_mobile | default: 335 }} * var(--vp-s)); --fd-gift-image-width: calc({{ block.settings.gift_card_image_width | default: 110 }} * var(--vp-s)); --fd-gift-image-width-mobile: calc({{ block.settings.gift_card_image_width_mobile | default: 82 }} * var(--vp-s)); --fd-gift-icon-width: calc({{ block.settings.gift_card_icon_width | default: 78 }} * var(--vp-s)); --fd-gift-icon-width-mobile: calc({{ block.settings.gift_card_icon_width_mobile | default: 62 }} * var(--vp-s)); --fd-gift-icon-left: {{ block.settings.gift_card_icon_left | default: -30 }}; --fd-gift-icon-left-mobile: {{ block.settings.gift_card_icon_left_mobile | default: -14 }}; --fd-gift-icon-rotate: {{ block.settings.gift_card_icon_rotate | default: -14 }}deg; --fd-gift-border: {{ block.settings.gift_card_border_color | default: '#418eff' }}; --fd-gift-bg: {{ block.settings.gift_card_bg | default: '#ffffff' }}; --fd-gift-heading-bg: {{ block.settings.gift_card_heading_bg | default: '#418eff' }}; --fd-gift-heading-color: {{ block.settings.gift_card_heading_color | default: '#ffffff' }}; --fd-gift-title-color: {{ block.settings.gift_card_title_color | default: '#191919' }}; --fd-gift-free-color: {{ block.settings.gift_card_free_color | default: '#00c7c9' }};">
                {%- if block.settings.gift_card_icon != blank -%}
                  <img class="fd-best__gift-icon" src="{{ block.settings.gift_card_icon | image_url: width: 240 }}" alt="" loading="lazy">
                {%- endif -%}
