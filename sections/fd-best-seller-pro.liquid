              text_left_mobile: block.settings.discount_badge_text_left_mobile
            %}

            {%- if image != blank -%}
              <a href="{{ product.url | default: '#' }}" target="_blank" rel="noopener">
                <img src="{{ image | image_url: width: 1000 }}" alt="{{ title | escape }}" loading="lazy">
              </a>
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>

          <div class="fd-best__small-info">
            <h3 class="fd-best__small-title">
              <a href="{{ product.url | default: '#' }}" target="_blank" rel="noopener">{{ title }}</a>
            </h3>

            {%- if block.settings.selling_point_1 != blank or block.settings.selling_point_2 != blank or block.settings.selling_point_3 != blank -%}
              <div class="fd-best__small-points">
                {%- if block.settings.selling_point_1 != blank -%}
                  <span class="fd-best__small-point">{{ block.settings.selling_point_1 | escape }}</span>
                {%- endif -%}
                {%- if block.settings.selling_point_2 != blank -%}
                  <span class="fd-best__small-point">{{ block.settings.selling_point_2 | escape }}</span>
                {%- endif -%}
                {%- if block.settings.selling_point_3 != blank -%}
                  <span class="fd-best__small-point">{{ block.settings.selling_point_3 | escape }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if block.settings.coupon_code != blank -%}
              {%- assign coupon_text = block.settings.coupon_text | default: block.settings.coupon_code -%}
              <div class="fd-best__small-coupon">
                <button class="fd-best__coupon is-custom" type="button" data-fdbs-copy-code data-code="{{ block.settings.coupon_code | escape }}">
                  <span class="fd-best__coupon-text">{{ coupon_text | escape }}</span>
                  <span class="fd-best__coupon-claim">{{ block.settings.coupon_claim_label | default: 'Claim' | escape }}</span>
                </button>
              </div>
            {%- endif -%}

            <div class="fd-best__small-bottom">
              <div class="fd-best__prices fd-best__small-prices">
                <span class="fd-best__sale-price">{{ sale_price_text }}</span>
                {%- if compare_price and compare_price > sale_price -%}
                  <span class="fd-best__compare-price">{{ compare_price | money }}</span>
                {%- endif -%}
              </div>

              <div class="fd-best__small-actions">
                {%- if block.settings.learn_button_label != blank -%}
                  <a class="fd-best__btn fd-best__small-learn" href="{{ block.settings.learn_button_link | default: product.url | default: '#' }}" target="_blank" rel="noopener">{{ block.settings.learn_button_label | escape }}</a>
                {%- endif -%}
                {%- if block.settings.shop_button_label != blank -%}
                  {%- if block.settings.shop_button_link != blank -%}
                    <a class="fd-best__btn fd-best__small-shop" href="{{ block.settings.shop_button_link }}" target="_blank" rel="noopener">{{ block.settings.shop_button_label | escape }}</a>
                  {%- else -%}
                    <button class="fd-best__btn fd-best__small-shop" type="button" data-fdbs-shop-now data-variant-id="{{ variant.id }}" data-checkout-url="{{ routes.checkout_url }}" {% if variant == blank %}disabled{% endif %}>{{ block.settings.shop_button_label | escape }}</button>
                  {%- endif -%}
                {%- endif -%}
              </div>
            </div>
          </div>
        </article>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('.fd-best--{{ section.id }}');
    if (!root || root.dataset.fdbsReady === '1') return;
    root.dataset.fdbsReady = '1';

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function parseBezier(raw) {
      var fallback = [0.42, 0, 0.58, 1];
      if (!raw) return fallback;
      var parts = raw.split(',').map(function (value) { return parseFloat(value.trim()); }).filter(function (value) { return Number.isFinite(value); });
      if (parts.length !== 4) return fallback;
      return parts;
    }

    function cubicBezier(p1x, p1y, p2x, p2y) {
      var NEWTON_ITERATIONS = 6;
      var NEWTON_MIN_SLOPE = 0.001;
      var SUBDIVISION_PRECISION = 0.0000001;
      var SUBDIVISION_MAX_ITERATIONS = 10;
      var kSplineTableSize = 11;
      var kSampleStepSize = 1.0 / (kSplineTableSize - 1.0);
      var float32ArraySupported = typeof Float32Array === 'function';

      function A(aA1, aA2) {
        return 1.0 - 3.0 * aA2 + 3.0 * aA1;
      }
      function B(aA1, aA2) {
        return 3.0 * aA2 - 6.0 * aA1;
      }
      function C(aA1) {
        return 3.0 * aA1;
      }
      function calcBezier(aT, aA1, aA2) {
        return ((A(aA1, aA2) * aT + B(aA1, aA2)) * aT + C(aA1)) * aT;
      }
      function getSlope(aT, aA1, aA2) {
        return 3.0 * A(aA1, aA2) * aT * aT + 2.0 * B(aA1, aA2) * aT + C(aA1);
      }

      var sampleValues = float32ArraySupported ? new Float32Array(kSplineTableSize) : new Array(kSplineTableSize);
      for (var i = 0; i < kSplineTableSize; ++i) {
        sampleValues[i] = calcBezier(i * kSampleStepSize, p1x, p2x);
      }

      function binarySubdivide(aX, aA, aB) {
        var currentX, currentT, i = 0;
        do {
          currentT = aA + (aB - aA) / 2.0;
          currentX = calcBezier(currentT, p1x, p2x) - aX;
          if (currentX > 0.0) {
            aB = currentT;
          } else {
            aA = currentT;
          }
        } while (Math.abs(currentX) > SUBDIVISION_PRECISION && ++i < SUBDIVISION_MAX_ITERATIONS);
        return currentT;
      }

      function newtonRaphsonIterate(aX, aGuessT) {
        for (var i = 0; i < NEWTON_ITERATIONS; ++i) {
          var currentSlope = getSlope(aGuessT, p1x, p2x);
          if (currentSlope === 0.0) return aGuessT;
          var currentX = calcBezier(aGuessT, p1x, p2x) - aX;
          aGuessT -= currentX / currentSlope;
        }
        return aGuessT;
      }

      function getTForX(aX) {
        var intervalStart = 0.0;
        var currentSample = 1;
        var lastSample = kSplineTableSize - 1;

        for (; currentSample !== lastSample && sampleValues[currentSample] <= aX; ++currentSample) {
          intervalStart += kSampleStepSize;
        }
        --currentSample;

        var dist = (aX - sampleValues[currentSample]) /
          (sampleValues[currentSample + 1] - sampleValues[currentSample]);
        var guessForT = intervalStart + dist * kSampleStepSize;

        var initialSlope = getSlope(guessForT, p1x, p2x);
        if (initialSlope >= NEWTON_MIN_SLOPE) {
          return newtonRaphsonIterate(aX, guessForT);
        }
        if (initialSlope === 0.0) {
          return guessForT;
        }
        return binarySubdivide(aX, intervalStart, intervalStart + kSampleStepSize);
      }

      return function (x) {
        if (p1x === p1y && p2x === p2y) return x;
        if (x === 0 || x === 1) return x;
        return calcBezier(getTForX(x), p1y, p2y);
      };
    }

    function updateProgress(card) {
      if (card.dataset.progressEnabled !== 'true') return;
      var fill = card.querySelector('[data-fdbs-progress-fill]');
      var text = card.querySelector('[data-fdbs-progress-text]');
      if (!fill || !text) return;

      var start = Date.parse(card.dataset.progressStart || '');
      var end = Date.parse(card.dataset.progressEnd || '');
      var min = Number(card.dataset.progressMin || 0);
      var fallback = Number(card.dataset.progressFallback || 0);
      var label = card.dataset.progressLabel || 'Sold';
      var bezier = parseBezier(card.dataset.progressBezier || '');
      var easing = cubicBezier(bezier[0], bezier[1], bezier[2], bezier[3]);
      var percent = fallback;

      if (Number.isFinite(start) && Number.isFinite(end) && end > start) {
        var now = Date.now();
        var t = clamp((now - start) / (end - start), 0, 1);
        percent = easing(t) * 100;
      }

      percent = clamp(percent, min, 100);
      fill.style.width = percent.toFixed(2) + '%';
      text.textContent = Math.round(percent) + '% ' + label;
    }

    function updateAllProgress() {
      root.querySelectorAll('.fd-best__card').forEach(updateProgress);
    }

    function showToast(message) {
      var toast = root.querySelector('.fd-best__toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.className = 'fd-best__toast';
        root.appendChild(toast);
      }
      toast.textContent = message || 'Copied';
      toast.classList.add('is-show');
      clearTimeout(window.__fdBestToastTimer);
      window.__fdBestToastTimer = setTimeout(function () {
        toast.classList.remove('is-show');
      }, 1500);
    }

    root.addEventListener('click', function (event) {
      var copyButton = event.target.closest('[data-fdbs-copy-code]');
      if (copyButton && root.contains(copyButton)) {
        var code = copyButton.getAttribute('data-code') || '';
        if (!code) return;
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(code).then(function () {
            showToast('Copied');
          });
        } else {
          var input = document.createElement('input');
          input.value = code;
          document.body.appendChild(input);
          input.select();
          try {
            document.execCommand('copy');
            showToast('Copied');
          } finally {
            document.body.removeChild(input);
          }
        }
        return;
      }

      var addButton = event.target.closest('[data-fdbs-add-cart]');
      if (addButton && root.contains(addButton)) {
        var addVariantId = addButton.getAttribute('data-variant-id');
        if (!addVariantId) return;
        var addForm = document.createElement('form');
        addForm.method = 'post';
        addForm.action = root.dataset.cartAddUrl || '/cart/add';
        addForm.target = '_blank';
        addForm.style.display = 'none';

        var addIdInput = document.createElement('input');
        addIdInput.type = 'hidden';
        addIdInput.name = 'id';
        addIdInput.value = addVariantId;
        addForm.appendChild(addIdInput);

        var addQuantityInput = document.createElement('input');
        addQuantityInput.type = 'hidden';
        addQuantityInput.name = 'quantity';
        addQuantityInput.value = '1';
        addForm.appendChild(addQuantityInput);

        document.body.appendChild(addForm);
        addForm.submit();
        setTimeout(function () {
          addForm.remove();
        }, 1000);
        return;
      }

      var button = event.target.closest('[data-fdbs-shop-now]');
      if (!button || !root.contains(button)) return;

      var variantId = button.getAttribute('data-variant-id');
      if (!variantId) return;

      var form = document.createElement('form');
      form.method = 'post';
      form.action = root.dataset.cartAddUrl || '/cart/add';
      form.target = '_blank';
      form.style.display = 'none';

      var idInput = document.createElement('input');
      idInput.type = 'hidden';
      idInput.name = 'id';
      idInput.value = variantId;
      form.appendChild(idInput);

      var quantityInput = document.createElement('input');
      quantityInput.type = 'hidden';
      quantityInput.name = 'quantity';
      quantityInput.value = '1';
      form.appendChild(quantityInput);

      var returnToInput = document.createElement('input');
      returnToInput.type = 'hidden';
      returnToInput.name = 'return_to';
      returnToInput.value = root.dataset.checkoutUrl || '/checkout';
      form.appendChild(returnToInput);

      document.body.appendChild(form);
      form.submit();
      setTimeout(function () {
        form.remove();
      }, 1000);
    });

    updateAllProgress();
    setInterval(updateAllProgress, 30000);
  })();
</script>

{% render 'section-decorations', section: section %}

{% schema %}
{
  "name": "FD Best Seller Pro",
  "class": "section-fd-best-seller-pro",
  "settings": [
    { "type": "header", "content": "Header Settings" },
    { "type": "text", "id": "title", "label": "Section Title", "default": "Flash Deals" },
    { "type": "checkbox", "id": "show_title_icons", "label": "Show Title Icons", "default": true },
    { "type": "image_picker", "id": "title_icon", "label": "Title Icon" },
    { "type": "range", "id": "title_icon_size", "min": 20, "max": 100, "step": 2, "unit": "px", "label": "Title Icon Size", "default": 40 },
    { "type": "range", "id": "title_icon_size_mobile", "min": 10, "max": 80, "step": 2, "unit": "px", "label": "Mobile Icon Size", "default": 30 },
    { "type": "checkbox", "id": "title_icon_mirror_right", "label": "Mirror Right Icon", "default": true },
    { "type": "textarea", "id": "sub_heading", "label": "Description", "default": "Celebrate a fresher, cleaner home." },
    { "type": "url", "id": "view_more_link", "label": "View More Link" },
    { "type": "text", "id": "view_more_label", "label": "View More Label", "default": "View More" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#191919" },
    { "type": "color", "id": "sub_heading_color", "label": "Sub Heading Color", "default": "#5c6470" },
    { "type": "checkbox", "id": "show_header_divider", "label": "Show Header Divider", "default": false },
    { "type": "color", "id": "header_divider_color", "label": "Header Divider Color", "default": "#ffffff" },
    { "type": "number", "id": "line_position_top", "label": "Line Position Top (px)", "default": 90 },
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Padding Top", "default": 50 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Padding Bottom", "default": 50 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 80, "step": 2, "unit": "px", "label": "Padding Top Mobile", "default": 28 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 80, "step": 2, "unit": "px", "label": "Padding Bottom Mobile", "default": 38 },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f4f8ff" },
    { "type": "color", "id": "primary_color", "label": "Primary Color", "default": "#10b7d7" },
    { "type": "range", "id": "description_image_width", "min": 80, "max": 500, "step": 10, "unit": "px", "label": "Description Image Width", "default": 220 },
    { "type": "range", "id": "description_image_width_mobile", "min": 60, "max": 360, "step": 10, "unit": "px", "label": "Description Image Width Mobile", "default": 180 }
  ],
  "blocks": [
    {
      "type": "count-down",
      "name": "Countdown",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "end_date", "label": "End date", "info": "YYYY-MM-DD HH:MM:SS", "default": "2026-12-31 23:59:59" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "text", "id": "message", "label": "Message" },
        { "type": "checkbox", "id": "hide_on_complete", "label": "Hide when finished", "default": false },
        { "type": "checkbox", "id": "show_days", "label": "Show days", "default": true },
