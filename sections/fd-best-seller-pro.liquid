              color_mobile: block.settings.discount_badge_color_mobile,
              background_image_mobile: block.settings.discount_badge_bg_image_mobile,
              width: block.settings.discount_badge_width,
              height: block.settings.discount_badge_height,
              width_mobile: block.settings.discount_badge_width_mobile,
              height_mobile: block.settings.discount_badge_height_mobile,
              font_size: block.settings.discount_badge_font_size,
              font_size_mobile: block.settings.discount_badge_font_size_mobile,
              top: block.settings.discount_badge_top,
              left: block.settings.discount_badge_left,
              top_mobile: block.settings.discount_badge_top_mobile,
              left_mobile: block.settings.discount_badge_left_mobile,
              text_top: block.settings.discount_badge_text_top,
              text_left: block.settings.discount_badge_text_left,
