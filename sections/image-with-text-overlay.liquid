{{- 'image-with-text-overlay.css' | asset_url | stylesheet_tag -}}
{%- liquid
  assign full_width = section.settings.full_width
  assign image = section.settings.image
  assign mobile_image = section.settings.mobile_image
  assign image_parallax = section.settings.image_parallax
  assign desktop_height = section.settings.desktop_height
  assign mobile_height = section.settings.mobile_height

  assign content_width = section.settings.content_width
  assign content_position = section.settings.content_position
  assign text_alignment = section.settings.text_alignment

  assign text_color = section.settings.text_color
  assign overlay_color = section.settings.overlay_color
  assign overlay_opacity = section.settings.overlay_opacity

  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing

  case mobile_height
    when 'mobile-height-350'
      assign mobile_image_height = 350
    when 'mobile-height-400'
      assign mobile_image_height = 400
    when 'mobile-height-450'
      assign mobile_image_height = 450
    when 'mobile-height-500'
      assign mobile_image_height = 500
    else
      assign mobile_image_height = 900
  endcase

  assign priority = false
  assign heading_tag = 'h3'
  if section.index == 1
    assign priority = 'high'
    assign heading_tag = 'h1'
  endif
-%}
<div class="row {% if full_width %}full-width-row-full{% endif %}">
  <div class="small-12 columns">
    <image-with-text-overlay
      class="image-with-text-overlay image-with-text-overlay--full-width-{{ full_width }} text-{{ text_alignment }} {{ mobile_height }} {{ desktop_height }} section-spacing{% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}"
      style="--text-color: {{ text_color }}; --overlay-color-rgb: {{ overlay_color.rgb | replace: ' ' , ',' }}; --overlay-opacity: {{ overlay_opacity | divided_by: 100.0 }}"
    >
      <div class="image-with-text-overlay--bg parallax--{{ image_parallax }}">
        {% if image %}
          {%- liquid
            assign small_width = image.src.height | times: '375' | divided_by: image.src.width
            assign master_width = image.src.width | append: 'x' | append: image.src.height
            assign width = '375x' | append: small_width | append: ',' | append: master_width

            assign class = ''
            if image_parallax
              assign class = 'thb-parallax-image'
            endif

            if mobile_image
              assign class = class | append: ' image-with-text-overlay--desktop'
            endif
          -%}
          {%- render 'responsive-image', image: image, sizes: width, class: class, priority: priority -%}
        {% else %}
          {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder_svg_tag' }}
        {% endif %}
        {%- if mobile_image -%}
          {%- liquid
            assign image = mobile_image
            assign master_width = image.src.width | append: 'x' | append: image.src.height
            assign width = '375x' | append: mobile_image_height | append: ',' | append: master_width

            assign class = ''
            if image_parallax
              assign class = 'thb-parallax-image'
            endif

            assign class = class | append: ' image-with-text-overlay--mobile'
            render 'responsive-image', image: image, sizes: width, class: class, priority: priority
          -%}
        {%- endif -%}
      </div>

      <div class="image-with-text-overlay--content content-{{ content_position }}">
        <div class="image-with-text-overlay--content-inner content-width-{{ content_width }}">
          {% for block in section.blocks %}
            {%- case block.type -%}
              {%- when 'badge' -%}
                <div {{ block.shopify_attributes }}>
                  <span
                    class="inline-badge"
                    style="--badge-bg: {{ block.settings.color_bg }};--badge-text: {{ block.settings.color_text }}"
                  >
                    {{- block.settings.text -}}
                  </span>
                </div>
              {%- when 'subheading' -%}
                <p class="subheading" {{ block.shopify_attributes }}>{{ block.settings.text }}</p>
              {%- when 'heading' -%}
                {%- liquid
                  if block.settings.heading_tag != 'adaptive'
                    assign heading_tag = block.settings.heading_tag
                  endif
                -%}
                <{{ heading_tag }}
                  class="{{ block.settings.heading_size }} image-with-text-overlay--heading"
                  style="{% if block.settings.desktop_font_size != blank %}--heading-desktop-font-size: {{ block.settings.desktop_font_size }}px;{% endif %}{% if block.settings.mobile_font_size != blank %}--heading-mobile-font-size: {{ block.settings.mobile_font_size }}px;{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text | newline_to_br -}}
                </{{ heading_tag }}>
              {%- when 'text' -%}
                <div
                  class="rte description-size--{{ block.settings.description_size }}"
                  style="{% if block.settings.desktop_font_size != blank %}--text-desktop-font-size: {{ block.settings.desktop_font_size }}px;{% endif %}{% if block.settings.mobile_font_size != blank %}--text-mobile-font-size: {{ block.settings.mobile_font_size }}px;{% endif %}"
                  {{ block.shopify_attributes }}
                >
                  {{ block.settings.text }}
                </div>
              {%- when 'button' -%}
                {% if block.settings.button_text != blank %}
                  <a
                    class="button {{ block.settings.button_color }}"
                    href="{{ block.settings.button_link }}"
                    role="button"
                    title="{{ block.settings.button_text | escape }}"
                    {{ block.shopify_attributes }}
                  >
                    {{- block.settings.button_text -}}
                  </a>
                {% endif %}
              {%- when 'newsletter' -%}
                <div
                  class="image-with-text-overlay--newsletter"
                  style="--newsletter-desktop-offset-x: {{ block.settings.desktop_offset_x | default: 0 }}px; --newsletter-desktop-offset-y: {{ block.settings.desktop_offset_y | default: 0 }}px; --newsletter-accent-color: {{ block.settings.btn_bg_color }};"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.title != blank -%}
                    <h4 class="newsletter-title">{{ block.settings.title }}</h4>
                  {%- endif -%}
                  {%- form 'customer', class: 'newsletter-form' -%}
                    <input type="hidden" name="contact[tags]" value="newsletter">
                    <div class="newsletter-form__field-wrapper">
                      <div class="field">
                        <input
                          id="NewsletterForm--{{ section.id }}"
                          type="email"
                          name="contact[email]"
                          class="field__input"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          capitalize="off"
                          autocomplete="email"
                          {% if form.errors %}
                            autofocus
                            aria-invalid="true"
                            aria-describedby="Newsletter-error--{{ section.id }}"
                          {% elsif form.posted_successfully? %}
                            aria-describedby="Newsletter-success--{{ section.id }}"
                          {% endif %}
                          placeholder="{{ block.settings.placeholder }}"
                          required
                        >
                        <button
                           type="submit"
                           class="newsletter-form__button"
                           name="commit"
                           id="Subscribe"
                           aria-label="{{ 'newsletter.button_label' | t }}"
                           style="background-color: {{ block.settings.btn_bg_color }}; color: {{ block.settings.btn_text_color }};"
                         >
                           <span class="button-text">{{ block.settings.button_text }}</span>
                           <div class="loading-overlay__spinner hidden">
                             <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                               <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                             </svg>
                           </div>
                         </button>
                       </div>
                       {%- if form.errors -%}
                         <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                           {{- form.errors.translated_fields.email | capitalize }}
                           {{ form.errors.messages.email -}}
                         </small>
                       {%- endif -%} 
                     </div>
                     {%- if form.posted_successfully? -%}
                       <h3
                         class="newsletter-form__message newsletter-form__message--success form__message header_sub_success_text"
                         id="Newsletter-success--{{ section.id }}"
                         tabindex="-1"
                         autofocus 
                       >
                         {{- 'newsletter.success' | t -}}
                       </h3>
                     {%- endif -%}
                     {%- if block.settings.agreement_text != blank -%}
                       <div class="newsletter-agreement">
                         <label class="agreement-checkbox">
                           <input type="checkbox" class="newsletter-checkbox">
                           <span class="checkmark"></span>
                           <div class="agreement-text">{{ block.settings.agreement_text }}</div>
                         </label>
                       </div>
                     {%- endif -%}
                   {%- endform -%}
                 </div>
              {% when 'space' %}
                <div style="height: {{ block.settings.height | append: 'px' }}" {{ block.shopify_attributes }}></div>
            {%- endcase -%}
          {% endfor %}
        </div>
      </div>
    </image-with-text-overlay>
  </div>
</div>
<script src="{{ 'image-with-text-overlay.js' | asset_url }}" defer="defer"></script>

<style>
  @media only screen and (min-width: 768px) {
    #shopify-section-{{ section.id }} .image-with-text-overlay--heading[style*="--heading-desktop-font-size"] {
      font-size: var(--heading-desktop-font-size);
      line-height: 1.4;
    }
    #shopify-section-{{ section.id }} .rte[style*="--text-desktop-font-size"] {
      font-size: var(--text-desktop-font-size);
      line-height: 1.4;
    }
  }
  @media only screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .image-with-text-overlay--heading[style*="--heading-mobile-font-size"] {
      font-size: var(--heading-mobile-font-size);
      line-height: 1.4;
    }
    #shopify-section-{{ section.id }} .rte[style*="--text-mobile-font-size"] {
      font-size: var(--text-mobile-font-size);
      line-height: 1.4;
    }
  }
  .image-with-text-overlay--newsletter {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(10px);
    padding: 20px;
    border-radius: 20px;
    max-width: 500px;
    /* margin: 0 auto; */
    text-align: left;
  }
  @media only screen and (min-width: 769px) {
    #shopify-section-{{ section.id }} .image-with-text-overlay--newsletter {
      transform: translate(var(--newsletter-desktop-offset-x, 0px), var(--newsletter-desktop-offset-y, 0px));
    }
  }
  .image-with-text-overlay--newsletter .newsletter-title {
    margin: 0 0 20px 0;
    font-size: 18px;
    font-weight: 600;
    color: #333;
  }
  .image-with-text-overlay--newsletter .newsletter-form__field-wrapper .field {
    display: flex;
    background: #fff;
    border-radius: 30px;
    overflow: hidden;
    border: 1px solid #e5e5e5;
    height: 50px;
    min-width: 0;
  }
  .image-with-text-overlay--newsletter .field__input {
    flex: 1 1 auto;
    min-width: 0;
    width: auto;
    border: none !important;
    padding: 0 20px;
    height: 100%;
    outline: none;
    box-shadow: none !important;
    background: transparent;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button {
    border-radius: 0 30px 30px 0;
    border: none;
    padding: 0 30px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    height: 100%;
    transition: opacity 0.3s;
    margin: 0;
    flex: 0 0 auto;
    min-width: max-content;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button:hover {
    opacity: 0.9;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button .loading-overlay__spinner {
    width: 20px;
    height: 20px;
    display: inline-block;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button .loading-overlay__spinner.hidden {
    display: none;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button .spinner {
    animation: rotator 1.4s linear infinite;
    width: 100%;
    height: 100%;
  }
  @keyframes rotator {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(270deg); }
  }
  .image-with-text-overlay--newsletter .newsletter-form__button .path {
    stroke-dasharray: 187;
    stroke-dashoffset: 0;
    transform-origin: center;
    animation: dash 1.4s ease-in-out infinite, colors 5.6s ease-in-out infinite;
    stroke: currentColor;
  }
  @keyframes colors {
    0% { stroke: currentColor; }
    25% { stroke: currentColor; }
    50% { stroke: currentColor; }
    75% { stroke: currentColor; }
    100% { stroke: currentColor; }
  }
  @keyframes dash {
    0% { stroke-dashoffset: 187; }
    50% {
      stroke-dashoffset: 46.75;
      transform: rotate(135deg);
    }
    100% {
      stroke-dashoffset: 187;
      transform: rotate(450deg);
    }
  }
  .image-with-text-overlay--newsletter .newsletter-agreement {
    margin-top: 20px;
  }
  .image-with-text-overlay--newsletter .agreement-checkbox {
    display: flex;
    align-items: center;
    cursor: pointer;
    font-size: 14px;
    color: #333;
    gap: 10px;
    position: relative;
  }
  .image-with-text-overlay--newsletter .agreement-checkbox.has-error .checkmark {
    border-color: #ff0000;
  }
  .image-with-text-overlay--newsletter .agreement-checkbox input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
    height: 0;
    width: 0;
  }
  .image-with-text-overlay--newsletter .checkmark {
    width: 20px;
    height: 20px;
    background-color: #fff;
    border: 2px solid var(--newsletter-accent-color, #00D0CD);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background-color 0.2s;
  }
  .image-with-text-overlay--newsletter .agreement-checkbox input:checked ~ .checkmark {
    background-color: var(--newsletter-accent-color, #00D0CD);
  }
  .image-with-text-overlay--newsletter .checkmark:after {
    content: "";
    display: none;
    width: 5px;
    height: 10px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
    margin-bottom: 2px;
  }
  .image-with-text-overlay--newsletter .agreement-checkbox input:checked ~ .checkmark:after {
    display: block;
  }
  .image-with-text-overlay--newsletter .agreement-text {
    line-height: 1.4;
  }
  .image-with-text-overlay--newsletter .agreement-text p {
    margin: 0;
  }
  .image-with-text-overlay--newsletter .agreement-text a {
     color: inherit;
     text-decoration: underline;
   }
   .header_sub_success_text{
    font-size: 20px;
    outline: none!important;
   }
 
@media (max-width: 768px) {
     .header_sub_success_text{
    font-size: 12px;
   }
  #shopify-section-{{ section.id }} .image-with-text-overlay:has(.image-with-text-overlay--newsletter) .image-with-text-overlay--content {
    position: absolute;
    inset: 0;
    display: block;
    max-width: none;
    height: 100%;
    padding: 0 15px;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .image-with-text-overlay:has(.image-with-text-overlay--newsletter) .image-with-text-overlay--content-inner {
    position: static !important;
    max-width: none;
    height: 100%;
    pointer-events: none;
  }
	.image-with-text-overlay--newsletter{
		display: none;
    position: absolute;
    left: 50%;
    bottom: 10px;
    z-index: 6;
    width: calc(100% - 28px);
    max-width: 414px;
    padding: 10px;
    border-radius: 10px;
    transform: translateX(-50%);
    pointer-events: auto;
	}
  .image-with-text-overlay--newsletter .newsletter-title {
    margin-bottom: 12px;
    font-size: 16px;
    line-height: 1.25;
  }
  .image-with-text-overlay--newsletter .newsletter-form__field-wrapper .field {
    height: 40px;
  }
  .image-with-text-overlay--newsletter .field__input {
    min-height: 40px;
    padding: 0 16px;
    font-size: 14px;
  }
  .image-with-text-overlay--newsletter .newsletter-form__button {
    height: 40px;
    padding: 0 12px;
    font-size: 12px;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    white-space: nowrap;
  }
  .image-with-text-overlay--newsletter .newsletter-agreement {
    margin-top: 12px;
  }
  .image-with-text-overlay--newsletter .agreement-checkbox {
    gap: 8px;
    font-size: 9px;
    line-height: 1.3;
  }
  .image-with-text-overlay--newsletter .checkmark {
    width: 18px;
    height: 18px;
    border-radius: 4px;
  }
}
 </style>

 <script>
   document.addEventListener('DOMContentLoaded', function() {
     const newsletterForms = document.querySelectorAll('.newsletter-form');
     
     newsletterForms.forEach(form => {
       const checkbox = form.querySelector('.newsletter-checkbox');
       const agreementLabel = form.querySelector('.agreement-checkbox');
       const submitBtn = form.querySelector('.newsletter-form__button');
       const btnText = submitBtn.querySelector('.button-text');
       const spinner = submitBtn.querySelector('.loading-overlay__spinner');
       
       form.addEventListener('submit', function(e) {
         // 校验复选框
         if (checkbox && !checkbox.checked) {
           e.preventDefault();
           e.stopImmediatePropagation();
           if (agreementLabel) {
             agreementLabel.classList.add('has-error');
           }
           return false;
         }
         
         // 显示 loading 状态
         if (submitBtn) {
           submitBtn.setAttribute('disabled', 'disabled');
           if (btnText) btnText.classList.add('hidden');
           if (spinner) spinner.classList.remove('hidden');
         }
       }, true); // 使用捕获阶段确保优先执行
       
       // 当复选框状态改变时移除错误样式
       if (checkbox) {
         checkbox.addEventListener('change', function() {
           if (this.checked && agreementLabel) {
             agreementLabel.classList.remove('has-error');
           }
         });
       }
     });
   });
 </script>

 {% schema %}
{
  "name": "Image with text overlay",
"class": "section-image-with-text-overlay",
  "settings": [
	{
		"type": "image_picker",
		"id": "image",
		"label": "Image",
		"info": "2800 x 650 .jpg recommended."
	},
	{
		"type": "image_picker",
		"id": "mobile_image",
		"label": "Mobile image (optional)",
		"info": "375 x 650 .jpg recommended."
	},
	{
		"type": "checkbox",
		"id": "image_parallax",
		"default": false,
		"label": "Enable parallax",
		"info": "Animations must be enabled in theme settings"
	},
	{
		"type": "select",
		"id": "desktop_height",
		"label": "Desktop height",
		"options": [
			{
				"value": "desktop-height-450",
				"label": "450px"
			},
			{
				"value": "desktop-height-550",
				"label": "550px"
			},
			{
				"value": "desktop-height-650",
				"label": "650px"
			},
			{
				"value": "desktop-height-750",
				"label": "750px"
			},
			{
				"value": "desktop-height-full",
				"label": "Full screen"
			}
		],
		"default": "desktop-height-650"
	},
	{
		"type": "select",
		"id": "mobile_height",
		"label": "Mobile height",
		"options": [
			{
				"value": "mobile-height-auto",
				"label": "Adapt to content"
			},
			{
				"value": "mobile-height-350",
				"label": "350px"
			},
			{
				"value": "mobile-height-400",
				"label": "400px"
			},
			{
				"value": "mobile-height-450",
				"label": "450px"
			},
			{
				"value": "mobile-height-500",
				"label": "500px"
			},
			{
				"value": "mobile-height-full",
				"label": "Full screen"
			}
		],
		"default": "mobile-height-500"
	},
	{
		"type": "checkbox",
		"id": "full_width",
		"label": "Make section full width",
		"default": true
	},
	{
		"type": "select",
		"id": "content_width",
		"label": "Content width",
		"options": [
			{
				"value": "small",
				"label": "Small"
			},
			{
				"value": "medium",
				"label": "Medium"
			},
			{
				"value": "large",
				"label": "Large"
			}
		],
		"default": "medium"
	},
	{
		 "type": "select",
		 "id": "content_position",
		 "label": "Content position",
		 "options": [
			 { "value": "top-left", "label": "Top left" },
			 { "value": "top-center", "label": "Top center" },
			 { "value": "top-right", "label": "Top right" },
			 { "value": "middle-left", "label": "Middle left" },
			 { "value": "middle-center", "label": "Middle center" },
			 { "value": "middle-right", "label": "Middle right" },
			 { "value": "bottom-left", "label": "Bottom left" },
			 { "value": "bottom-center", "label": "Bottom center" },
			 { "value": "bottom-right", "label": "Bottom right" }
		 ],
		 "default": "bottom-center"
	},
	{
		"type": "select",
		"id": "text_alignment",
		"options": [
			{
				"value": "left",
				"label": "Left"
			},
			{
				"value": "center",
				"label": "Center"
			},
			{
				"value": "right",
				"label": "Right"
			}
		],
		"default": "center",
		"label": "Content alignment"
	},
	{
     "type": "header",
     "content": "Colors"
   },
	{
		"type": "color",
		"id": "text_color",
		"label": "Text",
		"default": "#FFFFFF"
	},
	{
		"type": "color",
		"id": "overlay_color",
		"label": "Overlay",
		"default": "#000000"
	},
	{
		"type": "range",
		"id": "overlay_opacity",
		"min": 0,
		"max": 100,
		"step": 1,
		"unit": "%",
		"label": "Overlay opacity",
		"default": 30
	},
	{
     "type": "header",
     "content": "Spacing"
   },
	{
		"type": "checkbox",
		"id": "disable_top_spacing",
		"default": false,
		"label": "Remove top spacing"
	},
	{
		"type": "checkbox",
		"id": "disable_bottom_spacing",
		"default": false,
		"label": "Remove bottom spacing"
	}
  ],
  "blocks": [
	{
		"type": "badge",
		"name": "Badge",
		"limit": 1,
		"settings": [
			{
				"type": "text",
				"id": "text",
				"label": "Text",
				"default": "Badge heading"
			},
			{
				"type": "color",
				"id": "color_bg",
				"label": "Background",
				"default": "#3f72e5"
			},
			{
				"type": "color",
				"id": "color_text",
				"label": "Text",
				"default": "#ffffff"
			}
		]
	},
	{
		"type": "subheading",
		"name": "Subheading",
		"limit": 1,
		"settings": [
			{
