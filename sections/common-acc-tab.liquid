    }

    #common-acc-tab-{{ section.id }} .common-acc-tab__banner-title {
      margin-bottom: calc(var(--banner-mobile-title-margin-bottom, var(--banner-title-margin-bottom, 10)) * var(--vp-s));
      font-size: calc(var(--banner-mobile-title-size, 28) * var(--vp-s));
      line-height: calc(var(--banner-mobile-title-line-height, 34) * var(--vp-s));
    }

    #common-acc-tab-{{ section.id }} .common-acc-tab__banner-subtitle {
      font-size: calc(var(--banner-mobile-subtitle-size, 18) * var(--vp-s));
      line-height: calc(var(--banner-mobile-subtitle-line-height, 26) * var(--vp-s));
    }

    #common-acc-tab-{{ section.id }} .common-acc-tab__banner-points {
      width: 100%;
