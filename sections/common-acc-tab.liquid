                          {% else %}
                            {{ 'product-1' | placeholder_svg_tag }}
                          {% endif %}
                        </a>
                      </div>
 
                      <h3 class="card-title"><a href="{{ product.url }}" target="_blank" rel="noopener">{{ title }}</a></h3>

                      <div class="sp-card-footer">
                        <div class="sp-card-prices">
                          <span class="current-price">{{ price }}</span>
                          {% if compare_price != blank %}
                            <span class="original-price">{{ compare_price }}</span>
                          {% endif %}
                        </div>
                        
                        <div class="sp-card-actions">
                          <form method="post" action="/cart/add" target="_blank">
                            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                            <input type="hidden" name="quantity" value="1">
                            <input type="hidden" name="return_to" value="/cart">
                            <button type="submit" class="sp-btn sp-btn--cart">{{ section.settings.add_to_cart_label | default: 'Add to Cart' }}</button>
                          </form>
                          <a class="sp-btn sp-btn--shop" href="{{ product.url }}" target="_blank" rel="noopener">{{ section.settings.shop_now_label | default: 'Shop Now' }}</a>
                        </div>
                      </div>
                    </div>
                  {% endfor %}
                  
                {% else %}
                  {% comment %} Block Logic {% endcomment %}
                  {% for block in section.blocks %}
                    {% if block.type == 'product_card' %}
                      {% assign tab_group = block.settings.tab_group | plus: 0 %}
                    {% endif %}
                    {% if block.type == 'product_card' and tab_group == i %}
                      {% assign visible_count = visible_count | plus: 1 %} 
                      {% assign product = block.settings.product %}
                      {% assign title = block.settings.title | default: product.title %}
                      {% assign image = block.settings.image | default: product.featured_image %}
                      {% assign price = block.settings.custom_price | default: product.price | money %}
                      {% assign compare_price = block.settings.custom_compare_price %}
                      {% if compare_price == blank and product.compare_at_price > product.price %}
                          {% assign compare_price = product.compare_at_price | money %}
                      {% endif %}
                      
                      {% assign gift_image = block.settings.gift_image | default: block.settings.gift_product.featured_image %}
                      {% assign gift_compare_price = block.settings.gift_compare_price %}
                      {% if gift_compare_price == blank and product.compare_at_price > product.price %}
                        {% assign gift_compare_price = product.compare_at_price | money %}
                      {% endif %}
                      
                      <div class="acc-tab-card {% if visible_count > 6 %}extra-card{% endif %}" {{ block.shopify_attributes }}>
                      {% assign card_badge_text = block.settings.badge_text %}
                      {% assign card_badge_suffix = section.settings.badge_suffix %}
                      {% if card_badge_text == blank and product.compare_at_price > product.price %}
                        {% assign discount_percentage = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                        {% assign card_badge_text = discount_percentage | append: '%' %}
                      {% endif %}
                      {% render 'common-badge',
                        product: product,
                        text: card_badge_text,
                        off_text: card_badge_suffix,
                        split: true,
                        background: 'transparent',
                        background_mobile: 'transparent',
                        color: section.settings.badge_text_color,
                        color_mobile: section.settings.badge_mobile_text_color,
                        background_image: section.settings.badge_bg,
                        background_image_mobile: section.settings.badge_mobile_bg,
                        width: section.settings.badge_width,
                        height: section.settings.badge_height,
                        width_mobile: section.settings.badge_mobile_width,
                        height_mobile: section.settings.badge_mobile_height,
                        top: section.settings.badge_top,
                        left: section.settings.badge_left,
                        top_mobile: section.settings.badge_mobile_top,
                        left_mobile: section.settings.badge_mobile_left,
                        text_top: section.settings.badge_text_top,
                        text_left: section.settings.badge_text_left,
                        text_top_mobile: section.settings.badge_mobile_text_top,
                        text_left_mobile: section.settings.badge_mobile_text_left
                      %}
                        
                        <div class="card-image-wrapper">
                          {% if image != blank %}
                            <a href="{{ product.url }}" target="_blank" style="width: 100%;height:100%">
                              <img class="card-image" src="{{ image | image_url: width: 600 }}" loading="lazy" alt="{{ title | escape }}">
                            </a>
                          {% else %}
                            {{ 'product-1' | placeholder_svg_tag }}
                          {% endif %}
                        </div>

                        {% if block.settings.gift_product.id != blank %}
                          {% assign gift_ribbon_text = block.settings.gift_ribbon_text | default: section.settings.gift_ribbon_text %}
                          <div class="gift-banner">
                            {% if gift_ribbon_text != blank %}
                              <div class="gift-ribbon">{{ gift_ribbon_text | escape }}</div>
                            {% endif %}
                            <div class="gift-content">
                              <div class="gift-image-container">
                                {% if gift_image != blank %}
                                  <img src="{{ gift_image | image_url: width: 120 }}" loading="lazy" alt="{{ block.settings.gift_title | escape }}">
                                {% elsif block.settings.custom_banner != blank %}
                                  <img src="{{ block.settings.custom_banner | image_url: width: 120 }}" loading="lazy" alt="Gift">
                                {% else %}
                                  {{ 'product-1' | placeholder_svg_tag }}
                                {% endif %}
                              </div>
                              <div class="gift-info">
                                <div class="gift-title">{{ block.settings.gift_title | default: block.settings.gift_product.title }}</div>
                                <div class="gift-price-row">
                                  <span class="gift-price">{{ block.settings.gift_price | default: block.settings.gift_product.price | money }}</span>
                                  {% if gift_compare_price != blank %}
                                    <span class="gift-compare-price">{{ gift_compare_price | default: block.settings.gift_product.compare_at_price | money }}</span>
                                  {% endif %}
                                </div>
                              </div>
                              <div class="gift-plus">+1</div>
                            </div>
                          </div>
                        {% elsif block.settings.custom_banner != blank %}
                          <div class="custom-banner">
                            <img src="{{ block.settings.custom_banner | image_url: width: 400 }}" loading="lazy" alt="Banner">
                          </div>
                        {% endif %}

                        <h3 class="card-title"><a href="{{ product.url }}" target="_blank" rel="noopener">{{ title }}</a></h3>

                        <div class="sp-card-footer">
                          <div class="sp-card-prices">
                            <span class="current-price">{{ price }}</span>
                            {% if compare_price != blank %}
                              <span class="original-price">{{ compare_price }}</span>
                            {% endif %}
                          </div>
                          
                          <div class="sp-card-actions">
                            {% if block.settings.add_gift_enabled %}
                              {% assign gift_variant_id_fallback = block.settings.gift_product.selected_or_first_available_variant.id %}
                              {% assign gift_variant_id = block.settings.gift_variant_id | default: gift_variant_id_fallback %}
                              <button 
                                type="button" 
                                class="sp-btn sp-btn--cart sp-btn--bundle" 
                                data-main-id="{{ product.selected_or_first_available_variant.id }}" 
                                data-gift-id="{{ gift_variant_id }}"
                                onclick="spAddBundle(this)"
                              >
                                {{ block.settings.add_to_cart_text }}
                              </button>
                            {% else %}
                               <form method="post" action="/cart/add" target="_blank">
                                <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                                <input type="hidden" name="quantity" value="1">
                                <input type="hidden" name="return_to" value="/cart">
                                <button type="submit" class="sp-btn sp-btn--cart">{{ block.settings.add_to_cart_text | default: 'Add to Cart' }}</button>
                              </form>
                            {% endif %} 
                            {% assign gift_variant_id_calc = nil %}
                            {% if block.settings.gift_product.id != blank %}
                              {% assign gift_variant_id_calc = block.settings.gift_variant_id | default: block.settings.gift_product.selected_or_first_available_variant.id %}
                            {% endif %}
                            {% if block.settings.btn_link != blank %}
