      padding: calc(var(--banner-mobile-padding-top, 42) * var(--vp-s)) calc(var(--banner-mobile-padding-right, 24) * var(--vp-s)) calc(var(--banner-mobile-padding-bottom, 102) * var(--vp-s)) calc(var(--banner-mobile-padding-left, 24) * var(--vp-s));
    }

    #common-acc-tab-{{ section.id }} .common-acc-tab__banner-content {
