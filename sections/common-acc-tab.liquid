{% comment %} vd - tab section {% endcomment %}

<style>
  #common-acc-tab-{{ section.id }} {
    --vp-s: 1px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
  }

  @media screen and (min-width: 850px) and (max-width: 1500px) {
    #common-acc-tab-{{ section.id }} {
      --vp-s: calc(100vw / 1500);
    }
  }

  @media screen and (max-width: 849px) {
    #common-acc-tab-{{ section.id }} {
      --vp-s: calc(100vw / 375);
    }
  }

  .common-acc-tab-section{
      overflow: hidden;
    }
  #common-acc-tab-{{ section.id }} .acc-tab-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
  }
  
  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner {
    width: 100%;
    max-width: 1170px;
    margin: 0 auto 40px;
    border-radius: 4px;
    overflow: hidden;
    background-color: #081844;
    background-image: var(--top-banner-desktop);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: #fff;
    aspect-ratio: var(--top-banner-aspect-ratio, 1170 / 205);
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-inner {
    min-height: 100%;
    padding: 42px 48px;
    display: flex;
    align-items: center;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-compare {
    width: min(420px, 52%);
    text-align: center;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-title {
    font-size: 32px;
    line-height: 1.25;
    font-weight: 500;
    margin-bottom: 16px;
    color: var(--top-banner-title-color, #fff);
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-cols {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 26px;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-qty,
  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-save {
    font-size: 35px;
    line-height: 1.2;
    font-weight: 800;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-save {
    color: #00d8d8;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__top-banner-divider {
    width: 1px;
    height: 68px;
    background: rgba(255,255,255,.35);
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner {
    width: 100%;
    max-width: calc(1170 * var(--vp-s));
    min-height: calc(var(--banner-height, 385) * var(--vp-s));
    margin: 0 auto calc(var(--banner-margin-bottom, 40) * var(--vp-s));
    border-radius: calc(var(--banner-radius, 8) * var(--vp-s));
    overflow: hidden;
    position: relative;
    background-color: var(--banner-bg-color, #f7d4ad);
    background-image: var(--banner-desktop);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: var(--banner-text-color, #1f2329);
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-inner {
    min-height: calc(var(--banner-height, 385) * var(--vp-s));
    padding: calc(var(--banner-padding-top, 118) * var(--vp-s)) calc(var(--banner-padding-right, 50) * var(--vp-s)) calc(var(--banner-padding-bottom, 28) * var(--vp-s)) calc(var(--banner-padding-left, 50) * var(--vp-s));
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-content {
    max-width: calc(480 * var(--vp-s));
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-title {
    margin: 0 0 calc(var(--banner-title-margin-bottom, 14) * var(--vp-s));
    color: var(--banner-title-color, currentColor);
    font-size: calc(var(--banner-title-size, 34) * var(--vp-s));
    line-height: calc(var(--banner-title-line-height, 42) * var(--vp-s));
    font-weight: 800;
    white-space: pre-line;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-subtitle {
    margin: 0;
    color: var(--banner-subtitle-color, #5a6470);
    font-size: calc(var(--banner-subtitle-size, 24) * var(--vp-s));
    line-height: calc(var(--banner-subtitle-line-height, 32) * var(--vp-s));
    font-weight: 400;
    white-space: pre-line;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-points {
    position: absolute;
    left: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    gap: calc(var(--banner-point-gap, 48) * var(--vp-s));
    min-width: calc(645 * var(--vp-s));
    max-width: 100%;
    padding: calc(18 * var(--vp-s)) calc(42 * var(--vp-s));
    border-radius: 0 calc(5 * var(--vp-s)) 0 0;
    background: var(--banner-points-bg, rgba(58, 44, 33, 0.58));
    color: var(--banner-points-color, #ffffff);
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-point {
    display: inline-flex;
    align-items: center;
    gap: calc(13 * var(--vp-s));
    min-width: 0;
    color: inherit;
    font-size: calc(var(--banner-point-size, 14) * var(--vp-s));
    line-height: calc(var(--banner-point-line-height, 20) * var(--vp-s));
    font-weight: 700;
    white-space: nowrap;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-point-icon {
    width: calc(48 * var(--vp-s));
    height: calc(48 * var(--vp-s));
    border: calc(2 * var(--vp-s)) solid currentColor;
    border-radius: 50%;
    flex: 0 0 auto;
    position: relative;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__banner-point-icon::before {
    content: '';
    position: absolute;
    width: calc(16 * var(--vp-s));
    height: calc(16 * var(--vp-s));
    border-right: calc(3 * var(--vp-s)) solid currentColor;
    border-bottom: calc(3 * var(--vp-s)) solid currentColor;
    top: calc(12 * var(--vp-s));
    left: calc(14 * var(--vp-s));
    transform: rotate(45deg);
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-banner {
    width: 100%;
    max-width: calc(1170 * var(--vp-s));
    min-height: calc(var(--coupon-height, 257) * var(--vp-s));
    margin: 0 auto calc(var(--coupon-margin-bottom, 40) * var(--vp-s));
    border-radius: calc(var(--coupon-radius, 5) * var(--vp-s));
    overflow: hidden;
    position: relative;
    background-color: var(--coupon-bg-color, #d7651d);
    background-image: var(--coupon-desktop);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-inner {
    min-height: calc(var(--coupon-height, 257) * var(--vp-s));
    padding: calc(var(--coupon-padding-top, 56) * var(--vp-s)) calc(var(--coupon-padding-right, 50) * var(--vp-s)) calc(var(--coupon-padding-bottom, 34) * var(--vp-s)) calc(var(--coupon-padding-left, 48) * var(--vp-s));
    display: flex;
    align-items: flex-end;
    gap: calc(var(--coupon-gap, 18) * var(--vp-s));
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-card {
    min-height: calc(118 * var(--vp-s));
    border: 0;
    border-radius: calc(27 * var(--vp-s));
    background: #ffffff;
    color: var(--coupon-text-color, #555555);
    box-shadow: 0 calc(2 * var(--vp-s)) calc(8 * var(--vp-s)) rgba(146, 65, 11, 0.12);
    position: relative;
    overflow: hidden;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-card::before {
    content: '';
    position: absolute;
    inset: calc(6 * var(--vp-s));
    border: calc(1 * var(--vp-s)) solid rgba(224, 128, 48, 0.5);
    border-radius: calc(18 * var(--vp-s));
    pointer-events: none;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-card--small {
    width: calc(220 * var(--vp-s));
    min-height: calc(150 * var(--vp-s));
    padding: calc(24 * var(--vp-s)) calc(24 * var(--vp-s)) calc(22 * var(--vp-s));
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-card--claim {
    width: calc(300 * var(--vp-s));
    min-height: calc(186 * var(--vp-s));
    padding: calc(28 * var(--vp-s)) calc(40 * var(--vp-s)) calc(28 * var(--vp-s));
    text-align: center;
    background-image: var(--coupon-claim-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-card-content {
    position: relative;
    z-index: 1;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-primary {
    font-size: calc(var(--coupon-primary-size, 24) * var(--vp-s));
    line-height: calc(var(--coupon-primary-line-height, 30) * var(--vp-s));
    font-weight: 400;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-accent {
    color: var(--coupon-accent-color, #ff9d2e);
    font-size: calc(var(--coupon-accent-size, 22) * var(--vp-s));
    line-height: calc(var(--coupon-accent-line-height, 28) * var(--vp-s));
    font-weight: 800;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-code {
    margin-top: calc(9 * var(--vp-s));
    padding-top: calc(7 * var(--vp-s));
    border-top: calc(1 * var(--vp-s)) dashed rgba(85, 85, 85, 0.55);
    font-size: calc(var(--coupon-code-size, 13) * var(--vp-s));
    line-height: calc(var(--coupon-code-line-height, 18) * var(--vp-s));
    color: var(--coupon-code-color, #777777);
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-button {
    width: calc(111 * var(--vp-s));
    min-height: calc(30 * var(--vp-s));
    margin-top: calc(8 * var(--vp-s));
    padding: calc(6 * var(--vp-s)) calc(18 * var(--vp-s));
    border: 0;
    border-radius: calc(999 * var(--vp-s));
    background: var(--coupon-button-bg, #06c8c4);
    color: var(--coupon-button-color, #ffffff);
    font-size: calc(var(--coupon-button-size, 14) * var(--vp-s));
    line-height: calc(var(--coupon-button-line-height, 18) * var(--vp-s));
    font-weight: 700;
    cursor: pointer;
    transition: opacity .2s ease, transform .2s ease;
  }

  #common-acc-tab-{{ section.id }} .common-acc-tab__coupon-button:hover {
    opacity: .88;
    transform: translateY(calc(-1 * var(--vp-s)));
  }
    #common-acc-tab-{{ section.id }} .xmas-viewmore{
      color: {{ section.settings.view_more_color | default: '#E44D4D' }};
      background: {{ section.settings.view_more_bg | default: 'linear-gradient(90deg, #FFCFCF 0%, #FFD9AE 100%)' }};
    }
  @media (max-width: 768px) {
    #common-acc-tab-{{ section.id }} .xmas-view-more-container{
      flex-direction: column;
    }
    #common-acc-tab-{{ section.id }} .xmas-sub-heading{
      font-size: 18px;
    }
    #common-acc-tab-{{ section.id }} .xmas-viewmore{
