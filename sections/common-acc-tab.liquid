      border-radius: 0;
    }

    #common-acc-tab-{{ section.id }} .common-acc-tab__banner-point {
      gap: calc(6 * var(--vp-s));
      font-size: calc(var(--banner-mobile-point-size, 11) * var(--vp-s));
      line-height: calc(var(--banner-mobile-point-line-height, 15) * var(--vp-s));
    }

    #common-acc-tab-{{ section.id }} .common-acc-tab__banner-point-icon {
      width: calc(34 * var(--vp-s));
