              --banner-mobile-title-size: {{ block.settings.mobile_title_size }};
              --banner-mobile-title-line-height: {{ block.settings.mobile_title_line_height }};
              --banner-mobile-title-margin-bottom: {{ block.settings.mobile_title_margin_bottom }};
              --banner-subtitle-color: {{ block.settings.subtitle_color }};
              --banner-subtitle-size: {{ block.settings.subtitle_size }};
              --banner-subtitle-line-height: {{ block.settings.subtitle_line_height }};
              --banner-mobile-subtitle-size: {{ block.settings.mobile_subtitle_size }};
              --banner-mobile-subtitle-line-height: {{ block.settings.mobile_subtitle_line_height }};
              --banner-points-bg: {{ block.settings.points_bg }};
              --banner-points-color: {{ block.settings.points_color }};
              --banner-point-gap: {{ block.settings.point_gap }};
              --banner-mobile-point-gap: {{ block.settings.mobile_point_gap }};
              --banner-point-size: {{ block.settings.point_size }};
              --banner-point-line-height: {{ block.settings.point_line_height }};
              --banner-mobile-point-size: {{ block.settings.mobile_point_size }};
              --banner-mobile-point-line-height: {{ block.settings.mobile_point_line_height }};
            "
          >
            <div class="common-acc-tab__banner-inner">
              <div class="common-acc-tab__banner-content">
                {% if block.settings.title != blank %}
                  <h2 class="common-acc-tab__banner-title">{{ block.settings.title | escape | newline_to_br }}</h2>
                {% endif %}
                {% if block.settings.subtitle != blank %}
                  <p class="common-acc-tab__banner-subtitle">{{ block.settings.subtitle | escape | newline_to_br }}</p>
                {% endif %}
              </div>

              <div class="common-acc-tab__banner-points">
                {% if block.settings.point_1 != blank %}
                  <div class="common-acc-tab__banner-point">
                    <span class="common-acc-tab__banner-point-icon" aria-hidden="true"></span>
                    <span>{{ block.settings.point_1 | escape }}</span>
                  </div>
                {% endif %}
                {% if block.settings.point_2 != blank %}
                  <div class="common-acc-tab__banner-point">
                    <span class="common-acc-tab__banner-point-icon" aria-hidden="true"></span>
                    <span>{{ block.settings.point_2 | escape }}</span>
                  </div>
                {% endif %}
                {% if block.settings.point_3 != blank %}
                  <div class="common-acc-tab__banner-point">
                    <span class="common-acc-tab__banner-point-icon" aria-hidden="true"></span>
                    <span>{{ block.settings.point_3 | escape }}</span>
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
      
      <div class="acc-tab-container">
        <!-- Tabs Navigation -->
        {% unless section.settings.hide_tab_nav %}
        <div class="acc-tabs-nav">
          {% if section.settings.tab_1_title != blank %}
            <button class="acc-tab-btn active" data-tab="1">{{ section.settings.tab_1_title }}</button>
          {% endif %}
          {% if section.settings.tab_2_title != blank %}
            <button class="acc-tab-btn" data-tab="2">{{ section.settings.tab_2_title }}</button>
          {% endif %}
          {% if section.settings.tab_3_title != blank %}
            <button class="acc-tab-btn" data-tab="3">{{ section.settings.tab_3_title }}</button>
          {% endif %}
          {% if section.settings.tab_4_title != blank %}
            <button class="acc-tab-btn" data-tab="4">{{ section.settings.tab_4_title }}</button>
          {% endif %}
        </div>
        {% endunless %}

        <!-- Tabs Content -->
        <div class="acc-tabs-content">
          {% for i in (1..4) %}
            {% capture tab_title_key %}tab_{{ i }}_title{% endcapture %}
            {% capture tab_collection_key %}tab_{{ i }}_collection{% endcapture %}
            {% assign tab_collection = section.settings[tab_collection_key] %}
            
            {% if section.settings[tab_title_key] != blank %}
              <div class="acc-tab-panel {% if i == 1 %}active{% endif %}" id="tab-panel-{{ i }}-{{ section.id }}">
                {% assign visible_count = 0 %}
                <div class="acc-tab-cards">
                
                {% if tab_collection != blank %}
                  {% comment %} Collection Logic {% endcomment %}
                  {% for product in collections[tab_collection].products limit: 12 %}
                    {% assign visible_count = visible_count | plus: 1 %}
                    {% assign title = product.title %}
                    {% assign image = product.featured_image %}
                    {% assign price = product.price | money %}
                    {% assign compare_price = nil %}
                    {% if product.compare_at_price > product.price %}
                        {% assign compare_price = product.compare_at_price | money %}
                    {% endif %}
                    
                    <div class="acc-tab-card {% if visible_count > 6 %}extra-card{% endif %}">
