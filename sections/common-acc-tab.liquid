  /* Tabs Navigation */
  #common-acc-tab-{{ section.id }} .acc-tabs-nav {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  #common-acc-tab-{{ section.id }} .acc-tab-btn {
    padding: 12px 40px;
    background: {{ section.settings.tab_nav_bg | default: '#ffffff' }};
    border: 1px solid {{ section.settings.tab_nav_border_color | default: '#eeeeee' }};
    border-radius: 99px;
    font-size: 16px;
    font-weight: 500;
    color: {{ section.settings.tab_nav_text_color | default: '#666666' }};
    cursor: pointer;
    transition: all 0.3s ease;
    min-width: 150px;
    text-align: center;
    flex: 1;
  }

  #common-acc-tab-{{ section.id }} .acc-tab-btn.active {
    background: {{ section.settings.tab_nav_active_bg | default: '#ACCF42' }};
    color: {{ section.settings.tab_nav_active_text_color | default: '#FFFFFF' }};
    /* border-color: #ff8ba7; */
    /* box-shadow: 0 4px 10px rgba(255, 139, 167, 0.3); */
  }

  /* Tabs Content */
  #common-acc-tab-{{ section.id }} .acc-tab-panel {
    display: none;
    animation: fadeIn 0.5s ease;
  }

  #common-acc-tab-{{ section.id }} .acc-tab-panel.active {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding-top: 10px;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Product Card */
  #common-acc-tab-{{ section.id }} .acc-tab-card {
    background: #fff;
    border-radius: 12px;
    padding: 20px;
    position: relative;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    text-align: center;
    transition: transform 0.3s ease;
  }

  #common-acc-tab-{{ section.id }} .acc-tab-card:hover {
    transform: translateY(-5px);
  }
  #common-acc-tab-{{ section.id }} .common-badge {
    position: absolute;
    top: calc(var(--common-badge-top, -1) * var(--vp-s));
    left: calc(var(--common-badge-left, 20) * var(--vp-s));
