      max-width: 100%;
      min-height: calc(var(--banner-mobile-height, 430) * var(--vp-s));
      margin-bottom: calc(var(--banner-mobile-margin-bottom, var(--banner-margin-bottom, 28)) * var(--vp-s));
      border-radius: calc(var(--banner-mobile-radius, var(--banner-radius, 8)) * var(--vp-s));
      background-image: var(--banner-mobile, var(--banner-desktop));
