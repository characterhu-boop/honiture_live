                  </button>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>
{% render 'section-decorations', section: section %}
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var section = document.getElementById('common-acc-tab-{{ section.id }}');
    if (!section) return;

    var btns = section.querySelectorAll('.acc-tab-btn');
    var panels = section.querySelectorAll('.acc-tab-panel');

    function updateShowMore(panel) {
      if (!panel) return;
      var wrapper = panel.querySelector('.sp-show-more-wrapper');
      if (!wrapper) return;
      var cards = panel.querySelectorAll('.acc-tab-cards .acc-tab-card');
      var isMobile = window.matchMedia && window.matchMedia('(max-width: 768px)').matches;
      var threshold = isMobile ? 4 : 6;
      if (cards.length > threshold) {
        wrapper.style.display = '';
      } else {
        wrapper.style.display = 'none';
        panel.classList.remove('show-all');
        var textSpan = wrapper.querySelector('.btn-text');
        if (textSpan) textSpan.textContent = 'Show More';
      }
    }

    function updateAllPanels() {
      panels.forEach(function(panel) { updateShowMore(panel); });
    }

    updateAllPanels();
    window.addEventListener('resize', function() {
      updateAllPanels();
    });

    btns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        // Remove active class from all
        btns.forEach(function(b) { b.classList.remove('active'); });
        panels.forEach(function(p) { p.classList.remove('active'); });

        // Add active class to clicked
        btn.classList.add('active');
        var tabIndex = btn.getAttribute('data-tab');
        var targetPanel = section.querySelector('#tab-panel-' + tabIndex + '-{{ section.id }}');
        if (targetPanel) {
          targetPanel.classList.add('active');
          updateShowMore(targetPanel);
        }
      });
    });
  });
  function toggleShowMore(btn) {
    var panel = btn.closest('.acc-tab-panel');
    panel.classList.toggle('show-all');
    var textSpan = btn.querySelector('.btn-text');
    if (panel.classList.contains('show-all')) {
      textSpan.textContent = 'Show Less';
    } else {
      textSpan.textContent = 'Show More';
    }
  }

  function commonAccTabCopyCoupon(btn) {
    var code = btn.getAttribute('data-coupon-code');
    if (!code) return;

    function setCopiedState() {
      var defaultText = btn.getAttribute('data-default-text') || 'Claim';
      var successText = btn.getAttribute('data-success-text') || 'Copied';
      btn.textContent = successText;
      window.setTimeout(function() {
        btn.textContent = defaultText;
      }, 1800);
    }

    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(code).then(setCopiedState).catch(function() {
        fallbackCopy(code);
        setCopiedState();
      });
      return;
    }

    fallbackCopy(code);
    setCopiedState();
  }

  function fallbackCopy(code) {
    var textarea = document.createElement('textarea');
    textarea.value = code;
    textarea.setAttribute('readonly', 'readonly');
    textarea.style.position = 'fixed';
    textarea.style.top = '-9999px';
    document.body.appendChild(textarea);
    textarea.select();
    try {
      document.execCommand('copy');
    } catch (e) {}
    document.body.removeChild(textarea);
  }
</script>
<script>
  async function spAddBundle(btn) {
    try {
      var mainId = btn.getAttribute('data-main-id');
      var giftId = btn.getAttribute('data-gift-id');
      if (!mainId) return;
      var items = [{ id: Number(mainId), quantity: 1 }];
      if (giftId) {
        items.push({ id: Number(giftId), quantity: 1 });
      }
      var res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ items: items })
      });
      if (!res.ok) {
        try {
          var text = await res.text();
          console.warn('Add bundle failed', text);
        } catch(e){}
      }
      window.open('/cart', '_blank', 'noopener,noreferrer');
    } catch (e) {
      console.error('Add bundle error', e);
      window.open('/cart', '_blank', 'noopener,noreferrer');
    }
  }
</script>
<script>
  async function spBuyNow(el) {
    try {
      var mainId = el.getAttribute('data-main-id');
      var giftId = el.getAttribute('data-gift-id');
      var addGift = String(el.getAttribute('data-add-gift')).toLowerCase() === 'true';
      if (!mainId) return;
      var items = [{ id: Number(mainId), quantity: 1 }];
      if (addGift && giftId) items.push({ id: Number(giftId), quantity: 1 });
      var res = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ items: items })
      });
      if (!res.ok) { 
        try {
          var text = await res.text();
          console.warn('Buy now add failed', text);
        } catch(e){}
      }
      // window.location.href = '/checkout';
      window.open('/checkout', '_blank', 'noopener,noreferrer');
    } catch (e) {
      console.error('Buy now error', e);
      window.open('/checkout', '_blank', 'noopener,noreferrer');
    }
  }
</script>

