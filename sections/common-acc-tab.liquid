      border-width: calc(2 * var(--vp-s));
    }

    #common-acc-tab-{{ section.id }} .common-acc-tab__banner-point-icon::before {
      width: calc(11 * var(--vp-s));
      height: calc(11 * var(--vp-s));
      border-right-width: calc(2 * var(--vp-s));
      border-bottom-width: calc(2 * var(--vp-s));
      top: calc(9 * var(--vp-s));
      left: calc(10 * var(--vp-s));
    }

