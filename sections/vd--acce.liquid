{% comment %}
  Xmas Accessories Year Section (Customized)
  - Title via snippet `xmas-section-header`
  - Banner with subtitle, no button
  - Product cards with:
    - Discount badge
    - Custom description
    - Discount code with copy function
{% endcomment %}


    <section id="vd-acce-{{ section.id }}" class="vd-acce">
    {% render 'xmas-section-header', section: section %}
    <div class="acce__container">
        {% if section.settings.snow_image %}
        <div class="spin-section-snow">
            {{ section.settings.snow_image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: 'Snow strip' }}
        </div>
        {% endif %}
 
        {% if section.settings.banner_bg != blank or section.settings.banner_bg_mobile != blank %}
        <div class="acce-banner">
            <div class="acce-banner__content">
            {% if section.settings.banner_richtext != blank %}
                <div class="acce-banner__text">{{ section.settings.banner_richtext }}</div>
            {% endif %}
            {% if section.settings.banner_subtitle != blank %}
                <div class="acce-banner__subtitle">{{ section.settings.banner_subtitle }}</div>
            {% endif %}
            </div>
            {% if section.settings.banner_bg_link_url != blank %}
              <a href="{{ section.settings.banner_bg_link_url }}" class="acce-banner__link" target="_blank" rel="noopener noreferrer">
                {{ section.settings.banner_bg_link_label | default: 'Learn More' }}
              </a>
            {% endif %}
        </div>
        {% endif %}

        {% assign acce_blocks = section.blocks | where: 'type', 'acce_product' %}
        {% assign acce_total = acce_blocks.size %}
        <div class="acce__grid{% if acce_total > 4 %} is-collapsed{% endif %}">
        {% for block in section.blocks %}
            {% if block.type == 'acce_product' %}
            {% assign prod = block.settings.product %}
            {% assign has_prod = prod.id %}
            {% if has_prod %}
                {% assign variant_id = block.settings.variant_id | default: prod.selected_or_first_available_variant.id %}
                {% assign variant = prod.variants | where: 'id', variant_id | first %}
                {% if variant == blank %}{% assign variant = prod.selected_or_first_available_variant %}{% endif %}
                {% assign price = variant.price %}
                {% assign compare = variant.compare_at_price %}
                {% assign img = block.settings.image | default: prod.featured_image %}
                {% assign title = block.settings.title | default: prod.title %}

                <div class="acce-card" {{ block.shopify_attributes }}>
                <div class="acce-card__media">
                    {% if block.settings.show_discount_badge %}
                    <div class="acce-card__badge" {% if block.settings.discount_badge_bg != blank %}style="background: url({{ block.settings.discount_badge_bg | image_url: width: 200 }}) no-repeat center center / contain; clip-path: none;"{% endif %}>
                       {{ block.settings.discount_badge_text }}<br> OFF
                    </div>
                    {% endif %}
                    {% if img %}
                    <a href="{{ prod.url }}" target="_blank" class="acce-card__link">
                    <img src="{{ img | image_url: width: 600 }}" alt="{{ title | escape }}" loading="lazy" />
                    </a>{% endif %}
                </div>
                <div class="acce-card__content">
                  {% render 'xmas-copy-code', section: section, code_label: block.settings.code_label, discount_code: block.settings.discount_code %}
                    <div class="acce-card__title">{{ title }}</div>
                    
                    {% if block.settings.custom_description != blank %}
                    <div class="acce-card__desc">
                        {{ block.settings.custom_description }}
                    </div>
                    {% endif %}

                    {% comment %} {% if block.settings.discount_code != blank %}
                    <div class="acce-card__code-box">
                        <span class="code-label">Code: <strong>{{ block.settings.discount_code }}</strong></span>
                        <button type="button" class="btn-copy" data-code="{{ block.settings.discount_code }}">Copy</button>
                        <span class="copy-success-msg">Copied!</span>
                    </div>
                    {% endif %} {% endcomment %}
                    
                    <div class="vd-card-footer-wrap">
                      <div class="acce-card__price">
                      {{ price | money }}
                      {% if compare %}<span class="acce-card__compare">{{ compare | money }}</span>{% endif %}
                      </div>
                      
                      <div class="acce-card__actions">
                      <a href="{{ prod.url }}" class="acce-card__btn--shop" target="_blank">Shop now</a>
                      </div>
                    </div>
                </div>
                </div>
            {% endif %}
            {% endif %}
        {% endfor %}
        </div>

        {% if acce_total > 4 %}
        <div class="acce__toggle">
            <button type="button" class="acce-toggle__btn" aria-expanded="false">
            <span class="acce-toggle__label">Show more</span>
            <!-- 向下箭头（折叠态） -->
            <svg class="arrow arrow--down" viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.41 8.59 12 13.17l4.59-4.58L18 10l-6 6-6-6z" fill="currentColor"/>
            </svg>
            <!-- 向上箭头（展开态） -->
            <svg class="arrow arrow--up" viewBox="0 0 24 24" width="16" height="16" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.41 15.41 12 10.83l4.59 4.58L18 14l-6-6-6 6z" fill="currentColor"/>
            </svg>
            </button>
        </div>
        {% endif %}
    </div>

    <div class="acce__toast" role="status" aria-live="polite"></div>
    </section>
{% render 'section-decorations', section: section %}
<style>
  .vd-acce { padding: 24px 0;}

  .vd-acce .acce__container { 
    max-width: 1300px; 
    margin: 0 auto; 
      border-radius: 30px 30px 10px 10px;
      position: relative;
  }
  .vd-acce .spin-section-snow{
    position: absolute;
    top: -20px;
    left: 0;
  }
  /* Banner */
  .vd-acce .acce-banner { position: relative; background-size: cover; 
  background-position: center; border-radius: 12px; min-height: 160px; display: 
  flex; align-items: center; padding: 42px; margin-bottom: 18px; 
      height: 460px;
          background-size: 100%;
    background-repeat: no-repeat;
}
  /* 响应式背景图：PC/Mobile 优先使用对应设置，未设置则相互回退 */
  #vd-acce-{{ section.id }} .acce-banner {
    background-image: url({{ section.settings.banner_bg | default: section.settings.banner_bg_mobile | image_url: width: 1600 }});
  }
  .vd-acce .acce-banner__content { max-width: 700px; color: #fff; }
  .vd-acce .acce-banner__text { margin-bottom: 10px; color: #000;}
  .vd-acce .acce-banner__text strong{
    color: #DA2B2B;
  }
  .vd-acce .acce-banner__text p{
    margin-bottom: 0;
    font-size: 22px;
    font-weight: 500;
  }
  .vd-acce .acce-banner__subtitle {
    font-size: 16px;
    color: #333; /* Adjust color as needed */
    margin-top: 5px;
  }
  .vd-acce .acce-banner__link{
    position: absolute;
    right: 24px;
    bottom: 24px;
    display: inline-block;
    background: linear-gradient(90deg, #4DE0E6 0%, #76E8E6 100%);
    color: #fff;
    border-radius: 20px;
    padding: 8px 20px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
  }
  .vd-acce .acce-banner__link:hover{
    opacity: 0.9;
  }

  /* Grid */
  .vd-acce .acce__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; padding-top: 10px;}
  /* 默认折叠：仅显示前4张，超出隐藏 */
  .vd-acce .acce__grid.is-collapsed .acce-card:nth-child(n+5) { display: none; }

  /* 展开/收起按钮样式 */
  .vd-acce .acce__toggle { display: flex; justify-content: center; margin-top: 14px; }
  .vd-acce .acce-toggle__btn { cursor: pointer; border: 1px solid #fff; background: transparent; color: #fff; border-radius: 999px; padding: 8px 16px; font-size: 14px; }
  .vd-acce .acce-toggle__btn:hover { background: rgba(255,255,255,0.12); }
  .vd-acce .acce-toggle__btn { display: inline-flex; align-items: center; gap: 8px; }
  .vd-acce .acce-toggle__btn .arrow { width: 16px; height: 16px; color: #fff; }
  /* 默认显示向下箭头；展开后显示向上箭头 */
  .vd-acce .acce__toggle .arrow--up { display: none; }
  .vd-acce .acce__toggle.is-expanded .arrow--up { display: inline; }
  .vd-acce .acce__toggle.is-expanded .arrow--down { display: none; }
  
  .vd-acce .acce-card { background: #fff; border-radius: 10px; 
  box-shadow: 0 1px 6px rgba(0,0,0,0.08);
  display: flex; flex-direction: column; 
  justify-content: space-between;
  text-align: left; /* Image shows left align */
  position: relative;
}
  .vd-acce .acce-card__media {  padding: 10px; position: relative; text-align: center; }
  .vd-acce .acce-card__media img { width: 100%; height: auto; display: block; margin: 0 auto; }
  .vd-acce .acce-card__content { padding: 12px 16px 20px; text-align: left; }
  .vd-acce .acce-card__title { font-size: 14px; font-weight: 600; margin-bottom: 4px; color: #666; }
  
  .vd-acce .acce-card__desc {
    font-size: 18px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 10px;
    color: #000;
  }

  /* Badge */
  .vd-acce .acce-card__badge {
    position: absolute;
        top: -9px;
        left: 10px;
        line-height: 1;
    background-color: #E83A3A;
    color: white;
    font-weight: bold;
    font-size: 14px;
    padding: 4px 8px;
    clip-path: polygon(0 0, 100% 0, 100% 85%, 50% 100%, 0 85%);
width: 80px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  /* Code Box */
  .vd-acce .acce-card__code-box {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #E0F7FA; /* Light cyan background */
    padding: 4px 8px;
    border-radius: 4px;
    margin-bottom: 10px;
    font-size: 12px;
    width: fit-content;
    position: relative;
  }
  .vd-acce .code-label {
    color: #006064;
  }
  .vd-acce .btn-copy {
    background: #4DD0E1;
    border: none;
    color: white;
    padding: 2px 8px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 12px;
  }
  .vd-acce .copy-success-msg {
    position: absolute;
    top: -25px;
    right: 0;
    background: rgba(0,0,0,0.7);
    color: #fff;
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 10px;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .vd-acce .copy-success-msg.show {
    opacity: 1;
  }

  .vd-acce .acce-card__price { font-size: 24px; font-weight: 700; color: #000; margin-bottom: 10px; }
  .vd-acce .acce-card__compare { color: #999; text-decoration: line-through; font-weight: 400; margin-left: 6px; font-size: 14px; }
  
  .vd-acce .acce-card__actions { margin-top: 0; }
  .vd-acce .acce-card__btn--shop { 
    display: inline-block;
    background: #ff84a2; /* Light blue/cyan button */
    color: #fff;
    border-radius: 20px;
    padding: 6px 24px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    border: none;
    cursor: pointer;
  }

  .vd-acce .acce__toast { position: fixed; left: 50%; transform: translateX(-50%); bottom: 24px; background: rgba(0,0,0,0.85); color: #fff; padding: 10px 12px; border-radius: 8px; font-size: 13px; opacity: 0; pointer-events: none; transition: opacity .25s ease; }
  .vd-acce .acce__toast.is-visible { opacity: 1; }
.vd-card-footer-wrap{
        display: flex;
    justify-content: space-between;
}
  @media (max-width: 1024px) {
    .vd-acce .acce__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
      .vd-acce .xmas-sub-heading{
        padding: 0 50px;
  }
    .vd-acce .acce-banner__content{
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      width: 100%;

    }
    #vd-acce-{{ section.id }} .acce-banner {
      background-image: url({{ section.settings.banner_bg_mobile | default: section.settings.banner_bg | image_url: width: 1000 }});
        height: 300px;
        padding: 16px;
        align-items: start;
        font-size: 12px;
        padding-top:188px;
    }
    .vd-acce .acce-banner__link{
      right: 16px;
      bottom: 16px;
      padding: 6px 16px;
      font-size: 12px;
    }
    .vd-acce .acce-banner__text{
        display: none;
    }
    .vd-acce .acce-banner__text p{
      font-size: 14px;
      
    }
    .vd-acce .acce-card__media{
      padding: 0;
    }
    .vd-acce .acce__grid { 
        display: flex;
        overflow-x: auto;
        gap: 10px; 
        scroll-snap-type: x mandatory;
        padding-bottom: 10px;
        -webkit-overflow-scrolling: touch;
    }
    .vd-acce .acce-card {
        flex: 0 0 72%;
        width: 72%;
        scroll-snap-align: start;
    }
    /* Mobile force show all items */
    .vd-acce .acce__grid.is-collapsed .acce-card:nth-child(n+5) { 
        display: flex; 
    }
    /* Hide toggle button on mobile */
    .vd-acce .acce__toggle {
        display: none;
    }

    .vd-acce .acce__container{
      margin: 0 16px;
      padding: 30px 10px 20px;
      border-radius: 10px;
      padding-top: 0px;
    }
    .vd-acce .acce__container .xmas-one-card-discount-code{
        width: 100%;
            padding: 10px;
            font-size: 12px;
    }
    .vd-acce .spin-section-snow{
      top: -10px;
    }
    .vd-acce .acce-card__content { padding: 10px; }
    .vd-acce .acce-card__title { font-size: 12px; }
    .vd-acce .acce-card__desc { font-size: 12px; }
    .vd-acce .acce-card__price { font-size: 16px; }
    .vd-acce .acce-card__compare { font-size: 12px; }
    .vd-acce .acce-card__btn--shop { padding: 4px 16px; font-size: 12px; }
  }
</style>

<script>
  (function() {
    document.addEventListener('DOMContentLoaded', function() {
      var root = document.getElementById('vd-acce-{{ section.id }}');
      if (!root) return;

      // Copy Code Functionality
      root.querySelectorAll('.btn-copy').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var code = btn.getAttribute('data-code');
          if (code) {
            navigator.clipboard.writeText(code).then(function() {
              var msg = btn.parentElement.querySelector('.copy-success-msg');
              if (msg) {
                msg.classList.add('show');
                setTimeout(function() { msg.classList.remove('show'); }, 2000);
              }
              btn.textContent = 'Copied';
              setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
            }).catch(function(err) {
              console.error('Failed to copy text: ', err);
            });
          }
        });
      });

      // 展开/收起更多配件
      var grid = root.querySelector('.acce__grid');
      var toggleBtn = root.querySelector('.acce-toggle__btn');
      var toggleLabel = toggleBtn ? toggleBtn.querySelector('.acce-toggle__label') : null;
      var toggleWrap = root.querySelector('.acce__toggle');
      var preExpandViewportOffset = null; // 记录展开前按钮相对视口的位置
      if (grid && toggleBtn && toggleWrap) {
        toggleBtn.addEventListener('click', function() {
          var isCollapsed = grid.classList.contains('is-collapsed');
          if (isCollapsed) {
            // 展开前记录按钮相对视口的偏移量（不依赖页面滚动绝对值）
            var rect = toggleWrap.getBoundingClientRect();
            preExpandViewportOffset = rect.top;
            grid.classList.remove('is-collapsed');
            if (toggleLabel) { toggleLabel.textContent = 'Show less'; }
            toggleBtn.setAttribute('aria-expanded', 'true');
            toggleWrap.classList.add('is-expanded');
          } else {
            grid.classList.add('is-collapsed');
            if (toggleLabel) { toggleLabel.textContent = 'Show more'; }
            toggleBtn.setAttribute('aria-expanded', 'false');
            toggleWrap.classList.remove('is-expanded');
            // 收起后平滑滚动，使按钮回到点击时的相同视口位置
            if (preExpandViewportOffset !== null) {
              window.requestAnimationFrame(function() {
                var newRectTop = toggleWrap.getBoundingClientRect().top;
                var currentScroll = window.scrollY;
                var targetScroll = currentScroll + newRectTop - preExpandViewportOffset;
                window.scrollTo({ top: Math.max(targetScroll, 0), behavior: 'smooth' });
              });
            }
          }
        });
      }
    });
  })();
</script>

