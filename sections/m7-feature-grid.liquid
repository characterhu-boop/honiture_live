  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__image,
  #m7-feature-grid-{{ section.id }} .m7-feature-grid__placeholder,
  #m7-feature-grid-{{ section.id }} .m7-feature-grid__placeholder svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__image {
    object-fit: cover;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__placeholder {
    color: rgba(0, 0, 0, 0.28);
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__shade {
    position: absolute;
    inset: 0 0 auto;
    height: 50%;
    background: linear-gradient(180deg, #000 0%, rgba(1, 1, 1, 0) 78.85%);
    filter: drop-shadow(0 4px 4px rgba(0, 0, 0, 0.25));
    pointer-events: none;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--1 .m7-feature-grid__shade {
    height: 23.935091%;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--2 .m7-feature-grid__shade,
  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--3 .m7-feature-grid__shade {
    height: 63.783784%;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--4 .m7-feature-grid__shade {
    height: 52.212389%;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--5 .m7-feature-grid__shade {
    height: 39.730640%;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--6 .m7-feature-grid__shade {
    height: 46.093750%;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--7 .m7-feature-grid__shade,
  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--8 .m7-feature-grid__shade,
  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card--9 .m7-feature-grid__shade {
    height: 49.166667%;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__content {
    position: absolute;
    z-index: 2;
    top: {{ section.settings.text_top }}px;
    left: {{ section.settings.text_left }}px;
    right: 14px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    pointer-events: none;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__title {
    margin: 0;
    font-family: "Isidora Sans", var(--font-body-family), Arial, sans-serif;
    font-size: {{ section.settings.title_size }}px;
    line-height: {{ section.settings.title_line_height }}px;
    font-weight: 700;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__subtitle {
    margin: 0;
    font-family: "Isidora Sans", var(--font-body-family), Arial, sans-serif;
    font-size: {{ section.settings.subtitle_size }}px;
    line-height: {{ section.settings.subtitle_line_height }}px;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    #m7-feature-grid-{{ section.id }} {
      padding: {{ section.settings.mobile_padding_top }}px 12px {{ section.settings.mobile_padding_bottom }}px;
    }

    #m7-feature-grid-{{ section.id }} .m7-feature-grid__heading {
      margin-bottom: 20px;
      font-size: {{ section.settings.mobile_heading_size }}px;
    }

    #m7-feature-grid-{{ section.id }} .m7-feature-grid__inner--desktop {
      display: none;
    }

    #m7-feature-grid-{{ section.id }} .m7-feature-grid__inner--mobile {
      display: block;
      max-width: 1127px;
      aspect-ratio: 1127 / 2520;
    }

    #m7-feature-grid-{{ section.id }} .m7-feature-grid__content {
      top: {{ section.settings.mobile_text_top }}px;
      left: {{ section.settings.mobile_text_left }}px;
      right: 10px;
    }

    #m7-feature-grid-{{ section.id }} .m7-feature-grid__title {
