{% comment %}
  M7 feature grid
  Desktop-only fixed 9-card layout based on the provided 1179 x 744 design.
{% endcomment %}

{%- liquid
  assign section_title = section.settings.heading | strip
-%}

<section id="m7-feature-grid-{{ section.id }}" class="m7-feature-grid">
  {%- if section_title != blank -%}
    <h2 class="m7-feature-grid__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="m7-feature-grid__inner m7-feature-grid__inner--desktop">
    {%- for block in section.blocks limit: 9 -%}
      <div class="m7-feature-grid__card m7-feature-grid__card--{{ forloop.index }}" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            class="m7-feature-grid__image"
            src="{{ block.settings.image | image_url: width: 900 }}"
            srcset="
              {{ block.settings.image | image_url: width: 360 }} 360w,
              {{ block.settings.image | image_url: width: 600 }} 600w,
              {{ block.settings.image | image_url: width: 900 }} 900w
            "
            sizes="(min-width: 769px) 33vw, 0px"
            alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
            loading="lazy"
          >
        {%- else -%}
          <div class="m7-feature-grid__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if block.settings.show_gradient -%}
          <div class="m7-feature-grid__shade"></div>
        {%- endif -%}

        {%- if block.settings.title != blank or block.settings.subtitle != blank -%}
          <div class="m7-feature-grid__content">
            {%- if block.settings.title != blank -%}
              <div class="m7-feature-grid__title" style="color: {{ block.settings.title_color }};">
                {{ block.settings.title }}
              </div>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <div class="m7-feature-grid__subtitle" style="color: {{ block.settings.subtitle_color }};">
                {{ block.settings.subtitle }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <div class="m7-feature-grid__inner m7-feature-grid__inner--mobile">
    {%- for block in section.blocks limit: 9 -%}
      {%- liquid
        assign mobile_title = block.settings.mobile_title
        assign mobile_subtitle = block.settings.mobile_subtitle
        assign mobile_title_color = block.settings.mobile_title_color
        assign mobile_subtitle_color = block.settings.mobile_subtitle_color

        if mobile_title == blank
          assign mobile_title = block.settings.title
          assign mobile_title_color = block.settings.title_color
        endif

        if mobile_subtitle == blank
          assign mobile_subtitle = block.settings.subtitle
          assign mobile_subtitle_color = block.settings.subtitle_color
        endif
      -%}
      <div class="m7-feature-grid__card m7-feature-grid__card--mobile-{{ forloop.index }}" {{ block.shopify_attributes }}>
        {%- if block.settings.mobile_image != blank -%}
          <img
            class="m7-feature-grid__image"
            src="{{ block.settings.mobile_image | image_url: width: 1200 }}"
            srcset="
              {{ block.settings.mobile_image | image_url: width: 480 }} 480w,
              {{ block.settings.mobile_image | image_url: width: 800 }} 800w,
              {{ block.settings.mobile_image | image_url: width: 1200 }} 1200w
            "
            sizes="100vw"
            alt="{{ block.settings.mobile_image.alt | default: block.settings.mobile_title | escape }}"
            loading="lazy"
          >
        {%- elsif block.settings.image != blank -%}
          <img
            class="m7-feature-grid__image"
            src="{{ block.settings.image | image_url: width: 1200 }}"
            srcset="
              {{ block.settings.image | image_url: width: 480 }} 480w,
              {{ block.settings.image | image_url: width: 800 }} 800w,
              {{ block.settings.image | image_url: width: 1200 }} 1200w
            "
            sizes="100vw"
            alt="{{ block.settings.image.alt | default: block.settings.mobile_title | escape }}"
            loading="lazy"
          >
        {%- else -%}
          <div class="m7-feature-grid__placeholder">
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}

        {%- if block.settings.mobile_show_gradient -%}
          <div class="m7-feature-grid__shade"></div>
        {%- endif -%}

        {%- if mobile_title != blank or mobile_subtitle != blank -%}
          <div class="m7-feature-grid__content">
            {%- if mobile_title != blank -%}
              <div class="m7-feature-grid__title" style="color: {{ mobile_title_color }};">
                {{ mobile_title }}
              </div>
            {%- endif -%}
            {%- if mobile_subtitle != blank -%}
              <div class="m7-feature-grid__subtitle" style="color: {{ mobile_subtitle_color }};">
                {{ mobile_subtitle }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{%- style -%}
  #m7-feature-grid-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background }};
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__heading {
    max-width: 1179px;
    margin: 0 auto 28px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.2;
    font-weight: 800;
    text-align: {{ section.settings.heading_align }};
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__inner {
    position: relative;
    width: 100%;
    margin: 0 auto;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__inner--desktop {
    max-width: 1179px;
    aspect-ratio: 1179 / 744;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__inner--mobile {
    display: none;
  }

  #m7-feature-grid-{{ section.id }} .m7-feature-grid__card {
    position: absolute;
    overflow: hidden;
    border-radius: 10px;
    background: #d9d9d9;
  }

