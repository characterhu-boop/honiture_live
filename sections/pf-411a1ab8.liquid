<style>
  .spin-wheel-1 #my-lucky {
    margin: 0 auto;
    position: relative;
    background-image: url('https://cdn.shopify.com/s/files/1/0635/2142/3407/files/back-ground-turntable.webp?v=1761901795');
    background-position: center;
    background-size: contain;
    background-repeat: no-repeat;

  }

  @media screen and (min-width: 768px) {
    .spin-wheel-1 #my-lucky {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 1200px !important;
      height: 800px !important;
      transform: translate(-20%, 0);
    }

  }

  .spin-wheel-1 .spin-wheel-container {
    position: relative;
    margin: 0 auto;
    flex-shrink: 0;
  }

  /* 移动端适配转盘容器 */
  @media screen and (max-width: 768px) {
    .spin-wheel-1 .spin-wheel-container {
      width: 100%;
      height: 90vw;
    }

    .spin-wheel-1 #my-lucky {
      background-size: 200%;
    }
  }

  /* 弹窗样式 */
  .spin-wheel-1 .prize-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    z-index: 1000;
    justify-content: center;
    align-items: center;
  }

  .spin-wheel-1 .modal-content {
    background: url("https://cdn.shopify.com/s/files/1/0635/2142/3407/files/lQDPJxRy5lK2PdvNB4DNB4CwW2v9f5pD7UsI5MWRAe9cAQ_1920_1920.jpg?v=1762223559");
    background-size: 100% 100%;
    background-position: center;
    padding: 50px 60px;
    padding-bottom: 20px;
    width: 100%;
    height: 100%;
    overflow: auto;
    text-align: center;
    position: relative;
    animation: popIn 0.5s ease-out;
  }

  .spin-wheel-1 .modal-content-wrap {
    width: 720px;
    height: 540px;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0px 0px 20px 10px #fff;
  }

  .spin-wheel-1 #save-error-tip {
    color: red;
    text-align: center;
    width: 100%;
  }

