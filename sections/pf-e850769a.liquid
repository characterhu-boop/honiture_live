            radius: isMobile ? "40%" : "40%",
            imgs: [
              {
                src: "https://cdn.shopify.com/s/files/1/0635/2142/3407/files/button.png?v=1762222974",
                width: isMobile ? "40%" : "40%",
                top: isMobile ? "-55%" : "-55%",
              },
            ],
          },
        ],
        defaultConfig: {
          speed: 30,
          // decelerationTime: 6000,
           offsetDegree: 30,
        },
        start: async function () {
          validateInfoAndStartSpin();
