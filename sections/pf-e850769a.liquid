        // if(item.type === 2){
        //   imgWidth = "8%";
        // }
        if(index === 2 || index === 5 ){
          fonts[0].fontColor ='#fff'
          fonts[1].fontColor ='#fff'
        }
        return {
          fonts,
          imgs: [
            {
              src:
                item.imageUrl ,
              width: imgWidth,
              top: isMobile ? "60%" : "70%",
            },
          ],
        };
      });

      myLucky = new LuckyCanvas.LuckyWheel("#my-lucky", {
