    </script><script>// 按钮用来复制文案的功能，按钮加上属性data-copy_code=“xxx”, 点击按钮就可以复制xxx

(function () {
  var els = document.querySelectorAll('[data-copy_code]');
  els.forEach(function (el) {
    el.addEventListener('click', function (ev) {
      ev.preventDefault();
      var code = (el.getAttribute('data-copy_code') || '').trim();
      if (!code) return;
      // 只替换文案文本节点，保留图标等结
      var labelNode = null;
      for (var i = 0; i < el.childNodes.length; i++) {
        var n = el.childNodes[i];
        if (n.nodeType === 3 && n.textContent.trim()) { labelNode = n; }
      }
      var originalLabel = labelNode ? labelNode.textContent : el.textContent.trim();
      var setCopied = function () {
        if (labelNode) { labelNode.textContent = 'copied'; }
        else { el.textContent = 'copied'; }
        setTimeout(function () {
          if (labelNode) { labelNode.textContent = originalLabel; }
          else { el.textContent = originalLabel; }
        }, 3000);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(code).then(setCopied).catch(function () { fallback(); });
      } else { fallback(); }
      function fallback() {
        var ta = document.createElement('textarea');
        ta.value = code; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); document.body.removeChild(ta);
        setCopied();
      }
    });
  });
