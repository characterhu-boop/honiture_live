{{ 'text-with-icons.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign mobile_swipe = section.settings.mobile_swipe
  assign mobile_columns = section.settings.mobile_columns
  assign desktop_columns = section.settings.desktop_columns
  assign text_alignment = section.settings.text_alignment
  assign icon_position = section.settings.icon_position
  assign icon_size = section.settings.icon_size
  assign heading_size = section.settings.heading_size
  assign color_bg = section.settings.color_bg
  assign color_heading = section.settings.color_heading
  assign color_text = section.settings.color_text
  assign disable_top_spacing = section.settings.disable_top_spacing
  assign disable_bottom_spacing = section.settings.disable_bottom_spacing
  assign has_bg = false
  assign icon_blocks_count = 0
  for block in section.blocks
    if block.type == 'icon'
      assign icon_blocks_count = icon_blocks_count | plus: 1
    endif
  endfor
  assign last_row_remainder = icon_blocks_count | modulo: mobile_columns

  if color_bg != 'rgba(0,0,0,0)'
    assign has_bg = true
  endif
-%}
<style>
  .text-with-icons--{{ section.id }} {
    --vp-s: 1px;
    --content-max-width: calc({{ section.settings.content_max_width }} * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.section-spacing {
    margin-top: 0;
    margin-bottom: 0;
  }
  .text-with-icons--{{ section.id }} .text-with-icons__inner {
    max-width: min(var(--content-max-width), 100%);
    padding-left: 0;
    padding-right: 0;
  }
  @media screen and (min-width: 850px) and (max-width: 1500px) {
    .text-with-icons--{{ section.id }} {
      --vp-s: calc(100vw / 1500);
    }
  }
  @media screen and (max-width: 849px) {
    .text-with-icons--{{ section.id }} {
      --vp-s: calc(100vw / 375);
    }
    .text-with-icons--{{ section.id }} .text-with-icons__inner {
      max-width: 100%;
    }
  }
  @media only screen and (min-width: 768px) {
    .text-with-icons--{{ section.id }} .text-with-icons__inner {
      grid-template-columns: repeat({{ desktop_columns }}, 1fr);
	  z-index: 1;
	  position: relative;
    }
  }
  @media only screen and (max-width: 768px) {
    .text-with-icons--{{ section.id }}.text-with-icons-new.icon-xlarge .text-with-icons__icon {
        height: calc(80 * var(--vp-s));
        /* width: 100%; */
    }
  } 
  .text-with-icons--{{ section.id }}.text-with-icons-new .text-with-icons__block {
    background: #fff;
    padding: calc(10 * var(--vp-s)) calc(20 * var(--vp-s));
    border-radius: calc(12 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }} .text-with-icons__block-content {
    font-size: calc(15 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }} .text-with-icons__block-content h6 {
    margin-bottom: calc(10 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }} .text-with-icons__block-content p {
    font-size: calc(15 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.heading-large h6 {
    font-size: calc({{ section.settings.card_heading_size }} * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.heading-medium h6 {
    font-size: calc({{ section.settings.card_heading_size }} * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.heading-small h6 {
    font-size: calc({{ section.settings.card_heading_size }} * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.icon-left .text-with-icons__icon {
    margin-right: calc(20 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.icon-top .text-with-icons__icon {
    margin-bottom: calc(20 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.icon-right .text-with-icons__icon {
    margin-left: calc(20 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.icon-small .text-with-icons__icon {
    width: calc(32 * var(--vp-s));
    height: calc(32 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.icon-medium .text-with-icons__icon {
    width: calc(48 * var(--vp-s));
    height: calc(48 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.icon-large .text-with-icons__icon {
    width: calc(64 * var(--vp-s));
    height: calc(64 * var(--vp-s));
  }
  .text-with-icons--{{ section.id }}.icon-xlarge .text-with-icons__icon {
    width: calc(80 * var(--vp-s));
    height: calc(80 * var(--vp-s));
  }
  @media only screen and (min-width: 768px) {
    .text-with-icons--{{ section.id }}.text-with-icons-new.icon-xlarge .text-with-icons__icon {
      width: calc(100 * var(--vp-s));
      height: calc(100 * var(--vp-s)); 
    }
  }
  @media only screen and (max-width: 768px) {
    .text-with-icons--{{ section.id }} .text-with-icons__block-content h6 {
      font-size: calc({{ section.settings.card_heading_size_mobile }} * var(--vp-s)) !important;
    }
  }
  .text-with-icons--{{ section.id }} .xmax_section__title,
  .text-with-icons--{{ section.id }} .xmas-sub-heading {
    white-space: pre-line;
  }

</style>
<div class="text-with-icons text-with-icons-new text-with-icons--{{ section.id }}{% if mobile_swipe %} swipe-on-mobile{% endif %} text-{{ text_alignment }} icon-{{ icon_position }} icon-{{ icon_size }} heading-{{ heading_size }} icon-columns-{{ icon_blocks_count }} text-with-icons-has-bg--{{ has_bg }} last-r-{{ last_row_remainder }} section-spacing {% if disable_top_spacing %} section-spacing--disable-top{% endif %}{% if disable_bottom_spacing %} section-spacing--disable-bottom{% endif %}" style="--color-heading: {{ color_heading }};--color-text: {{ color_text }};--color-bg: {{ color_bg }}">
  {% if section.settings.title != blank %}
    {% render 'xmas-section-header'
      , section: section %}
  {% endif %}
  <div class="text-with-icons__inner" style="--icon-columns: {{ icon_blocks_count }};--mobile-columns: {{ mobile_columns }}">
    {% for block in section.blocks %}
      {%- unless block.type == 'icon' -%}
        {%- continue -%}
      {%- endunless -%}
      <div class="text-with-icons__block {% if block.settings.text != blank %} has-no-content{% endif %}" {{ block.shopify_attributes }}>
        <div class="text-with-icons__icon">
          {%- if block.settings.image != blank -%}
            <img
              data-src="{{ block.settings.image | image_url }}"
              alt="{{ block.settings.image.alt | escape }}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="lazyload{% unless settings.lazy_loading %} no-blur{% endunless %}" />
            <noscript>
              <img
                src="{{ block.settings.image | image_url }}"
                alt="{{ block.settings.image.alt | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}" />
            </noscript>
          {%- else -%}
            {% render 'svg-icons-inline'
              , icon: block.settings.icon %}
          {%- endif -%}
        </div>
        <div class="text-with-icons__block-content">
          {% if block.settings.heading != blank %}
            <h6>{{ block.settings.heading }}</h6>
          {% endif %}
          {% if block.settings.text != blank %}
            {{ block.settings.text }}
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% render 'section-decorations', section: section %}

