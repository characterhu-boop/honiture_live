  .spin-wheel-1 .prize-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.7);
    z-index: 1000;
    justify-content: center;
    align-items: center;
  }

  .spin-wheel-1 .modal-content {
    background: url("https://cdn.shopify.com/s/files/1/0635/2142/3407/files/lQDPJxRy5lK2PdvNB4DNB4CwW2v9f5pD7UsI5MWRAe9cAQ_1920_1920.jpg?v=1762223559");
    background-size: 100% 100%;
    background-position: center;
    padding: 50px 60px;
    padding-bottom: 20px;
    width: 100%;
    height: 100%;
    overflow: auto;
    text-align: center;
    position: relative;
    animation: popIn 0.5s ease-out;
  }

  .spin-wheel-1 .modal-content-wrap {
    width: 720px;
    height: 540px;
    overflow: hidden;
    border-radius: 12px;
    box-shadow: 0px 0px 20px 10px #fff;
  }

  .spin-wheel-1 #save-error-tip {
    color: red;
    text-align: center;
    width: 100%;
  }

  @keyframes popIn {
    0% {
      transform: scale(0.8);
      opacity: 0;
    }

    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .spin-wheel-1 .modal-close {
    position: sticky;
    display: block;
    top: 0;
    left: 100%;
    transform: translate(40px, -40px);
