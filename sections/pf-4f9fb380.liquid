    height: 30px;
    cursor: pointer;
    color: #fff;
    transition: color 0.3s;
    background: #00000027;
    border-radius: 50%;
  }

  .spin-wheel-1 .modal-close:hover {
    color: #333;
    background: #00000060;
  }

