{% comment %} 引入assets中的js文件 {% endcomment %}
<style>
  .spin-wheel{
    overflow: hidden;
  }
    .section-{{ section.id }} #my-lucky {
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }
    .section-{{ section.id }} .spin-wheel-container {
        position: relative;
        margin: 0 auto;
        width: 100%;
        flex-shrink: 0;
      position: relative;
    }

    /* 翻牌卡片网格 */
    .section-{{ section.id }} .flip-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto auto auto;
      grid-template-areas:
        "a1 a2 a3 a4"
        "a5 center center a6"
        "a7 a8 a9 a10";
      gap: 12px;
      width: 100%;
      margin: 0 auto;
    }
    .section-{{ section.id }} .flip-grid.disabled .flip-card {
      pointer-events: none;
    }
    .section-{{ section.id }} .flip-grid.disabled {
      filter: grayscale(10%);
    }
    .section-{{ section.id }} .flip-card { perspective: 1000px; cursor: pointer; }
    .section-{{ section.id }} .flip-card.disabled { cursor: not-allowed; opacity: 0.6; }
    .section-{{ section.id }} .flip-card-inner {
      position: relative;
      width: 100%;
      transform-style: preserve-3d;
      transition: transform 0.6s;
      border-radius: 12px;
      box-shadow: 0 6px 12px rgba(0,0,0,0.08);
    }
    .section-{{ section.id }} .flip-card-inner.spinning {
      transition: none;
      animation: flipSpin 0.6s ease-in-out 3;
    }

    /* 翻开后的轻微弹跳过渡（在 rotateY(180deg) 基础上做轻微缩放回弹） */
    .section-{{ section.id }} .flip-card.flipped .flip-card-inner.bounce {
      animation: revealBounce 300ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    @keyframes revealBounce {
      0%   { transform: rotateY(180deg) scale(1.02); }
      40%  { transform: rotateY(180deg) scale(0.98); }
      70%  { transform: rotateY(180deg) scale(1.01); }
      100% { transform: rotateY(180deg) scale(1.00); }
    }

    .section-{{ section.id }} .flip-card.flipped .flip-card-inner { transform: rotateY(180deg); }
    .section-{{ section.id }} .flip-face {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      backface-visibility: hidden;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      background: #fff; 
    }
    .section-{{ section.id }} .flip-card-front {
      background: #fff;
      /* border: 2px solid #FFAE00; */
      position: relative;
      overflow: hidden;
      padding: 20px;
    }
    /* 统一正反两面图片尺寸 */
    .section-{{ section.id }} .flip-face img {
      width: 72%;
      /* height: 72%; */
      /* object-fit: contain; */
    }
    .section-{{ section.id }} .flip-card-front img.card-cover {
      /* filter: drop-shadow(0 2px 2px rgba(0,0,0,0.15)); */
      animation: floatCard 3.5s ease-in-out infinite;
    }
    .section-{{ section.id }} .flip-card:not(.flipped):hover .flip-card-inner {
      transform: translateY(-4px) scale(1.02);
      box-shadow: 0 10px 20px rgba(0,0,0,0.12);
    }
    .section-{{ section.id }} .flip-card-front::after {
      content: "";
      position: absolute;
      top: -100%; left: -50%;
      width: 200%; height: 300%;
      background: linear-gradient(120deg, rgba(255,255,255,0) 35%, rgba(255,255,255,0.5) 50%, rgba(255,255,255,0) 65%);
      transform: rotate(25deg);
      animation: shimmer 6s ease-in-out infinite;
      pointer-events: none;
    }
    .section-{{ section.id }} .flip-card-back { 
        transform: rotateY(180deg);
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding-top: 15px;
    }
    .section-{{ section.id }} .flip-card-back img {
       /* filter: drop-shadow(0 2px 2px rgba(0,0,0,0.15));  */ 
       width: 60%;
      }
    .section-{{ section.id }} .flip-card-back .prize-title{
      font-size: 12px;
    }
    /* 订阅模块 */
    .section-{{ section.id }} .spin-wheel-container .subscribe-box {
      grid-area: center;
      width: 100%;
      background: #fff;
      color: #fff;
      padding: 16px;
      border-radius: 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      align-items: center;
      justify-content: center;
    }
    .section-{{ section.id }} .spin-wheel-container .signup-container{
      width: 100%;
    }
    .section-{{ section.id }} .spin-wheel-container .signup-container{
      margin-bottom: 0;
      margin-top: 8px;
    }
    .section-{{ section.id }} .spin-wheel-container .subscribe-box input[type="email"] {
      padding: 10px 12px;
      border-radius: 8px;
      border: none;
      outline: none;
    }
    .section-{{ section.id }} .spin-wheel-container .subscribe-box button {
      background: #FFAE00;
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 10px 16px;
      font-weight: 700;
      cursor: pointer;
    }
    .section-{{ section.id }} .spin-wheel-container .field {
        border: 1px solid #DA2B2B ;
        border-radius: 10px;
    }
    .section-{{ section.id }} .subscribe-tip { text-align: center; margin-top: 8px; color: #fff; }


     /* 弹窗样式 */
   .section-{{ section.id }} .prize-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%; 
        height: 100%;
        background-color: rgba(0, 0, 0, 0.7);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

    .section-{{ section.id }} .modal-content {
        background: url('{{ section.settings.modal_bg | img_url: '1024x1024' }}');
        background-size: 100% 100%;
        background-position: center;
        padding: 30px;
        padding-bottom: 20px;
        width: 100%;
        height: 100%;
        overflow: auto;
        text-align: center;
        position: relative;
        animation: popIn 0.5s ease-out;
    }
    .section-{{ section.id }} .modal-content-wrap{
        width: 720px;
        height: 540px;
        overflow: hidden;
        border-radius: 12px; 
    }
    .section-{{ section.id }} #save-error-tip{
        color: red;
        text-align: center;
        width: 100%;
    }
    @keyframes popIn {
        0% { transform: scale(0.8); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }
    @keyframes flipSpin {
      0% { transform: rotateY(0); }
      50% { transform: rotateY(180deg); }
      100% { transform: rotateY(360deg); }
    }

    @keyframes floatCard {
      0% { transform: translateY(0); }
      50% { transform: translateY(-4px); }
      100% { transform: translateY(0); }
    }
    @keyframes shimmer {
      0% { transform: translateX(-20%) rotate(25deg); opacity: 0.0; }
      20% { transform: translateX(0) rotate(25deg); opacity: 0.35; }
      40% { transform: translateX(20%) rotate(25deg); opacity: 0.0; }
      100% { transform: translateX(20%) rotate(25deg); opacity: 0.0; }
    }

    .section-{{ section.id }} .modal-close {
