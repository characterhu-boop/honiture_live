<li>
	<div class="mega-menu-promotion">
		<div class="mega-menu-promotion--image">
		{%- render 'responsive-image', image: promotion_image, sizes: '670x0', priority: 'low' -%}
		</div>
		<div class="mega-menu-promotion--content">
			{%- if promotion_heading -%}
			<h6>{{ promotion_heading }}<span>{%- render 'svg-icons' with 'thb-mobile-menu-forward' -%}</span></h6>
			{%- endif -%}
			{%- if promotion_content -%}
			<p>{{ promotion_content }}</p>
			{%- endif -%}
		</div>
		{%- if promotion_link != empty -%}<a href="{{ promotion_link }}" class="mega-menu-promotion--link"></a>{%- endif -%}
	</div>
</li>
