<div class="linked-products-block" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <span class="linked-products-title">{{ block.settings.title | escape }}</span>
          {%- endif -%}

          <div class="linked-products-grid">
            {%- assign p1 = block.settings.product_1 -%}
            {%- assign t1 = block.settings.product_title_1 | strip -%}
            {%- if p1 != blank -%}
              <a class="linked-products-item{% if block.settings.show_images and p1.featured_image %} has-image{% endif %}" href="{{ p1.url }}">
                {%- if block.settings.show_images and p1.featured_image -%}
                  {{ p1.featured_image | image_url: width: 480 | image_tag: sizes: '(min-width: 1100px) 16vw, 33vw', widths: '200,300,400,480', class: 'linked-products-image' }}
                {%- endif -%}
                <div class="linked-products-item-content">
                  <div class="linked-products-item-title small-caption">{{ t1 | default: p1.title }}</div>
                  {% comment %} <div class="linked-products-item-price">{{ p1.price | money }}</div> {% endcomment %}
                </div>
              </a>
            {%- elsif t1 != blank -%}
              <div class="linked-products-item">
                <div class="linked-products-item-content">
                  <div class="linked-products-item-title small-caption">{{ t1 }}</div>
                </div>
              </div>
            {%- endif -%}

            {%- assign p2 = block.settings.product_2 -%}
            {%- assign t2 = block.settings.product_title_2 | strip -%}
