          </div>

          <style>
            .linked-products-block{ margin-bottom: 15px; }
            .linked-products-title { font-size:15px; font-weight: 500; }
            .linked-products-grid { display:flex; gap: 16px; margin-top: 15px; overflow-x:auto; -webkit-overflow-scrolling: touch; scroll-snap-type: x mandatory; flex-wrap: nowrap; flex-direction: row; }
            .linked-products-item { text-decoration: none; color: inherit; display:flex; align-items:center; flex-direction: column; border: 1px solid #dadce0; border-radius: 5px; flex: 0 0 25%; min-width: 25%; scroll-snap-align: start; }
            .linked-products-image { width: 100%; height: auto; border-radius: 5px; object-fit: cover; }
            .linked-products-item-content { flex: 1; display:flex; flex-direction: column; gap: 6px; padding: 8px 12px; text-align: center; }
            .linked-products-item-title { font-size: 13px; }
            .linked-products-item-price { font-size: 13px; }
            .linked-products-item.has-image .linked-products-item-content { 
              border-top: 1px solid #dadce0; 
              width: 100%;
             }

            /* 移动端 */
            @media screen and (max-width: 767px) {
              .linked-products-image { 
                width: 100%; height: auto; border-radius: 5px; object-fit: cover;
                
               }
              .linked-products-item { 
                flex: 0 0 40%; min-width: 40%; 
                flex-direction: column;
              }

            }
             .linked-products-grid{
              padding-bottom: 15px;
             }
         </style>
        </div>