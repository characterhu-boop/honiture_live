<script>
  (function () {
    const sectionId = "{{ section.id }}";
    // const base_url_test = "https://shopify-api-test-01.external.sub.puture-in.com";
    const base_url_test = "http://localhost:8083"; // 测试环境
    const base_url = "https://shopify-api.puture-in.com";

    const copyCode = (element) => {
      const code = element.textContent.replace("Code: ", "").trim();
      navigator.clipboard
        .writeText(code)
        .then(() => {
          const originalText = `Code: ${code}`;
          element.textContent = "Copied!";
          setTimeout(() => {
            element.textContent = originalText;
          }, 2000);
        })
        .catch((err) => {
          console.error("Failed to copy code: ", err);
        });
    };

    document.addEventListener("DOMContentLoaded", function () {
  // 获取DOM元素
  const prizeModal = document.getElementById(`flip-card-prizeModal-${sectionId}`);
  const prizeTitle = document.getElementById(`flip-card-prizeTitle-${sectionId}`);
  const prizeDescription = document.getElementById(`flip-card-prizeDescription-${sectionId}`);
  const prizeName = document.getElementById(`flip-card-prizeName-${sectionId}`);
  const prizeImage = document.getElementById(`flip-card-prizeImage-${sectionId}`);
  const closeModal = document.getElementById(`flip-card-closeModal-${sectionId}`);
  const prizeCode = document.getElementById(`flip-card-prizeCode-${sectionId}`);
  const cardGrid = document.getElementById(`flip-card-grid-${sectionId}`);
  const modalContentWrap = prizeModal ? prizeModal.querySelector(".modal-content-wrap") : null;
  // const wheelOverlay = document.getElementById("wheelOverlay"); // 蒙层元素
  const rootEl = document.getElementById(`flip-card-root-${sectionId}`);
  const activityId = rootEl ? rootEl.dataset.activity : "";
  const isTest = rootEl ? rootEl.dataset.istest : ""; 
  // 地址相关元素
  const addressSection = document.getElementById(`flip-card-addressSection-${sectionId}`);
  const addressDisplay = document.getElementById(`flip-card-addressDisplay-${sectionId}`);
  const editAddressBtn = document.getElementById(`flip-card-editAddressBtn-${sectionId}`);
  const addressForm = document.getElementById(`flip-card-addressForm-${sectionId}`);
  const saveAddressBtn = document.getElementById(`flip-card-saveAddressBtn-${sectionId}`);
  const cancelAddressBtn = document.getElementById(`flip-card-cancelAddressBtn-${sectionId}`);

  // 当前中奖记录数据
  let currentDrawRecord = null;
  // 转盘实例
  let myLucky = null;
  // 添加抽奖状态标识
  let isSpinning = false;
  // 订阅状态
  let subscribed = false;
  let subscribedEmail = "";
  let isRunning = false;
  let hasPlayed = false;

  function setTip(message) {
    try {
      const container = document.getElementById(`flip-card-container-${sectionId}`) || document.body;
      let toast = container.querySelector('.flip-card-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.className = 'flip-card-toast';
        container.appendChild(toast);
      }
      if (!message) {
        toast.classList.remove('is-visible');
        return;
      }
      toast.textContent = message;
      toast.classList.add('is-visible');
      clearTimeout(toast._timer);
      toast._timer = setTimeout(() => {
        toast.classList.remove('is-visible');
      }, 2400);
    } catch (e) {}
  }

  function setHighlighted(cards, index) {
    for (let i = 0; i < cards.length; i++) {
      if (i === index) cards[i].classList.add('is-highlighted');
      else cards[i].classList.remove('is-highlighted');
    }
  }

  function getTargetIndex(prize, len) {
    const seed = String((prize && (prize.prizeId || prize.id || prize.discountCode || prize.prizeName)) || Date.now());
    let hash = 0;
    for (let i = 0; i < seed.length; i++) {
      hash = (hash * 31 + seed.charCodeAt(i)) >>> 0;
    }
    return len ? (hash % len) : 0;
  }

  function computePerimeterOrder(gridEl) {
    const nodes = Array.from(gridEl ? gridEl.querySelectorAll('.flip-card') : []);
    if (!nodes.length) return nodes;
    const g = gridEl.getBoundingClientRect();
    const cx = g.left + g.width / 2;
    const cy = g.top + g.height / 2;
    const maxR = Math.max(g.width, g.height) / 2;
    const minPerimeterR = maxR * 0.35;
    const items = nodes.map(n => {
      const r = n.getBoundingClientRect();
      const x = r.left + r.width / 2;
      const y = r.top + r.height / 2;
      const dx = x - cx;
      const dy = y - cy;
      const dist = Math.hypot(dx, dy);
      const ang = Math.atan2(dy, dx); // -PI..PI, 0 at +X
      return { n, x, y, dist, ang };
    });
    // 仅保留外围卡片（过滤中心卡片）
    let ring = items.filter(it => it.dist >= minPerimeterR);
    if (!ring.length) ring = items;
    // 顺时针排序（从 -PI 到 PI 转换到 0..2PI）
    ring.sort((a, b) => {
      const A = (a.ang + 2 * Math.PI) % (2 * Math.PI);
      const B = (b.ang + 2 * Math.PI) % (2 * Math.PI);
      return A - B;
    });
    // 将起点旋到左上角附近（y 最小，x 最小优先）
    let startIdx = 0;
    for (let i = 1; i < ring.length; i++) {
      if (ring[i].y < ring[startIdx].y - 2 || (Math.abs(ring[i].y - ring[startIdx].y) <= 2 && ring[i].x < ring[startIdx].x)) {
        startIdx = i;
      }
    }
    const ordered = ring.slice(startIdx).concat(ring.slice(0, startIdx)).map(it => it.n);
    return ordered;
  }

  function runMarqueeTo(orderedCards, fromIndex, toIndex) {
    const len = orderedCards.length;
    if (!len) return Promise.resolve(0);
    let current = fromIndex;
    const extraCycles = 1;
    const distance = (toIndex - current + len) % len;
    const totalSteps = extraCycles * len + distance;

    return new Promise((resolve) => {
      let step = 0;
      const runStep = () => {
        step += 1;
        current = (current + 1) % len;
        setHighlighted(orderedCards, current);

        const t = step / totalSteps;
        const delay = Math.floor(50 + Math.pow(t, 2.3) * 200);
        if (step >= totalSteps) {
          resolve(current);
          return;
        }
        setTimeout(runStep, delay);
      };
      runStep();
    });
  }

  async function drawPrize(email) {
    const response = await fetch(`${isTest==='true'?base_url_test:base_url}/draw-records/draw`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        activityId: Number(activityId),
        userEmail: email,
        drawType: 'subscribe'
      })
    });
    const result = await response.json();
    if (!result || result.code !== 200) throw new Error((result && result.msg) || 'draw failed, please try again later');
    return result.data;
  }

  async function onPlay() {
    if (isRunning || hasPlayed) return;
    const email = (emailInput ? emailInput.value : '').trim();
    if (!validateEmail(email)) {
      setTip('Please enter a valid email');
      return;
    }

    isRunning = true;
    setTip('');
    playBtns.forEach((btn) => btn.setAttribute('disabled', 'disabled'));
    if (emailInput) emailInput.setAttribute('disabled', 'disabled');

    try {
      try {
        localStorage.setItem('flipCardEmail', email);
      } catch (e) {}

      const orderedCards = computePerimeterOrder(cardGrid);
      if (!orderedCards.length) {
        throw new Error('No cards found');
      }

      let fastIndex = -1;
      const startFast = Date.now();
      let fastTimer = null;
      fastTimer = setInterval(() => {
        fastIndex = (fastIndex + 1) % orderedCards.length;
        setHighlighted(orderedCards, fastIndex);
      }, 80);

      let prize = null;
      try {
        prize = await drawPrize(email);
      } finally {
        const elapsed = Date.now() - startFast;
        const minFast = 600;
        if (elapsed < minFast) {
          await new Promise((r) => setTimeout(r, minFast - elapsed));
        }
        if (fastTimer) clearInterval(fastTimer);
      }

      function getVisualOffset(len) {
        try {
          if (window.crypto && window.crypto.getRandomValues) {
            const arr = new Uint32Array(1);
            window.crypto.getRandomValues(arr);
            return arr[0] % len;
          }
        } catch(e){}
        return Math.floor(Math.random() * len);
      }

      const baseIndex = getTargetIndex(prize, orderedCards.length);
      const visualIndex = (baseIndex + getVisualOffset(orderedCards.length)) % orderedCards.length;
      const finalIndex = await runMarqueeTo(orderedCards, fastIndex, visualIndex);

      const targetCard = orderedCards[finalIndex];
      await revealPrizeOnCard(targetCard, prize);

      hasPlayed = true;
    } catch (e) {
      setTip((e && e.message) ? e.message : 'Something went wrong');
      playBtns.forEach((btn) => btn.removeAttribute('disabled'));
      if (emailInput) emailInput.removeAttribute('disabled');
    } finally {
      isRunning = false;
    }
  }

  // 关闭弹窗
  closeModal.addEventListener("click", function () {
    prizeModal.style.display = "none";
    if (modalContentWrap) {
      modalContentWrap.style.height = "720px";
      modalContentWrap.style.height = "540px";
    }
  });
  const emailInput = document.getElementById(`flip-card-email-${sectionId}`);
  const playBtnDesktop = document.getElementById(`flip-card-play-cta-${sectionId}`);
  const playBtnInline = document.getElementById(`flip-card-play-inline-${sectionId}`);
  const playBtns = [playBtnDesktop, playBtnInline].filter(Boolean);


  // 地址编辑功能
  editAddressBtn.addEventListener("click", function () {
    showAddressForm();
  });

  cancelAddressBtn.addEventListener("click", function () {
    hideAddressForm();
  });

  saveAddressBtn.addEventListener("click", function () {
    saveAddress();
  }); 

  if (prizeCode) {
    prizeCode.addEventListener('click', function () {
      copyCode(prizeCode);
    });
  }

  playBtns.forEach((btn) => {
    btn.setAttribute('disabled', 'disabled');
    btn.addEventListener('click', onPlay);
  });


  // 点击弹窗外部也可关闭
  // prizeModal.addEventListener('click', function(e) {
  //     if (e.target === prizeModal) {
  //         prizeModal.style.display = 'none';
  //     }
  // });

  // 从服务端获取数据的函数
  function fetchFlipCardData() {
    return new Promise((resolve, reject) => {
      // 使用Shopify的AJAX API获取数据
      fetch(`${isTest==='true'?base_url_test:base_url}/activity/${activityId}`)
        .then((response) => {
          if (!response.ok) {
            throw new Error("Network response was not ok");
          }
          return response.json();
        })
        .then((data) => {
          console.log(data.data, "奖品信息", activityId);
          if (data.code === 200) {
            resolve(data.data);
          } else {
            reject(data.msg);
          }
        })
        .catch((error) => {
          console.error("Error fetching flip card data:", error);
          reject(error);
        });
    });
  }

  // 显示地址表单
  function showAddressForm() {
    if (!currentDrawRecord) return;

    // 填充表单数据
    document.getElementById(`flip-card-consignee-${sectionId}`).value =
      currentDrawRecord.consignee || "";
    document.getElementById(`flip-card-countryCode-${sectionId}`).value =
      currentDrawRecord.countryCode || "";
    document.getElementById(`flip-card-stateOrProvinceCode-${sectionId}`).value =
      currentDrawRecord.stateOrProvinceCode || "";
    document.getElementById(`flip-card-city-${sectionId}`).value = currentDrawRecord.city || "";
    document.getElementById(`flip-card-addressLineOne-${sectionId}`).value =
      currentDrawRecord.addressLineOne || "";
    document.getElementById(`flip-card-addressLineTwo-${sectionId}`).value =
      currentDrawRecord.addressLineTwo || "";
    document.getElementById(`flip-card-postalCode-${sectionId}`).value =
      currentDrawRecord.postalCode || "";
    document.getElementById(`flip-card-phone-${sectionId}`).value = currentDrawRecord.phone || "";
    document.getElementById(`flip-card-userEmail-${sectionId}`).value = currentDrawRecord.email || "";

    addressDisplay.style.display = "none";
    editAddressBtn.style.display = "none";
    addressForm.classList.add("active");
  }

  // 隐藏地址表单
  function hideAddressForm() {
    addressForm.classList.remove("active");
    addressDisplay.style.display = "block";
    editAddressBtn.style.display = "inline-block";
  }

  // 保存地址
  function saveAddress() {
    if (!currentDrawRecord) return;

    const updatedData = {
      id: currentDrawRecord.id,
      activityId: currentDrawRecord.activityId,
      orderNumber: currentDrawRecord.orderNumber,
      consignee: document.getElementById(`flip-card-consignee-${sectionId}`).value,
      countryCode: document.getElementById(`flip-card-countryCode-${sectionId}`).value,
      stateOrProvinceCode: document.getElementById(`flip-card-stateOrProvinceCode-${sectionId}`)
        .value,
      city: document.getElementById(`flip-card-city-${sectionId}`).value,
      addressLineOne: document.getElementById(`flip-card-addressLineOne-${sectionId}`).value,
      addressLineTwo: document.getElementById(`flip-card-addressLineTwo-${sectionId}`).value,
      postalCode: document.getElementById(`flip-card-postalCode-${sectionId}`).value,
      phone: document.getElementById(`flip-card-phone-${sectionId}`).value,
      email: document.getElementById(`flip-card-userEmail-${sectionId}`).value,
    };

    // 调用保存地址的API
    fetch(`${isTest==='true'?base_url_test:base_url}/draw-records/updateAddress`, {
      method: "PUT",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify(updatedData),
    })
      .then((response) => response.json())
      .then((result) => {
        if (result.code === 200) {
          // 更新当前记录数据
          currentDrawRecord = { ...currentDrawRecord, ...updatedData };
          // 更新显示的地址
          displayAddress(currentDrawRecord);
          // 隐藏表单
          hideAddressForm();
          // 显示成功提示（可选）
        } else {
          // save-error-tip 中展示错误提示
          const saveTip = document.getElementById(`flip-card-save-error-tip-${sectionId}`);
          saveTip.textContent = result.msg || "Failed to update address. Please try again.";
        }
      })
      .catch((error) => {
        console.error("Error saving address:", error);
      });
  }

  // 显示地址信息
  function displayAddress(record) {
    if (!record) return;

    const addressLines = [
      record.consignee,
      record.addressLineOne,
      record.addressLineTwo,
      `${record.city}, ${record.stateOrProvinceCode} ${record.postalCode}`,
      record.countryCode,
      record.email,
      record.phone,
    ].filter((line) => line && line.trim() !== "");

    addressDisplay.innerHTML = `
                <strong>Shipping Address:</strong><br>
                ${addressLines.join(", ")}
            `;
  }

  // 显示中奖弹窗
  function showPrizeModal(prize) {
    // 保存中奖记录数据
    currentDrawRecord = prize;
    prizeTitle.innerHTML = prozeTip[prize.prizeType]?.title;
    prizeDescription.textContent = prozeTip[prize.prizeType]?.description;
    prizeName.textContent = prize.prizeName || "";
    prizeImage.src =
      prize.prizeImageUrl ||
      "https://cdn.shopify.com/s/files/1/0277/1160/2768/files/thankyou.webp?v=1756268576";
    // 0 谢谢回顾 1 优惠券 2 实物
    prizeImage.classList.remove("prize-image-tk");
    if (prize.prizeType === 1) {
      prizeCode.textContent = `Code: ${prize.discountCode || "COUPONCODE"}`;
      prizeCode.style.display = "block";
      prizeImage.style.display = "none";
      addressSection.style.display = "none";
      // modalContentWrap.style.width = "520px";
      // modalContentWrap.style.height = "400px"; 
    } else { 
      if (prize.prizeType === 0) {
          prizeImage.src ="https://cdn.shopify.com/s/files/1/0277/1160/2768/files/thankyou.webp?v=1756268576";
          prizeCode.style.display = "none";
          prizeImage.classList.add("prize-image-tk");
          prizeImage.style.display = "block";
          addressSection.style.display = "none";
          // modalContentWrap.style.width = "520px";
          // modalContentWrap.style.height = "360px";
      } else if (prize.prizeType === 2) {
         // 显示地址信息（仅对实物奖品显示地址）
        // 实物奖品
        addressSection.style.display = "block"; 
        prizeImage.style.display = "block";
        prizeCode.style.display = "none";
        displayAddress(prize);
      } 
    }

    prizeModal.style.display = "flex";

    // 添加庆祝效果
    createConfetti();
  }

  async function revealPrizeOnCard(card, prize) {
    if (!card) return;
    const inner = card.querySelector('.flip-card-inner');
    if (!inner) return;
    if (card.classList.contains('flipped')) return;

    const gridEl = document.getElementById(`flip-card-grid-${sectionId}`);
    const coverUrlSpin = gridEl && gridEl.dataset ? gridEl.dataset.cardCover : '';
    if (coverUrlSpin) {
      const frontImgSpin = card.querySelector('.flip-card-front img');
      const backImgSpin = card.querySelector('.flip-card-back img');
      if (frontImgSpin) frontImgSpin.src = coverUrlSpin;
      if (backImgSpin) backImgSpin.src = coverUrlSpin;
    }

    inner.classList.add('spinning');
    await new Promise((resolve) => {
      inner.addEventListener('animationend', () => resolve(), { once: true });
    });
    inner.classList.remove('spinning');

    const backImg = card.querySelector('.flip-card-back img');
    const prizeTitle = card.querySelector('.prize-title');
    if (backImg) {
      const apiImg = prize && (prize.prizeImageUrl || prize.imageUrl || prize.imgUrl);
      if (apiImg) {
        backImg.src = apiImg;
        backImg.style.width = '40%';
      }
    }
    if (prizeTitle) {
      const apiTitle = prize && (prize.prizeName || prize.title || prize.name);
      prizeTitle.textContent = apiTitle || '';
    }

    card.classList.add('flipped');
    inner.classList.add('bounce');
    inner.addEventListener('animationend', () => {
      inner.classList.remove('bounce');
    }, { once: true });

    setTimeout(() => {
      showPrizeModal(prize);
    }, 250);
  }
  
  const prozeTip = {
    0: {
      title: "Thank you！",
      description:
        "Thank you for your trust and support in Honiture, and look forward to your 100% lucky index next time!",
    },
    1: {
      title: "Congratulations!<br /> Get a Honiture coupon! <br />Use it quickly!",
      description: "Each discount code is limited to one time.",
    },
    2: {
      title: "Congratulations!",
      description:
        "We will deliver free gifts to your hands within a week! Stay tuned.",
    },
  };
  
  // 创建庆祝效果
  function createConfetti() {
    // 简单的庆祝效果 - 实际项目中可以使用专门的库如canvas-confetti
    const colors = [
      "#ff0000",
      "#00ff00",
      "#0000ff",
      "#ffff00",
      "#ff00ff",
      "#00ffff",
    ];
    const celebrate = document.createElement("div");
    celebrate.className = "celebrate";
    prizeModal.appendChild(celebrate);

    for (let i = 0; i < 50; i++) {
      const confetti = document.createElement("div");
      confetti.style.position = "absolute";
      confetti.style.width = "10px";
      confetti.style.height = "10px";
      confetti.style.backgroundColor =
        colors[Math.floor(Math.random() * colors.length)];
      confetti.style.borderRadius = Math.random() > 0.5 ? "50%" : "0";
      confetti.style.left = Math.random() * 100 + "vw";
      confetti.style.setProperty('--rotate', `${Math.random() * 360}deg`);
      confetti.style.animation = `flipCardFall-${sectionId} ${
        Math.random() * 2 + 1
      }s linear forwards`;

      if (!document.getElementById(`flipCardFallStyle-${sectionId}`)) {
        const style = document.createElement("style");
        style.id = `flipCardFallStyle-${sectionId}`;
        style.textContent = `
          @keyframes flipCardFall-${sectionId} {
            to {
              transform: translateY(100vh) rotate(var(--rotate));
              opacity: 0;
            }
          }
        `;
        document.head.appendChild(style);
      }

      celebrate.appendChild(confetti);

      // 移除元素
      setTimeout(() => {
        confetti.remove();
      }, 3000);
    }

    // 移除庆祝容器
    setTimeout(() => {
      celebrate.remove();
    }, 3000);
  }
  
  // 邮箱格式校验函数
  function validateEmail(email) {
    // 基本的邮箱格式正则表达式
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return emailRegex.test(email);
  }

  
  // lucky canvas 不支持单词换行，因此需要手动处理换行逻辑
  function getFonts(item, isMobile) {
    const fonts = [];
    let baseTop = 25; // 起始位置
    const lineHeight = 20; // 行高
    const baseConfig = {
      fontSize: isMobile? "13px":"27px",
      fontWeight: "700",
      lengthLimit: "100%",
      fontColor: "#f2dfa7",
    };
    // 处理标题，支持<br>换行
    if (item.name && item.name.includes("<br>")) {
      const lines = item.name.split("<br>");
      lines.forEach((line, index) => {
        fonts.push({
          text: line,
          top: `${baseTop + index * lineHeight}%`,
          ...baseConfig,
        });
      });
      baseTop += lines.length * lineHeight; // 更新基础位置
    } else if (item.name) {
      fonts.push({
        text: item.name,
        top: `${baseTop}%`,
        ...baseConfig,
      });
      baseTop += lineHeight; // 更新基础位置
    }

    // 处理描述文本
    if (item.description) {
      fonts.push({
        text: item.description,
        top: `${baseTop}%`,
        fontSize: isMobile?"12px":"15px",
      });
    }

    return fonts;
  }
  
  // 保存数据变量，用于在转盘初始化后使用
  let data = null;
  
  /// 初始化环形 10 张翻牌卡片（第一排4、第二排2+订阅、第三排4）
  function initFlipCards(wheelData) {
    data = wheelData; // 保存数据供后续使用
    const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);

    const gridEl = document.getElementById(`flip-card-grid-${sectionId}`);
    const centerBox = document.getElementById(`flip-card-subscribeBox-${sectionId}`);
    gridEl.innerHTML = '';
    if (isMobile) {
      // 移动端：订阅模块移到九宫格下方
      if (centerBox && gridEl && gridEl.parentNode) {
        gridEl.parentNode.insertBefore(centerBox, gridEl.nextSibling);
      }
    } else {
      // 桌面端：保持订阅模块在网格中心区域
      gridEl.appendChild(centerBox);
    }
    const coverUrl = gridEl.dataset.cardCover || 'https://cdn.shopify.com/s/files/1/0277/1160/2768/files/card_back.webp?v=1756900100';

    // 移动端渲染9张卡片以匹配九宫格；桌面端保持10张
    const areas = isMobile
      ? ['a1','a2','a3','a4','a5','a6','a7','a8','a9']
      : ['a1','a2','a3','a4','a5','a6','a7','a8','a9','a10'];

    for (let i = 0; i < areas.length; i++) {
      const card = document.createElement('div');
      card.className = 'flip-card';
      card.dataset.index = String(i);
      card.style.gridArea = areas[i];
      card.innerHTML = `
        <div class="flip-card-inner">
          <div class="flip-face flip-card-front">
            <img class="card-cover" src="${coverUrl}" alt="card-cover" />
          </div>
          <div class="flip-face flip-card-back">
            <img alt="prize" />
            <div class="prize-title"></div>
          </div>
        </div>
      `;
      gridEl.appendChild(card);
    }

    playBtns.forEach((btn) => btn.removeAttribute('disabled'));
    setTip('');
  }

  // 初始化环形 10 张翻牌卡片
  fetchFlipCardData().then((wheelData) => {
    initFlipCards(wheelData);
  
    // 隐藏加载指示器
    // const loadingElement = document.getElementById('wheelLoading');
    // if (loadingElement) {
