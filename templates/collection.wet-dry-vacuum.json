        "heading_Vce839": {
          "type": "heading",
          "disabled": true,
          "settings": {
            "text": "Cordless Vacuum Cleaners",
            "marker_style": "style1",
            "size": "h3",
            "heading_tag": "h3",
            "marker_color": "#fd6262"
          }
        },
        "text_9zmxzM": {
          "type": "text",
          "settings": {
            "text": "<h1>Cordless Vacuum Cleaners<\/h1><p>Honiture cordless vacuum cleaner series offers powerful suction with the convenience of wireless operation. Designed for effortless cleaning, these vacuums are lightweight, portable, and equipped with advanced features such as anti-tangle technology, LED highlights, and wider cleaning paths. Perfect for daily use, they deliver exceptional performance, whether for quick cleanups or deep cleaning, making home maintenance easier and more efficient.<\/p>",
            "custom_liquid": "",
            "size": "text-size-small"
          }
        }
      },
